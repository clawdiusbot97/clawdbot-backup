# OpenClaw Backup Configuration
# Copy this file to ~/.openclaw/backup.env and fill in your values.

# Private GitHub repository URL (must already exist)
BACKUP_GITHUB_REPO=https://github.com/yourusername/openclaw-backup.git

# GitHub personal access token with repo permissions
# Optional if using SSH key authentication (use SSH URL above)
BACKUP_GITHUB_TOKEN=ghp_your_token_here

# Optional: Temporary directory for backup processing
# BACKUP_TEMP_DIR=/tmp/openclaw-backup

# Optional: Exclude patterns (comma-separated globs)
# BACKUP_EXCLUDE_PATTERNS=**/node_modules,**/venv