# Telegram Bot Token (from BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Target chat/channel ID (e.g., -1001234567890 for groups)
BROKIA_INBOX_CHAT_ID=your_chat_id_here

# Mission Control Integration
MISSION_CONTROL_BASE_URL=http://localhost:3000

# Classification behavior
INTAKE_USE_LLM_CLASSIFIER=false

# Dedupe window (minutes)
INTAKE_DEDUPE_WINDOW_MINUTES=10

# State file path (relative to skill root)
INTAKE_STATE_PATH=./state/state.json