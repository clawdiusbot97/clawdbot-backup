{"id":"4478959617","type":"page","subType":"live","subtype":"live","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/4478959617","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvNDQ3ODk1OTYxNw==","status":"current","title":"Recomendaciones Detalladas de Configuración commerce-service","version":{"by":{"type":"known","accountId":"5f3d2a10ea5e2f003979db69","accountType":"atlassian","email":"","publicName":"Ignacio Jorge","profilePicture":{"path":"/wiki/aa-avatar/5f3d2a10ea5e2f003979db69","width":48,"height":48,"isDefault":false},"displayName":"Ignacio Jorge","isExternalCollaborator":false,"isGuest":false,"locale":"en_US","accountStatus":"active","_expandable":{"operations":"","personalSpace":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/user?accountId=5f3d2a10ea5e2f003979db69"}},"when":"2025-12-22T15:35:07.518Z","friendlyWhen":"Dec 22, 2025","message":"Autosaved","number":2,"minorEdit":false,"ncsStepVersion":"79","ncsStepVersionSource":"ncs-ack","confRev":"confluence$content$4478959617.38","contentTypeModified":false,"_expandable":{"collaborators":"","content":"/rest/api/content/4478959617"},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/4478959617/version/2"}},"ancestors":[{"id":"2178416778","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2178416778","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjE3ODQxNjc3OA==","status":"current","title":"Bancard","macroRenderedOutput":{},"extensions":{"position":878},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2178416778/restriction/byOperation","history":"/rest/api/content/2178416778/history","body":"","version":"","descendants":"/rest/api/content/2178416778/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2178416778/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2178416778","tinyui":"/x/igDYgQ","editui":"/pages/resumedraft.action?draftId=2178416778","webui":"/spaces/BAN/overview","edituiv2":"/spaces/BAN/pages/edit-v2/2178416778"}},{"id":"3517906970","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/3517906970","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMzUxNzkwNjk3MA==","status":"current","title":"Documentos","macroRenderedOutput":{},"extensions":{"position":581175418},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/3517906970/restriction/byOperation","history":"/rest/api/content/3517906970/history","body":"","version":"","descendants":"/rest/api/content/3517906970/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3517906970/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/3517906970","tinyui":"/x/GgCv0Q","editui":"/pages/resumedraft.action?draftId=3517906970","webui":"/spaces/BAN/pages/3517906970/Documentos","edituiv2":"/spaces/BAN/pages/edit-v2/3517906970"}},{"id":"4445437971","type":"page","subType":"live","subtype":"live","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/4445437971","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvNDQ0NTQzNzk3MQ==","status":"current","title":"Análisis de uso de memoria de commerce-service","macroRenderedOutput":{},"extensions":{"position":30920859},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/4445437971/restriction/byOperation","history":"/rest/api/content/4445437971/history","body":"","version":"","descendants":"/rest/api/content/4445437971/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/4445437971/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/4445437971","tinyui":"/x/EwD4CAE","editui":"/spaces/BAN/pages/4445437971/An+lisis+de+uso+de+memoria+de+commerce-service","webui":"/spaces/BAN/pages/4445437971/An+lisis+de+uso+de+memoria+de+commerce-service","edituiv2":"/spaces/BAN/pages/4445437971/An+lisis+de+uso+de+memoria+de+commerce-service"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<h2 local-id=\"75603809-ba6d-4682-b4c3-6a08e3b84108\">1. Estrategia general de memoria en el host (30GB)</h2><p local-id=\"623fa95e-875f-4e65-9ee9-b99da47aeeef\">Primero pensemos en el servidor completo:</p><ul local-id=\"be7cec06-085c-44a9-8953-d80599ed16c4\"><li local-id=\"e3cf2915-12a8-46ac-8cc5-dd69485a5c73\"><p local-id=\"f201d9ad-c348-4de9-9446-34270fb2e2cb\">RAM total: <strong>30GB</strong></p></li><li local-id=\"7c8ec4e2-8a83-415a-9536-2c2232db7a1e\"><p local-id=\"74e8407b-24cf-4e85-98e1-33afb9aa1980\">Tenemos:</p><ul local-id=\"adec15ed-892f-4c15-82d9-fc4b9d948cd3\"><li local-id=\"d6fd16f7-75aa-4245-b539-321685d892ba\"><p local-id=\"f53d3cff-896d-40fd-b7bb-a592c51fb53b\">1 contenedor JRuby Puma (commerce-service API)</p></li><li local-id=\"27eeeaa9-672f-4f37-a38b-15adce075060\"><p local-id=\"997d1576-6b28-46c8-9572-50f2a59c63ba\">1 contenedor JRuby Sidekiq (commerce-service jobs)</p></li><li local-id=\"1585b33c-1f52-4064-95a1-14e22995847d\"><p local-id=\"dbf73068-652d-4806-ba57-b54d11716aac\">2 contenedores m&aacute;s de vpos-service (Puma + Sidekiq) que consumen poco</p></li><li local-id=\"5311da4c-71a9-431f-8efd-b2de6c14cb91\"><p local-id=\"cd334b19-b375-4196-beef-619da2ff0dc4\">el propio sistema operativo y daemons varios</p></li></ul></li></ul><p local-id=\"95cbb268-5b26-4c62-a0e6-3aad55d12943\">Regla de dedo razonable:</p><ul local-id=\"621a36a0-941c-4bc0-8bbf-1120d8e33fd7\"><li local-id=\"1f6863a0-ac58-4953-8569-8e5f60af4e55\"><p local-id=\"f8f19d2b-1ed2-49b0-8535-e33517b2d655\">No usar m&aacute;s del <strong>75&ndash;80%</strong> de la RAM del host como <em>suma de l&iacute;mites de contenedores JVM</em>.</p></li><li local-id=\"fb6b580b-1fa4-499a-8a00-b70c0ef6906a\"><p local-id=\"43316c97-6793-4d4d-9e55-1aafb795db99\">Dejar al menos <strong>4&ndash;6GB</strong> libres para:</p><ul local-id=\"97a70c80-0b42-47e0-b70f-507cd4795ffe\"><li local-id=\"5a10ec53-6f60-41c0-999e-9c33deb566a1\"><p local-id=\"26a2c26d-2d97-4d22-aaf3-7d9ceac3da40\">OS</p></li><li local-id=\"3cc753c2-1888-4238-b941-d694c66c84a8\"><p local-id=\"f2e444b8-f15f-42c1-ad8c-73369a9eae6e\">page cache</p></li><li local-id=\"70d96634-b0bd-47a4-81d6-5cbcb22de341\"><p local-id=\"f42e7e63-5a00-421c-bf47-e3bbb55cb684\">picos inesperados</p></li></ul></li></ul><p local-id=\"57e211a2-b712-4553-9e9f-96908ef3678a\">Con 30GB totales:</p><ul local-id=\"36361eaa-de2f-426e-9d7c-02bf1cdb4860\"><li local-id=\"4733b05d-27d0-48fe-9092-ad2bd759a981\"><p local-id=\"9b8fb555-10da-4678-a88a-90a1cdae2baf\">Reservamos ~<strong>5GB</strong> para OS/overhead.</p></li><li local-id=\"5b580abd-46f4-49ea-8653-18b790817d63\"><p local-id=\"631a44a6-4aca-4c6c-ba40-8499f5f5357f\">Quedan ~<strong>25GB</strong> para contenedores.</p></li><li local-id=\"95f668fb-31ee-42f4-a4ba-4e896596faac\"><p local-id=\"4a38d018-6c29-4723-9a43-d3af84f7b448\">Como los otros dos contenedores &ldquo;consumen poco&rdquo;, asumamos que entre los dos usan <strong>4&ndash;6GB</strong> de l&iacute;mite de RAM.</p></li><li local-id=\"c1110ee7-86c4-45b3-9d8c-83daa7848933\"><p local-id=\"71d5277d-42cc-4580-8818-a5f035aa02fc\">Quedan <strong>19&ndash;21GB</strong> para los dos contenedores grandes de commerce-service.</p></li></ul><p local-id=\"8bea5da2-801d-4e45-9114-3d720f1c50fc\">Conclusi&oacute;n pr&aacute;ctica - se puede armar algo como:</p><ul local-id=\"9f48858f-7fb9-45b3-ad4a-a718f4cf324b\"><li local-id=\"c0844acf-a092-4601-943c-03fece1a266d\"><p local-id=\"afde7496-92ab-41cc-8a42-d9d1a4480416\"><strong>commerce-service Puma container</strong>: l&iacute;mite entre <strong>10&ndash;12GB</strong></p></li><li local-id=\"49e5c95b-118c-4821-b57c-8b516af0382f\"><p local-id=\"ac1e46c6-adc4-4f40-83e7-c7373a8563cb\"><strong>commerce-service Sidekiq container</strong>: l&iacute;mite entre <strong>6&ndash;8GB</strong></p></li><li local-id=\"bf0b8d94-3ba1-4548-b67e-f2274852a285\"><p local-id=\"094351a0-f34e-4ee3-9762-51a8a201b7b1\">Otros servicios: mantenerlos en <strong>2&ndash;3GB</strong> cada uno si es suficiente</p></li></ul><p local-id=\"eb3274d0-65d9-45ba-ae43-ce8fe5f0fe8b\">Y verificar que la suma no pase ~24&ndash;25GB.</p><hr local-id=\"f58e8999-d01d-4913-90b5-bb13f6ddae72\" /><h2 local-id=\"946cdc5b-b208-47c5-bb40-aa2259a20a35\">2. Relaci&oacute;n contenedor &harr; JVM: heap vs. native</h2><p local-id=\"baff7f8a-ec8c-4c83-80ff-2af8046282eb\">Dentro de cada contenedor JRuby tenemos:</p><ul local-id=\"00d3d5a7-f7f1-4fa5-865e-db71231bf99f\"><li local-id=\"d6c95e4c-ca5f-40ad-9a96-0a03dcaf0dbf\"><p local-id=\"0a806d38-beb9-4991-9c4b-88e0c6b16640\">Heap de la JVM (<strong>-Xmx</strong> / <strong>-Xms</strong>)</p></li><li local-id=\"0cf8d7a3-44e0-4200-8e14-bca338fd7296\"><p local-id=\"a5d8e9df-d7d5-458f-99da-47d7553fcd4c\">Metaspace + code cache (clases, JIT)</p></li><li local-id=\"0983a72a-3cdd-4e86-be88-f78a309ae50e\"><p local-id=\"f1d8114b-e600-4dff-802e-68afcd392df4\">Memoria nativa de JRuby / C extensions / buffers</p></li><li local-id=\"0126c5ef-8509-455c-b162-1f38792faab8\"><p local-id=\"6e98c7e6-4998-4859-a6b5-8c6e64616eed\">Stacks de threads (Java threads)</p></li><li local-id=\"cdc02ee8-4f73-49ae-942a-c4a167e2c684\"><p local-id=\"7f58a662-8916-43d8-982e-f040170d1771\">Overhead del propio contenedor y librer&iacute;as</p></li></ul><p local-id=\"582de96e-b600-401c-aa3e-2ba3be9c90c6\">Regla de dedo razonable:</p><ul local-id=\"3281ceab-8667-4b63-9800-b8e7467d0280\"><li local-id=\"8176179f-2171-4151-8dc4-d491cffe51f9\"><p local-id=\"0168410e-4262-40c1-aa45-bb4448d158db\"><strong>Memoria del contenedor &asymp; 1.5&ndash;2 &times; heap m&aacute;ximo (Xmx)</strong></p></li></ul><p local-id=\"874addd0-9751-4d26-90ac-2e7e4b01c2aa\">Ejemplo:</p><ul local-id=\"b74e2402-9d09-4e5d-8a6d-4169107f4d58\"><li local-id=\"af2b9da1-21ff-4d40-a2b8-9ecc93a282c2\"><p local-id=\"8822bb12-7dc5-4958-9253-e1b285a0a4fd\">Si le damos <strong>Xmx = 4.5GB</strong>:</p><ul local-id=\"5ab13349-14d1-4fe3-9b0d-f5eeb89781e0\"><li local-id=\"f24a339a-8021-4fa9-8780-c3d6da60ed94\"><p local-id=\"6854ba45-5a56-44f2-a978-5a5d26d46a3e\">Configuramos el contenedor alrededor de <strong>7&ndash;9GB</strong>.</p></li></ul></li><li local-id=\"2be830b3-69ed-4401-a4d3-663354668e1b\"><p local-id=\"e54fe52f-7cc5-4b72-b51c-4c333473a159\">Si le damos <strong>Xmx = 6GB</strong>:</p><ul local-id=\"eae28823-f830-43e8-8aab-170e736bc6eb\"><li local-id=\"827aff46-247c-462b-b115-7dcb44edffd8\"><p local-id=\"5735e950-4c74-438e-a69b-37e9174fbb11\">Contenedor entre <strong>9&ndash;12GB</strong>.</p></li></ul></li></ul><p local-id=\"16c79704-4446-49a7-9a68-bb9f6fcf3261\">As&iacute; evitamos:</p><ul local-id=\"d686d6fb-1c3b-46ec-bfbd-093210e48744\"><li local-id=\"e65cf331-9d3f-43d5-9b02-5f3fbe16c9d4\"><p local-id=\"e4963ed0-f78e-465e-ab0d-ced784f7a6b6\">OOM killer del contenedor</p></li><li local-id=\"ab860602-cd32-4859-be39-ffafd9e0322e\"><p local-id=\"77c24e15-f4ac-4f47-8594-2d1938b4ac58\">y a la vez no reservamos 10GB de heap que nunca vamos a usar.</p></li></ul><hr local-id=\"672b4f88-aa3b-420c-8b6e-35acf2a554dc\" /><h2 local-id=\"11f9b4db-8d77-4bf1-abd5-f2ad6bb3f7cf\">3. C&oacute;mo saber cu&aacute;nta memoria REALMENTE necesita cada contenedor</h2><p local-id=\"3f296d85-3976-40fa-a95e-6657cec367cb\">No hay una f&oacute;rmula m&aacute;gica, pero hay una metodolog&iacute;a bastante clara:</p><h3 local-id=\"ca7b1304-347d-4416-a2f8-ad6f18e66b83\">Paso 1 &ndash; Medir el &ldquo;live set&rdquo; m&aacute;ximo</h3><ul local-id=\"98c9fd9d-9e7e-47fb-a115-59fa4b412f85\"><li local-id=\"256f9901-9065-40d9-a7f4-c27bc4eedc6e\"><p local-id=\"15dcb251-489f-4ae5-a0ea-ae506ddf1c45\">Mirar en los GC logs / Dynatrace el <strong>Old Gen used-after-GC</strong> (despu&eacute;s de un full GC o un major GC).</p></li><li local-id=\"315f4043-123f-48b9-884e-c711dc195878\"><p local-id=\"7a68cfb9-3ec7-4515-8874-da86d277c5b4\">Ese valor es &ldquo;lo que realmente est&aacute; vivo&rdquo; (el <em>live set</em>).</p></li></ul><p local-id=\"fdafe788-b819-4757-bda8-0e93fbae8c63\">Tomamos:</p><ul local-id=\"8612d84c-9d9c-48ac-a04b-8216d5e5d97d\"><li local-id=\"e696f006-6b0e-4322-84fb-1c2c0ba0de4c\"><p local-id=\"91911f7e-242a-49b9-b73d-0b3455de89fc\"><strong>L = m&aacute;ximo Old Gen used-after-GC</strong> en el per&iacute;odo &ldquo;peor caso&rdquo; (picos de tr&aacute;fico o jobs).</p></li></ul><h3 local-id=\"03671505-4386-4b4d-89a0-e36c850a4578\">Paso 2 &ndash; Agregar margen de seguridad</h3><ul local-id=\"d97577c7-941c-40c8-88b1-dd5812455a98\"><li local-id=\"75b1a38a-7698-4224-b799-7cdc7f468b16\"><p local-id=\"c26ff228-4e3a-422a-b2ac-550e097d9a54\">Elegimos un factor de seguridad (<strong>S</strong>) entre <strong>1.3 y 1.5</strong>.</p></li><li local-id=\"0dd30734-437a-4b1d-a829-7b6dff32878b\"><p local-id=\"916816e1-a782-4083-bbcf-869c5ca6c7a9\">Calcul&aacute;s: <strong>Xmx = L &times; S</strong></p></li></ul><p local-id=\"a73a74ad-90cd-4c5a-ab69-115e72958edc\">Ejemplo num&eacute;rico:</p><ul local-id=\"a0c438cd-b8dd-4509-b856-a02970e540d4\"><li local-id=\"1e908021-4317-4c35-8e15-fe477d3cf72c\"><p local-id=\"e5f1ad61-7856-4c0f-88c8-960aaca147b5\">Si el Old Gen usado despu&eacute;s del GC nunca pasa de <strong>3GB</strong> en los peores picos:</p><ul local-id=\"e532a812-b0e1-4b78-ad09-56c02acfff91\"><li local-id=\"b9b8d5ef-418e-4c2b-b9be-1a2d7c16a6be\"><p local-id=\"3d31d24c-332c-443b-a911-eb19bf332caa\">Con S = 1.5 &rarr; Xmx &asymp; <strong>4.5GB</strong></p></li></ul></li><li local-id=\"acfa7daa-57ab-4117-ab58-aa1751d47204\"><p local-id=\"6d46a71e-ccf6-4a44-908c-7c6bc6784648\">Si en Sidekiq vemos que el m&aacute;ximo usado-after-GC est&aacute; en <strong>2GB</strong>:</p><ul local-id=\"7819adb0-c474-495f-ad6e-f72a1db2c320\"><li local-id=\"e5df9d56-038c-4557-9dda-c0eb37022131\"><p local-id=\"a869dada-8ed9-4f50-b9f9-7b48db002df6\">Xmx &asymp; <strong>3GB</strong></p></li></ul></li></ul><h3 local-id=\"dd104b23-4e80-441f-a795-273e5084c426\">Paso 3 &ndash; Derivar el l&iacute;mite de memoria del contenedor</h3><p local-id=\"f831fc0c-fbca-42aa-8e8b-2b6ab60a9a45\">Usando el factor 1.5&ndash;2 para overhead:</p><ul local-id=\"a8693d43-bc7f-41bd-8d31-69ea057a9bbb\"><li local-id=\"0db886a1-dd76-454a-aa37-960028f350c9\"><p local-id=\"c969507e-2caa-4c61-be76-ce6ea73df916\"><strong>Memoria contenedor &asymp; Xmx &times; 1.5&ndash;2</strong></p></li></ul><p local-id=\"0c2748f3-e352-4e46-bd1c-e33ed91eebb9\">Con los ejemplos:</p><ul local-id=\"a4e6810a-8b47-427d-b596-3165d6afcc53\"><li local-id=\"c56324f8-6b9c-4ce5-a083-2027ac5594f3\"><p local-id=\"49a0afd8-0e2b-496c-b5b9-65bf209db820\">Puma:</p><ul local-id=\"09c4256f-cf75-4e33-9f82-a605a6e07505\"><li local-id=\"b9696d93-6231-486b-a63e-343f20f5542d\"><p local-id=\"4b300ad8-a2d9-47a2-bb9e-915c6d659292\">Xmx = 4.5GB &rarr; contenedor entre <strong>7 y 9GB</strong></p></li></ul></li><li local-id=\"e425c434-cd9b-447c-9b33-c805b8d0b9ca\"><p local-id=\"6c5430ba-46fd-4954-9322-0b5f8b6dcd17\">Sidekiq:</p><ul local-id=\"9c116847-824b-4221-a10b-07c74295dcb0\"><li local-id=\"50abb8bd-3913-4e40-ad36-13c2ed68c5c8\"><p local-id=\"1ce8469e-816d-4a27-86bd-cc82f97af634\">Xmx = 3GB &rarr; contenedor entre <strong>4.5 y 6GB</strong></p></li></ul></li></ul><p local-id=\"391e6e06-8827-4d4d-b336-6406b9debfec\">Y luego verificamos que:</p><ul local-id=\"7f3d8842-f1ee-4923-aacd-4c1af5882a7b\"><li local-id=\"5d84fe47-826d-4282-8fa6-26c691b944cc\"><p local-id=\"66f12a8a-0b64-4cab-afa3-a8c8ebc840c6\">Puma + Sidekiq de commerce-service + otros contenedores + OS &le; 30GB con margen.</p></li></ul><hr local-id=\"c17481de-9e35-47bd-8d5e-49ddd5bd93df\" /><h2 local-id=\"0f2906cd-7d8e-4a7a-b270-aa5b75608f60\">4. Recomendaciones concretas para nuestro escenario</h2><p local-id=\"73d5f3b7-2a87-4517-a5ed-ccf5e5758021\">Teniendo en cuenta la realidad (JRuby, Puma 32 threads, Sidekiq, 30GB host, heap actual 10GB):</p><h3 local-id=\"b94253aa-afbb-4e95-b213-d061c6af02b6\">Para Puma (JRuby API, 32 hilos)</h3><ol start=\"1\" local-id=\"814f4dc7-1395-44ac-b26d-8d7ebdd4055c\"><li local-id=\"92169eb0-e566-4d27-9cc2-5c8250675250\"><p local-id=\"d53ec78e-890f-4b1c-974c-c82e282fb2e1\"><strong>Reducir heap m&aacute;ximo (Xmx)</strong></p><ul local-id=\"0a06472a-2062-4de2-b35b-0ae673310742\"><li local-id=\"67792afe-3600-48ba-b171-183551db0776\"><p local-id=\"a24915cf-4457-448e-b4ef-8ea2d8d256c7\">En vez de 10GB, probablemente algo como <strong>4&ndash;6GB</strong> sea m&aacute;s realista si el Old Gen used-after-GC est&aacute; bastante por debajo de eso.</p></li><li local-id=\"81bcec48-9bf9-41d9-82e8-ed17098e1183\"><p local-id=\"e7824a1c-fa35-4e97-bf35-c4d92a39db74\">Idealmente: calibrar usando el procedimiento de arriba (gc logs &rarr; L &rarr; Xmx = L &times; S).</p></li></ul></li><li local-id=\"46c470ea-0d3a-4031-9287-2ea4e3170b1b\"><p local-id=\"0ec54968-4040-4fc9-b91f-c8c96e85fe28\"><strong>Emparejar Xms y Xmx (en un valor ya razonable)</strong></p><ul local-id=\"a1a86dbc-30c1-4158-8706-4e68b13d7165\"><li local-id=\"b2a09275-3b75-4409-9bdd-a36c15103868\"><p local-id=\"9380924f-565f-4397-8130-a9f989b021f1\">Ej: <code>-Xms4g -Xmx4g</code></p></li><li local-id=\"c290dd50-0375-4cb9-953e-eb823e74a36c\"><p local-id=\"12b46812-2045-487f-ac07-2dc4b5d7f865\">Ventaja: evit&aacute;s escaladas progresivas del heap y ten&eacute;s un comportamiento m&aacute;s predecible.</p></li><li local-id=\"b4888ed4-e708-4137-a216-c59f04cabc7a\"><p local-id=\"ce52d5b0-9e1e-4c55-a3c5-2c7a1386db34\">Desventaja: reserva esa memoria desde el arranque, pero si Xmx ya es razonable, est&aacute; bien.</p></li></ul></li><li local-id=\"4c8fd3e8-eb7d-48c2-aa48-923d61131bbe\"><p local-id=\"6b803e39-5f91-4ca9-905a-8120b4f46736\"><strong>Revisar el n&uacute;mero de threads Puma</strong></p><ul local-id=\"16fe5c5a-842d-47c6-a095-077d88b1cea0\"><li local-id=\"1e4b4343-e44f-4d2e-8fe4-2e0c7b206738\"><p local-id=\"1e4b6834-9e4d-4cda-bd5b-1b47d69fa597\">32 threads para una sola instancia JRuby puede ser demasiado si no ten&eacute;s suficientes cores y si la app no es s&uacute;per I/O bound.</p></li><li local-id=\"56275058-c77a-486b-9845-99cc6a9ce515\"><p local-id=\"4ae60be1-ba01-4c15-aa30-3a6f078efbf2\">Valores t&iacute;picos invertibles:</p><ul local-id=\"7ab61357-3a1f-4564-890c-0133cf1bb0b3\"><li local-id=\"614478ce-0405-4551-b8ad-86aaa13c59b8\"><p local-id=\"42fbcc62-934f-4dbb-8ba2-d90f8b867acd\">CPU-bound: <strong>#cores o 2&times; #cores</strong></p></li><li local-id=\"a1198dae-7a7d-464b-8fb8-36139f2ee0a7\"><p local-id=\"57238301-b693-4d1b-818e-94e89f4b4b59\">I/O-bound (mucho tiempo en la DB / API externas): <strong>8&ndash;16 threads</strong> suele ser m&aacute;s que suficiente.</p></li></ul></li><li local-id=\"7afc270e-70a7-4c57-810c-bb1f063d21b5\"><p local-id=\"9f136971-99f8-48b5-86d5-7744f53768a7\">Menos threads = menos stacks, menos objetos vivos al mismo tiempo, mejor comportamiento de memoria.</p></li></ul></li></ol><h3 local-id=\"3c1eddf1-26ed-469b-a119-d5b629add9dd\">Para Sidekiq (JRuby workers)</h3><ol start=\"1\" local-id=\"e253a9f5-0ed4-40fb-bd6c-c41112efc6ef\"><li local-id=\"89e90f0c-056f-4b14-8eeb-31a1b82d28cd\"><p local-id=\"dbd41391-2c45-4dd9-99df-27aa6e824a5d\"><strong>Ajustar la concurrencia de Sidekiq</strong></p><ul local-id=\"119f1876-012b-414d-96b4-9546fefa4f1d\"><li local-id=\"d61fb9e4-0232-4b55-982e-c835d10a58fb\"><p local-id=\"082b2c3b-6d40-4e0a-918c-599f3a036b72\">No usar una concurrencia exagerada si despu&eacute;s los jobs son principalmente CPU-bound.</p></li><li local-id=\"757b2b86-2702-46f1-b77c-9c1e74aade81\"><p local-id=\"b00358d2-4b66-4cf0-81ac-b1f73b5c2bc9\">Por ejemplo, 5&ndash;10 workers concurrentes puede ser m&aacute;s sano que 25&ndash;50, dependiendo de la carga.</p></li></ul></li><li local-id=\"4c9e1160-bc06-4a98-a536-008c69f07f87\"><p local-id=\"608a6b35-35d8-4b79-a1da-9fdf68e348c1\"><strong>Heap y memoria</strong></p><ul local-id=\"20e8eea3-d810-4637-a415-1ba1e81382db\"><li local-id=\"a2c00e24-1bf3-4f30-871a-68fb647f0743\"><p local-id=\"c1acc2f6-87f0-47ac-afb3-0245db7806e9\">Mismo m&eacute;todo: med&iacute;s L (live set) de Old Gen y calcul&aacute;s Xmx.</p></li><li local-id=\"ddf68f14-9737-415d-9ea4-e56d0c801244\"><p local-id=\"c363143a-3943-4e29-ace6-2c23dec5e12f\">Probablemente Sidekiq pueda vivir con <strong>2&ndash;4GB</strong> de heap en muchos escenarios, salvo que los jobs procesen payloads grandes.</p></li></ul></li></ol><hr local-id=\"1154aa4e-d49c-43d7-a8a3-5d408dd60f53\" /><h2 local-id=\"a0779fd7-55b9-418e-9d83-051fd49fa0ef\">5. Ajustes recomendados de JVM (GC, contenedores, etc.)</h2><p local-id=\"e9aeb628-7198-40c6-8a2d-12f49debd363\">Dado que los contenedores tienen l&iacute;mites y el problema principal es c&oacute;mo &ldquo;se queda agarrada&rdquo; la memoria:</p><ol start=\"1\" local-id=\"d20411e9-1742-4b99-93c3-aed0dd75d187\"><li local-id=\"7c0de93d-0380-4d62-a4e2-5ee064289165\"><p local-id=\"d26a6877-1a68-4625-807b-ddb0bf7a92b5\"><strong>Considerar G1GC en lugar de Parallel GC</strong></p><ul local-id=\"e4609a03-2cc5-4dfb-9f27-98e2431e82d9\"><li local-id=\"bc3e955e-cff9-4739-afe3-3fe6945b85ae\"><p local-id=\"47b0e521-f9e2-4580-858a-8e2c9bee727a\">Ventajas:</p><ul local-id=\"4833abf9-93e2-42e1-b88f-c64fa3de894d\"><li local-id=\"6835e8f5-f8b5-4bc3-a84c-0ceba7809603\"><p local-id=\"36a5ca27-30a7-4671-8c91-78f2f4aa4d1b\">Menos pausas largas.</p></li><li local-id=\"f796005a-318e-4b65-9d1e-20a8e66b2918\"><p local-id=\"3e614bf5-6150-4822-a614-2f1e99c7f8b2\">Mejor manejo de heaps medianos/grandes.</p></li><li local-id=\"d05b3e4a-e85c-4202-8c53-fca7880b00db\"><p local-id=\"0b6b2657-320e-4673-b943-d53ec5cd56fc\">En JDKs modernos, G1 puede devolver memoria al SO m&aacute;s agresivamente que Parallel (aunque nunca es perfecto).</p></li></ul></li><li local-id=\"21218c74-f769-44ba-9097-0a3b443dacf6\"><p local-id=\"93a71ed7-85a9-4d24-bcca-9db5c10920a0\">Ej: agregar:</p><ul local-id=\"9e44f887-c824-4210-9f81-dad2328cc5f9\"><li local-id=\"f37407f9-da54-48b5-8600-05090d58df50\"><p local-id=\"10b2f996-7493-4d54-9af6-9b1fac4dbe3f\"><code>-XX:+UseG1GC</code></p></li></ul></li></ul></li><li local-id=\"1ef89263-13fe-4b79-902a-f3151c49eaca\"><p local-id=\"31f69948-2173-4dfd-8953-9da99afe40d1\"><strong>Configurar la JVM para que respete el l&iacute;mite del contenedor</strong></p><ul local-id=\"97d466ef-c81d-4c27-809a-e08569c81dd0\"><li local-id=\"245831bb-d214-4201-a5f6-45e10f1f4dc5\"><p local-id=\"93441e16-a041-4b32-ba43-c1bab0d63d31\">En JDK 10+ esto suele estar activado por defecto, pero pod&eacute;s hacerlo expl&iacute;cito:</p><ul local-id=\"3e196f46-0b7d-499e-9cd7-a7bd5da0b4e7\"><li local-id=\"dad27f79-82f3-49ca-9ac5-4373fb666733\"><p local-id=\"e684969a-ed44-40d5-8553-c353e879077e\"><code>-XX:+UseContainerSupport</code> (si aplica a la versi&oacute;n)</p></li><li local-id=\"baa05958-4832-4549-87c9-a7d87e13f731\"><p local-id=\"e8929b4f-ced8-447d-ab9b-fba91e79805f\">O usar <code>-XX:MaxRAMPercentage</code> en lugar de <code>-Xmx</code> fijo, pero como ya ten&eacute;s 10GB fijo, para vos es m&aacute;s claro seguir con <code>-Xmx</code> y <code>-Xms</code>.</p></li></ul></li></ul></li><li local-id=\"01516b54-f988-4904-bf19-7e5a1fb814ea\"><p local-id=\"3ff68e52-2080-4f1e-9cbd-6437ca611576\"><strong>Otros flags &uacute;tiles (opcional, orientativo)</strong></p><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:local-id=\"24f913ac-9809-4bd4-a49e-12e7b6a6d5ba\" ac:macro-id=\"84e7f546-23db-4acd-8475-d2a2b62a8664\"><ac:plain-text-body><![CDATA[-Xms4g\n-Xmx4g\n-XX:+UseG1GC\n-XX:MaxGCPauseMillis=200\n-XX:+HeapDumpOnOutOfMemoryError\n-XX:HeapDumpPath=/dumps/commerce-service-puma.hprof\n]]></ac:plain-text-body></ac:structured-macro><p local-id=\"982b52d7-6a2f-4eb4-bdcb-9c1717195a76\">Y algo similar para Sidekiq pero con Xmx menor si el live set lo permite.</p></li></ol><hr local-id=\"276ae264-bc60-477e-aac5-dd66a4b55fab\" /><h2 local-id=\"22f87124-dd91-4552-a5d6-1ccba8839c07\">6. C&oacute;mo validar que &ldquo;no te quedaste corto&rdquo;</h2><p local-id=\"d5287520-0d82-4094-9d2d-b6d702d0fa08\">Una vez aplicadas las configuraciones:</p><ol start=\"1\" local-id=\"535c45fb-5128-40b9-a4d1-502eb24f1872\"><li local-id=\"0da27f44-4ac7-42b7-8cc8-29f20e95f6dc\"><p local-id=\"57860486-b09b-4cd2-bdbd-b614ff968592\"><strong>Mirar m&eacute;tricas en picos de tr&aacute;fico / jobs</strong></p><ul local-id=\"96e6c233-6ccb-4ba5-b37f-a1e86bf20abc\"><li local-id=\"bdc3e8ed-cbd0-4696-9c10-c63469116f64\"><p local-id=\"fd945d28-194e-48ce-92c4-24134f041f17\">Old Gen used-after-GC: que no se acerque a Xmx de forma sostenida.</p></li><li local-id=\"77ca9189-d247-43d7-a902-b23c622b44b4\"><p local-id=\"bcb2f7ef-2f48-4951-9283-bb4520e3dc83\">Frecuencia de full GCs: que no sea excesiva.</p></li><li local-id=\"0b61c6a5-4313-4471-9dec-380d4b909c7e\"><p local-id=\"6a7a3ae8-2886-4abc-a50e-ec57676123c9\">Pausas de GC: que est&eacute;n dentro de valores aceptables para tu SLA.</p></li></ul></li><li local-id=\"b926857e-31cf-43d4-b0bb-fc6525c3ed3e\"><p local-id=\"79abb62f-4b13-489e-aa52-9ae7acd89f88\"><strong>Mirar el uso de memoria del contenedor</strong></p><ul local-id=\"004a58a9-1454-4e0b-ac55-e7736c2d8bf9\"><li local-id=\"5238e9e7-7e87-441a-b3f3-96663aaeeaac\"><p local-id=\"e40c2911-e268-44cb-8b18-908f1c7f075b\">Que el RSS del proceso + resto de cosas dentro del contenedor se mantengan lejos del l&iacute;mite (por ejemplo &le; 80% del l&iacute;mite) incluso en picos.</p></li></ul></li><li local-id=\"264ae0b4-a57c-45bc-a65a-9c76fc2a4132\"><p local-id=\"fdcf8758-8a0b-40d8-b4a3-0cde4ec80060\"><strong>Iterar</strong></p><ul local-id=\"fcaf5955-700c-42fd-89a6-591871bba2c9\"><li local-id=\"1efb453e-62aa-4e61-a553-f6026e4ed63b\"><p local-id=\"790da9f1-03cd-4694-b3ce-ad958dbc2dd8\">Si ves que:</p><ul local-id=\"27127bdb-f359-4dc1-b540-7d988ffdfd47\"><li local-id=\"0888749a-1479-4685-b825-077f1357ed13\"><p local-id=\"744eed4e-8de1-4731-8618-5a2a4ee7f61e\">Heap se queda muy sobrado todo el tiempo (Old Gen after GC &lt;&lt; Xmx/2) &rarr; pod&eacute;s bajar Xmx.</p></li><li local-id=\"810d4e5c-7564-4ddf-a101-a91d974b07ad\"><p local-id=\"98ca8cf6-466b-4c5d-94e2-fcc9d4117765\">Heap vive demasiado cerca del techo y el GC empieza a ser agresivo &rarr; sub&iacute;s un poco Xmx o baj&aacute;s concurrencia (threads Puma / Sidekiq).</p></li></ul></li></ul></li></ol>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/4478959617"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":529},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/4478959617/child","restrictions":"/rest/api/content/4478959617/restriction/byOperation","history":"/rest/api/content/4478959617/history","draftVersion":"","descendants":"/rest/api/content/4478959617/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/spaces/BAN/pages/4478959617/Recomendaciones+Detalladas+de+Configuraci+n+commerce-service","webui":"/spaces/BAN/pages/4478959617/Recomendaciones+Detalladas+de+Configuraci+n+commerce-service","edituiv2":"/spaces/BAN/pages/4478959617/Recomendaciones+Detalladas+de+Configuraci+n+commerce-service","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/4478959617","tinyui":"/x/AYD3CgE","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}