47005/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2760147005/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2760147005","tinyui":"/x/PYCEp","editui":"/pages/resumedraft.action?draftId=2760147005","webui":"/spaces/BAN/pages/2760147005/Iniciativas+en+Curso","edituiv2":"/spaces/BAN/pages/edit-v2/2760147005"}},{"id":"3233218577","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/3233218577","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMzIzMzIxODU3Nw==","status":"current","title":"VPos","macroRenderedOutput":{},"extensions":{"position":10592077},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/3233218577/restriction/byOperation","history":"/rest/api/content/3233218577/history","body":"","version":"","descendants":"/rest/api/content/3233218577/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3233218577/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/3233218577","tinyui":"/x/EQC3w","editui":"/pages/resumedraft.action?draftId=3233218577","webui":"/spaces/BAN/pages/3233218577/VPos","edituiv2":"/spaces/BAN/pages/edit-v2/3233218577"}},{"id":"3741450281","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/3741450281","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMzc0MTQ1MDI4MQ==","status":"current","title":"Nuevos Medios de Pago","macroRenderedOutput":{},"extensions":{"position":179690828},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/3741450281/restriction/byOperation","history":"/rest/api/content/3741450281/history","body":"","version":"","descendants":"/rest/api/content/3741450281/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3741450281/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/3741450281","tinyui":"/x/KQAC3w","editui":"/pages/resumedraft.action?draftId=3741450281","webui":"/spaces/BAN/pages/3741450281/Nuevos+Medios+de+Pago","edituiv2":"/spaces/BAN/pages/edit-v2/3741450281"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<ac:structured-macro ac:name=\"info\" ac:schema-version=\"1\" ac:macro-id=\"b2382ab9-4e9a-4dc8-b4ef-605ac9113e49\"><ac:rich-text-body><p>Este documento representa el tasking y estimaci&oacute;n para QR en VPOS, a cargo de Juli&aacute;n Carracedo y Gast&oacute;n Gabadian.</p><p>Las horas estimadas son: <strong>339 ~ 43 d&iacute;as</strong> </p><p>Fecha estimada de entrega: <strong>Viernes</strong> <time datetime=\"2025-03-18\" />, comenzando: <strong>Martes</strong> <time datetime=\"2025-02-11\" /> </p></ac:rich-text-body></ac:structured-macro><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"d127e8c3-3fed-4af2-bc1b-c09b7117def2\"><colgroup><col style=\"width: 136.0px;\" /><col style=\"width: 472.0px;\" /><col style=\"width: 146.0px;\" /></colgroup><tbody><tr><th><p><strong>Proyecto</strong></p></th><th><p><strong>Tarea</strong></p></th><th><p style=\"text-align: center;\"><strong>Estimaci&oacute;n (hs)</strong></p></th></tr><tr><td data-highlight-colour=\"#b3f5ff\"><p>vpos-portal</p></td><td data-highlight-colour=\"#b3f5ff\"><p>Agregar tab al iframe para mostrar el QR. Agregar comportamiento para que cargue la imagen solo al primer click. Subsiguientes clicks no cargan la imagen.</p></td><td data-highlight-colour=\"#b3f5ff\"><p style=\"text-align: center;\">12</p></td></tr><tr><td data-highlight-colour=\"#b3f5ff\"><p>vpos-portal</p></td><td data-highlight-colour=\"#b3f5ff\"><p>Implementar endpoint que consuma vpos-service y genere el alias y el qr para un SingleBuy dado.</p></td><td data-highlight-colour=\"#b3f5ff\"><p style=\"text-align: center;\">12</p></td></tr><tr><td data-highlight-colour=\"#b3f5ff\"><p>vpos-portal</p></td><td data-highlight-colour=\"#b3f5ff\"><p>Limitar pesta&ntilde;a de QR a flujos de single_buy y comercios que lo tengan habilitado. Implementarlo de manera que por default nunca se muestre la pesta&ntilde;a QR, a menos que est&eacute;n dadas las condiciones. </p><p>Nota: validar otras acciones que rendericen la misma vista que single_buy.</p></td><td data-highlight-colour=\"#b3f5ff\"><p style=\"text-align: center;\">12</p></td></tr><tr><td data-highlight-colour=\"#b3f5ff\"><p>vpos-portal</p></td><td data-highlight-colour=\"#b3f5ff\"><p>Agregar endpoint para recibir confirmaciones de pagos QR desde vpos-service para actualizar vista de usuarios</p></td><td data-highlight-colour=\"#b3f5ff\"><p style=\"text-align: center;\">12</p></td></tr><tr><td data-highlight-colour=\"#b3f5ff\"><p>vpos-portal</p></td><td data-highlight-colour=\"#b3f5ff\"><p>Configuraci&oacute;n de websockets en el c&oacute;digo javascript de vpos-portal para poder recibir notificaciones del pago y redirigir al usuario correspondientemente.</p></td><td data-highlight-colour=\"#b3f5ff\"><p style=\"text-align: center;\">20</p></td></tr><tr><td data-highlight-colour=\"#b3d4ff\"><p>vpos-service</p></td><td data-highlight-colour=\"#b3d4ff\"><p>Agregar columna <code>qr_enabled</code> a las applications para poder configurar si un comercio/sucursal tiene habilitado el pago con QR. Endpoint para actualizar el campo.</p></td><td data-highlight-colour=\"#b3d4ff\"><p style=\"text-align: center;\">8</p></td></tr><tr><td data-highlight-colour=\"#b3d4ff\"><p>vpos-service</p></td><td data-highlight-colour=\"#b3d4ff\"><p>Agregar columnas <code>alias</code> y <code>qr_url</code> en la tabla <code>operations</code>, asociado a un <code>SingleBuy</code>. Agregar validaci&oacute;n de <code>presence</code> para ambas columnas a la vez. Ajustar factories y tests.</p></td><td data-highlight-colour=\"#b3d4ff\"><p style=\"text-align: center;\">8</p></td></tr><tr><td data-highlight-colour=\"#b3d4ff\"><p>vpos-service</p></td><td data-highlight-colour=\"#b3d4ff\"><p>Crear endpoint para generar QR de un determinado process_id: <code>POST /buy/:process_id/generate_qr</code>.</p><p>Estas operaci&oacute;n completa las columnas <code>alias</code> y <code>qr_url</code> en conjunto. Las mismas se completan &uacute;nicamente para aquellos SingleBuy que el usuario solicita QR.</p><p>Usar la constante <code>Bancard::PaymentsWithConfirmation::Prefixes::VPOS</code> (V) para la primera letra del alias.</p><p>Usar bancard-commons para generaci&oacute;n del QR. (payment-link-service de referencia)</p><p>Almacenar en S4 la imagen del QR.</p></td><td data-highlight-colour=\"#b3d4ff\"><p style=\"text-align: center;\">24</p></td></tr><tr><td data-highlight-colour=\"#b3d4ff\"><p>vpos-service</p></td><td data-highlight-colour=\"#b3d4ff\"><p>Crear endpoint de confirmaci&oacute;n para que billing-service-public-proxy confirme los pagos que se hayan hecho a trav&eacute;s de pago QR con App de entidad bancaria.</p><p>El endpoint debe:</p><ol start=\"1\"><li><p>confirmar el pago en jpos-compras</p></li><li><p>enviar callback de confirmaci&oacute;n al comercio a su URL de confirmaci&oacute;n del pago</p></li><li><p>llamar al endpoint de confirmaci&oacute;n de vpos-portal</p></li><li><p>devolver mensaje a public-proxy para que la app de la entidad bancaria reciba los datos de la confirmaci&oacute;n.</p></li></ol></td><td data-highlight-colour=\"#b3d4ff\"><p style=\"text-align: center;\">32</p></td></tr><tr><td data-highlight-colour=\"#b3d4ff\"><p>vpos-service</p></td><td data-highlight-colour=\"#b3d4ff\"><p>En la operaci&oacute;n de <code>get_buy</code> debemos agregar en la respuesta para que vpos-portal pueda distinguir si mostrar o no la tab de QR</p><ol start=\"1\"><li><p>Al buy un atributo que describa si es una preautorizaci&oacute;n. </p></li><li><p>Al store un atributo que describa si tiene activo QR.</p></li></ol></td><td data-highlight-colour=\"#b3d4ff\"><p style=\"text-align: center;\">8</p></td></tr><tr><td data-highlight-colour=\"#abf5d1\"><p>commerce-suite</p></td><td data-highlight-colour=\"#abf5d1\"><p>Agregar a la pantalla de personalizaci&oacute;n de aplicaci&oacute;n de vpos la posibilidad de encender/apagar pagos QR.</p></td><td data-highlight-colour=\"#abf5d1\"><p style=\"text-align: center;\">12</p></td></tr><tr><td data-highlight-colour=\"#b3bac5\"><p>billing-service-public-proxy</p></td><td data-highlight-colour=\"#b3bac5\"><p>Editar las operaciones:</p><ul><li><p><code>confirm</code>:  <code>POST /payments</code> </p></li><li><p><code>confirm_payment_with_confirmation</code> : <code>POST /payments/:payment_alias/payment_with_confirmation/confirm</code></p></li></ul><p>Para que en el caso en el que el alias comience con <code>Bancard::Payment sWithConfirmation::Prefixes::VPOS</code> (V) redirigir dicha confirmaci&oacute;n a VPOS service.</p><p>Evaluar par&aacute;metros de entrada, salida y validaciones propias de QRs VPOS</p></td><td data-highlight-colour=\"#b3bac5\"><p style=\"text-align: center;\">32</p></td></tr><tr><td data-highlight-colour=\"#b3bac5\"><p>billing-service-public-proxy</p></td><td data-highlight-colour=\"#b3bac5\"><p>Adaptar operaci&oacute;n <code>confirmation_by_entity_transaction_id</code> para que funcione con QRs de vpos.</p></td><td data-highlight-colour=\"#b3bac5\"><p style=\"text-align: center;\">32</p></td></tr><tr><td data-highlight-colour=\"#b3bac5\"><p>billing-service-public-proxy</p></td><td data-highlight-colour=\"#b3bac5\"><p>Adaptar la operaci&oacute;n <code>decode_qr_code</code>para soportar el decode de QRs de vpos.</p></td><td data-highlight-colour=\"#b3bac5\"><p style=\"text-align: center;\">24</p></td></tr><tr><td data-highlight-colour=\"#ffbdad\"><p>nginx</p></td><td data-highlight-colour=\"#ffbdad\"><p>Debuggear y revisar configuraci&oacute;n relacionada a websockets en vpos-portal</p></td><td data-highlight-colour=\"#ffbdad\"><p style=\"text-align: center;\">8</p></td></tr><tr><td data-highlight-colour=\"#c0b6f2\"><p /></td><td data-highlight-colour=\"#c0b6f2\"><p>Revisi&oacute;n y correcci&oacute;n de PRs, pruebas locales, armado de provides, deploy a stg, pruebas en ambiente</p></td><td data-highlight-colour=\"#c0b6f2\"><p style=\"text-align: center;\">32</p></td></tr><tr><td><p /></td><td><p /></td><td><p style=\"text-align: center;\" /></td></tr><tr><td data-highlight-colour=\"#eae6ff\"><p /></td><td data-highlight-colour=\"#eae6ff\"><p><strong>Total Desarrollo</strong></p></td><td data-highlight-colour=\"#eae6ff\"><p style=\"text-align: center;\">288</p></td></tr><tr><td data-highlight-colour=\"#eae6ff\"><p /></td><td data-highlight-colour=\"#eae6ff\"><p><strong>Total Gesti&oacute;n 15% (para facturaci&oacute;n, no afecta el desarrollo)</strong></p><p><em>Incluye reuniones de estimaci&oacute;n, planificaci&oacute;n, t&eacute;cnicas y de seguimiento.</em></p></td><td data-highlight-colour=\"#eae6ff\"><p style=\"text-align: center;\">51</p></td></tr><tr><td data-highlight-colour=\"#eae6ff\"><p /></td><td data-highlight-colour=\"#eae6ff\"><p><strong>Total Desarrollo + Gesti&oacute;n</strong></p></td><td data-highlight-colour=\"#eae6ff\"><p style=\"text-align: center;\">339</p></td></tr></tbody></table>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/3711533057"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":346433015},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3711533057/child","restrictions":"/rest/api/content/3711533057/restriction/byOperation","history":"/rest/api/content/3711533057/history","draftVersion":"","descendants":"/rest/api/content/3711533057/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=3711533057","webui":"/spaces/BAN/pages/3711533057/Nuevos+medios+de+pago+-+QR+en+VPOS+-+Tasking+y+Estimaci+n","edituiv2":"/spaces/BAN/pages/edit-v2/3711533057","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/3711533057","tinyui":"/x/AYA53Q","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}