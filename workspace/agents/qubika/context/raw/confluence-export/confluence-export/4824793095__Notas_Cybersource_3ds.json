7005/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2760147005/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2760147005","tinyui":"/x/PYCEp","editui":"/pages/resumedraft.action?draftId=2760147005","webui":"/spaces/BAN/pages/2760147005/Iniciativas+en+Curso","edituiv2":"/spaces/BAN/pages/edit-v2/2760147005"}},{"id":"4487741468","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/4487741468","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvNDQ4Nzc0MTQ2OA==","status":"current","title":"Migrar Cardinal 3DS a Cybersource 3DS","macroRenderedOutput":{},"extensions":{"position":156},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/4487741468/restriction/byOperation","history":"/rest/api/content/4487741468/history","body":"","version":"","descendants":"/rest/api/content/4487741468/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/4487741468/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/4487741468","tinyui":"/x/HIB9CwE","editui":"/pages/resumedraft.action?draftId=4487741468","webui":"/spaces/BAN/pages/4487741468/Migrar+Cardinal+3DS+a+Cybersource+3DS","edituiv2":"/spaces/BAN/pages/edit-v2/4487741468"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<h2 local-id=\"95a7f4cc-ef75-4b6b-ac82-9c60a04ee2ba\">Preguntas, tareas t&eacute;cnicas y recomendaciones adicionales (de la documentaci&oacute;n oficial):</h2><ul local-id=\"b9ea0b6e-3762-4e69-b44b-40ea4e903e35\"><li local-id=\"68444eb0-b457-4f02-90e8-684326fbbee0\"><p local-id=\"857c40129b98\"><strong>Actualizar l&oacute;gica para NO autorizar pagos si el enrollment service rechaza la operaci&oacute;n</strong><br />La documentaci&oacute;n de cybersource indica que seg&uacute;n la respuesta del enrollment service (ex lookup), hay casos en los que no se debe proceder a la autorizaci&oacute;n. Es decir que para nuestro caso, ser&iacute;a condici&oacute;n suficiente para mostrar un mensaje de error sin siquiera llamar al JPOS. <br />Nosotros hoy en dia sea cual sea el resultado del lookup, siempre llamamos al JPOS enviando el resultado. Mantenemos ese comportamiento?<br />Rta: siempre llamar al JPOS.</p></li><li local-id=\"2da331d9-5a9a-4f03-969a-a4fc99f43aee\"><p local-id=\"5bad654ce43b\"><strong>Disparar DDC apenas se complete el n&uacute;mero de tarjeta</strong> (mejora UX y performance). Las buenas pr&aacute;cticas indican que el DDC hay que realizarlo ni bien el usuario introduce la tarjeta, antes de presionar &ldquo;Pagar&rdquo;. Para ahorrar tiempo. Implementamos de esa manera? Suma complejidad y llamados al servicio. C&oacute;mo aplica a flujos con tarjetas catastradas/alias_token? Imposible realizar si se requiere kount antes.<br />Rta: no implementar esta mejora. </p></li><li local-id=\"9a6015bf-e44a-4dd1-b356-1eba7d914ef4\"><p local-id=\"fe911d6e70d7\"><strong>Documentar nuevo modelo de datos y flujos 3DS</strong> para QA y soporte. Diagramas.</p></li><li local-id=\"c291ca4c-1c92-4fdc-899d-16d7f1e81562\"><p local-id=\"fe1e82d463c8\"><strong>Riesgo detectado:</strong> que la gema oficial de cybersource no soporte el 100% de nuestros requerimientos o presente fallas o incompatibilidades, tendremos que implementar la comunicaci&oacute;n con cybersource nosotros en external-services.<br />Rta: la gema viene funcionando bien.</p></li><li local-id=\"76edc3a3-7635-4d8e-b89f-faaf9e02956e\"><p local-id=\"e619a8b50f78\"><strong>Consideraciones especiales para Visa Token</strong>: se envia a cybersource el Visa Token en los mismos campos que el PAN? Hay que enviar de manera diferenciada?</p></li><li local-id=\"ab26cc15-7cb6-4d69-ad36-3075b2cb368b\"><p local-id=\"833bdc94c392\">Nomenclatura: tenemos en c&oacute;digo, tablas, columnas, muy presente el nombre &ldquo;cardinal&rdquo;. Reemplazarlos todos lleva un esfuerzo extra. Sobre todo lo relacionado a la base de datos. </p></li><li local-id=\"71c77ce5-e664-4607-b1e0-afa1bd32b45d\"><p local-id=\"3a465b5bc616\">Migraci&oacute;n de credenciales: en vPOS cada comercio tiene sus credenciales para cardinal.</p></li><li local-id=\"cea71d8c-9a81-45cb-b343-abb56b1c2859\"><p local-id=\"96fbe1021714\">Reversibilidad del cambio: este cambio de proveedor de 3DS no est&aacute; siendo planeado como reversible. No se podr&aacute; vovler a Cardinal como proveedor de una manera sencilla ni podr&aacute;n estar activos ambos ni son compatibles entre s&iacute;.</p></li><li local-id=\"82b9a227-2b53-4e03-a467-44fbfdaf32bc\"><p local-id=\"6f4d4d191a84\">Ajustes al JPOS: qu&eacute; cambios habr&iacute;a en los par&aacute;metros de las peticiones que se le hacen al JPOS para autorizar/preautorizar/catastrar ?</p></li></ul><p local-id=\"4ee5f62c4689\" /><h1 local-id=\"5907c584-4337-48dc-bdc5-c01309b0d47c\">Consideraciones importantes para el desarrollo</h1><ol start=\"1\" local-id=\"106f00ef-a316-4f84-9f09-856242d3e2d7\"><li local-id=\"c3f32fd8-e6fa-4340-ae7e-d6c5024c4cd8\"><p local-id=\"e5503c343eff\">En Step 3 (enrollment service) se debe enviar el referenceId obtenido en el Step 1 (setup service)</p></li><li local-id=\"4d3c9103-bdab-4130-ab60-e6ba4e15311c\"><p local-id=\"531913bd39f8\">Validar si el <code>consumerAuthenticationInformation.authenticationTransactionId</code>que recibimos en la respuesta del Check Enrollment (step 3) es el mismo que el <code>TransactionId</code> que recibimos en el <code>POST returnUrl?TrasactionId=?</code>Esto nos serviria para saber de qu&eacute; pago estamos recibiendo el returnUrl.</p></li><li local-id=\"d41725cc-5abb-4c14-a74f-9726c5f3e9ff\"><p local-id=\"930f7af96951\"><a href=\"https://app.diagrams.net/#G1RDyKeUuSk8d7nmdrZ8PIf3ObgQnWC5yo#%7B%22pageId%22%3A%222YBvvXClWsGukQMizWep%22%7D\"><u>https://app.diagrams.net/#G1RDyKeUuSk8d7nmdrZ8PIf3ObgQnWC5yo#{&quot;pageId&quot;%3A&quot;2YBvvXClWsGukQMizWep&quot;}</u></a></p></li><li local-id=\"638cf56a-8251-4ed5-a7b9-72e485e642bd\"><p local-id=\"62156114e59b\"><a href=\"https://app.diagrams.net/#G1YniFU4FFpyAKf6b983OaeJpLB7NblfRz#%7B%22pageId%22%3A%22Q6Qj3vK8hR4XFauKPOTc%22%7D\"><u>https://app.diagrams.net/#G1YniFU4FFpyAKf6b983OaeJpLB7NblfRz#{&quot;pageId&quot;%3A&quot;Q6Qj3vK8hR4XFauKPOTc&quot;}</u></a></p></li></ol>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/4824793095"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":3554},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/4824793095/child","restrictions":"/rest/api/content/4824793095/restriction/byOperation","history":"/rest/api/content/4824793095/history","draftVersion":"","descendants":"/rest/api/content/4824793095/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/spaces/BAN/pages/4824793095/Notas+Cybersource+3ds","webui":"/spaces/BAN/pages/4824793095/Notas+Cybersource+3ds","edituiv2":"/spaces/BAN/pages/4824793095/Notas+Cybersource+3ds","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/4824793095","tinyui":"/x/B4CUHwE","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}