ate":"","children":"/rest/api/content/2178416778/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2178416778","tinyui":"/x/igDYgQ","editui":"/pages/resumedraft.action?draftId=2178416778","webui":"/spaces/BAN/overview","edituiv2":"/spaces/BAN/pages/edit-v2/2178416778"}},{"id":"2260140085","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2260140085","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjI2MDE0MDA4NQ==","status":"current","title":"Management","macroRenderedOutput":{},"extensions":{"position":504478064},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2260140085/restriction/byOperation","history":"/rest/api/content/2260140085/history","body":"","version":"","descendants":"/rest/api/content/2260140085/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2260140085/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2260140085","tinyui":"/x/NQC3hg","editui":"/pages/resumedraft.action?draftId=2260140085","webui":"/spaces/BAN/pages/2260140085/Management","edituiv2":"/spaces/BAN/pages/edit-v2/2260140085"}},{"id":"2919137286","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2919137286","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjkxOTEzNzI4Ng==","status":"current","title":"Cómo Maximizar la Eficiencia de Jira","macroRenderedOutput":{},"extensions":{"position":368},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2919137286/restriction/byOperation","history":"/rest/api/content/2919137286/history","body":"","version":"","descendants":"/rest/api/content/2919137286/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2919137286/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2919137286","tinyui":"/x/BoD_rQ","editui":"/pages/resumedraft.action?draftId=2919137286","webui":"/spaces/BAN/pages/2919137286/C+mo+Maximizar+la+Eficiencia+de+Jira","edituiv2":"/spaces/BAN/pages/edit-v2/2919137286"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<p><em><u>Trazabilidad Completa</u></em>: Al vincular commits, pull requests y branches de GitHub directamente a las tareas y historias de usuario en Jira, se logra una trazabilidad completa desde la planificaci&oacute;n hasta la entrega. Esto permite a los equipos entender r&aacute;pidamente el estado del trabajo y c&oacute;mo los cambios en el c&oacute;digo afectan a las funcionalidades espec&iacute;ficas o a la resoluci&oacute;n de problemas.</p><p><em><u>Mejora la Colaboraci&oacute;n</u></em>: Facilita la comunicaci&oacute;n entre desarrolladores y otros miembros del equipo (como gestores de proyecto, QA, etc.) al permitirles ver en Jira los detalles relevantes del desarrollo en GitHub sin necesidad de cambiar de plataforma.</p><p><em><u>Automatizaci&oacute;n de Tareas</u></em>: Puedes configurar Jira para actualizar autom&aacute;ticamente el estado de las tareas bas&aacute;ndose en acciones espec&iacute;ficas en GitHub, como cuando se hace merge a un pull request. Esto reduce la necesidad de actualizaciones manuales y mejora la precisi&oacute;n del seguimiento del proyecto.</p><p><em><u>Gesti&oacute;n de Releases y Versiones</u></em>: Conectar GitHub con Jira facilita la creaci&oacute;n y el seguimiento de releases. Puedes asociar commits y pull requests a versiones espec&iacute;ficas en Jira, lo que ayuda en la planificaci&oacute;n de lanzamientos y en la gesti&oacute;n de versiones.</p><p><em><u>Facilita la Revisi&oacute;n de C&oacute;digo</u></em>: Integrar GitHub con Jira hace que sea m&aacute;s sencillo para los equipos realizar revisiones de c&oacute;digo de manera eficiente, ya que pueden vincular directamente los cambios en el c&oacute;digo con las tareas correspondientes, proporcionando un contexto claro durante las revisiones.</p><p><em><u>Informes Mejorados</u></em>: La integraci&oacute;n permite generar informes m&aacute;s ricos y detallados sobre el progreso del desarrollo, ya que puedes combinar datos de Jira y GitHub para obtener una visi&oacute;n completa del trabajo realizado y pendiente.</p><p><em><u>Mejora la Visibilidad</u></em>: Todos los miembros del equipo pueden tener una visi&oacute;n clara del progreso del desarrollo y de c&oacute;mo contribuye cada cambio en el c&oacute;digo a los objetivos del proyecto, lo que mejora la transparencia y la comprensi&oacute;n general del proyecto.</p><p><em><u>Seguimiento de Problemas Eficiente</u></em>: La conexi&oacute;n entre Jira y GitHub facilita el seguimiento de bugs o incidencias desde que se reportan hasta que se resuelven, vinculando directamente los problemas en el c&oacute;digo con las tareas de Jira correspondientes.</p><ol start=\"6\"><li><p>Modificar campos en los tickets</p></li><li><p>Crear columnas</p></li><li><p>Crear reglas de automatizaci&oacute;n.</p></li></ol>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/2994995206"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":1618},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2994995206/child","restrictions":"/rest/api/content/2994995206/restriction/byOperation","history":"/rest/api/content/2994995206/history","draftVersion":"","descendants":"/rest/api/content/2994995206/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=2994995206","webui":"/spaces/BAN/pages/2994995206/Sincronizaci+n+del+Tablero+con+GitHub","edituiv2":"/spaces/BAN/pages/edit-v2/2994995206","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/2994995206","tinyui":"/x/BgCEsg","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}