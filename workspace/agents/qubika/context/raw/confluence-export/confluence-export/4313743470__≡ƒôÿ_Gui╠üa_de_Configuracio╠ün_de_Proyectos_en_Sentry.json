/2178416778/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2178416778","tinyui":"/x/igDYgQ","editui":"/pages/resumedraft.action?draftId=2178416778","webui":"/spaces/BAN/overview","edituiv2":"/spaces/BAN/pages/edit-v2/2178416778"}},{"id":"2259944189","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2259944189","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjI1OTk0NDE4OQ==","status":"current","title":"Documentación Técnica","macroRenderedOutput":{},"extensions":{"position":44304616},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2259944189/restriction/byOperation","history":"/rest/api/content/2259944189/history","body":"","version":"","descendants":"/rest/api/content/2259944189/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2259944189/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2259944189","tinyui":"/x/-QK0hg","editui":"/pages/resumedraft.action?draftId=2259944189","webui":"/spaces/BAN/pages/2259944189/Documentaci+n+T+cnica","edituiv2":"/spaces/BAN/pages/edit-v2/2259944189"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<h2>\uD83E\uDDE9 1. Crear o editar el proyecto</h2><h3>En <strong>General Settings</strong>:</h3><ol start=\"1\"><li><p><strong>Nombre del proyecto:</strong><br />➜ Debe ser igual al nombre del repositorio, <strong>sin la palabra &ldquo;bancard&rdquo;</strong>.<br />Ejemplo:</p><ul><li><p>Repositorio &rarr; <code>bancard-payment-link-service</code></p></li><li><p>Proyecto en Sentry &rarr; <code>payment-link-service</code></p></li></ul></li><li><p><strong>Subject Prefix:</strong><br />➜ Debe ser igual al nombre del proyecto en may&uacute;sculas y entre corchetes.<br />Ejemplo:</p><ul><li><p><code>[PAYMENT-LINK-SERVICE]</code></p></li></ul></li><li><p><strong>Project Teams:</strong><br />➜ Asignar el proyecto al equipo <strong>#bancard</strong>.</p></li><li><p><strong>Alert Settings &rarr; Subject Template:</strong><br />➜ Usar la siguiente plantilla:</p><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:macro-id=\"3f227220-f29e-4f11-9f2f-fdaec515ee28\"><ac:plain-text-body><![CDATA[[${tag:environment}] - $title]]></ac:plain-text-body></ac:structured-macro></li><li><p><strong>Resto de la configuraci&oacute;n:</strong><br />➜ Dejar todo con los valores por defecto.</p></li></ol><hr /><h2>\uD83D\uDEA8 2. Crear las alertas obligatorias</h2><p>Cada proyecto debe tener <strong>dos alertas</strong> configuradas:</p><ul><li><p><strong>First Time Error</strong></p></li><li><p><strong>High Frequency Error</strong></p></li></ul><p>Pod&eacute;s duplicarlas desde otro proyecto y solo cambiar los valores que se indican.</p><h3>Pasos:</h3><ol start=\"1\"><li><p>Ir a <strong>Alerts</strong>.</p></li><li><p>En otra alerta existente (de otro proyecto), hacer clic en <strong>⋯ &rarr; Duplicate</strong>.</p></li><li><p>En la secci&oacute;n <strong>1. Select an environment and project</strong>:</p><ul><li><p>Dejar <strong>production</strong> como &uacute;nico ambiente.</p></li><li><p>Seleccionar el proyecto correspondiente (ej. <em>payment-link-service</em>).</p></li></ul></li><li><p>En la secci&oacute;n <strong>5. Add a name and owner</strong>:</p><ul><li><p>Reemplazar el nombre del proyecto en el campo <em>Name</em>.</p></li><li><p>Mantener el resto igual (por ejemplo:<br /><code>payment-link-service First Time Error</code> o<br /><code>payment-link-service High Frequency Error (10+ in 5m)</code>).</p></li><li><p>Asignar el <strong>Team: #bancard</strong>.</p></li></ul></li></ol><hr /><h2>✅ 3. Checklist de verificaci&oacute;n</h2><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"c2d67972-d3d9-4bbc-962f-ebcb3ba39d0f\"><tbody><tr><th><p>Elemento</p></th><th><p>Valor esperado</p></th></tr><tr><td><p><strong>Project name</strong></p></td><td><p>sin &ldquo;bancard&rdquo;</p></td></tr><tr><td><p><strong>Subject Prefix</strong></p></td><td><p><code>[NOMBRE-DEL-PROYECTO]</code></p></td></tr><tr><td><p><strong>Team asignado</strong></p></td><td><p><code>#bancard</code></p></td></tr><tr><td><p><strong>Subject Template</strong></p></td><td><p><code>[${tag:environment}] - $title</code></p></td></tr><tr><td><p><strong>Alert 1</strong></p></td><td><p>First Time Error</p></td></tr><tr><td><p><strong>Alert 2</strong></p></td><td><p>High Frequency Error</p></td></tr><tr><td><p><strong>Ambiente</strong></p></td><td><p>production</p></td></tr><tr><td><p><strong>Action interval</strong></p></td><td><p>30 min</p></td></tr><tr><td><p><strong>Destinatario</strong></p></td><td><p>#bancard</p></td></tr></tbody></table>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/4313743470"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":980481198},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/4313743470/child","restrictions":"/rest/api/content/4313743470/restriction/byOperation","history":"/rest/api/content/4313743470/history","draftVersion":"","descendants":"/rest/api/content/4313743470/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=4313743470","webui":"/spaces/BAN/pages/4313743470/Gu+a+de+Configuraci+n+de+Proyectos+en+Sentry","edituiv2":"/spaces/BAN/pages/edit-v2/4313743470","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/4313743470","tinyui":"/x/boAeAQE","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}