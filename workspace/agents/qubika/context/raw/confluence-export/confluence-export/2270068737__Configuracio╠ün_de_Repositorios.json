ublishDate":"","children":"/rest/api/content/2178416778/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2178416778","tinyui":"/x/igDYgQ","editui":"/pages/resumedraft.action?draftId=2178416778","webui":"/spaces/BAN/overview","edituiv2":"/spaces/BAN/pages/edit-v2/2178416778"}},{"id":"2794455140","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2794455140","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjc5NDQ1NTE0MA==","status":"current","title":"Metodologías de Trabajo","macroRenderedOutput":{},"extensions":{"position":846},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2794455140/restriction/byOperation","history":"/rest/api/content/2794455140/history","body":"","version":"","descendants":"/rest/api/content/2794455140/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2794455140/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2794455140","tinyui":"/x/ZACQpg","editui":"/pages/resumedraft.action?draftId=2794455140","webui":"/spaces/BAN/pages/2794455140/Metodolog+as+de+Trabajo","edituiv2":"/spaces/BAN/pages/edit-v2/2794455140"}},{"id":"2269937665","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2269937665","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjI2OTkzNzY2NQ==","status":"current","title":"GitHub Guidelines","macroRenderedOutput":{},"extensions":{"position":528594102},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2269937665/restriction/byOperation","history":"/rest/api/content/2269937665/history","body":"","version":"","descendants":"/rest/api/content/2269937665/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2269937665/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2269937665","tinyui":"/x/AYBMhw","editui":"/pages/resumedraft.action?draftId=2269937665","webui":"/spaces/BAN/pages/2269937665/GitHub+Guidelines","edituiv2":"/spaces/BAN/pages/edit-v2/2269937665"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<p>The purpose of this document is to act as a guide on how to configure GitHub repositories and each of its branches.</p><ac:structured-macro ac:name=\"toc\" ac:schema-version=\"1\" data-layout=\"default\" ac:local-id=\"e9d8a704-cc73-44e4-b457-22a21174149d\" ac:macro-id=\"89d65ba5-efac-4149-b03b-128129a92a38\"><ac:parameter ac:name=\"style\">none</ac:parameter></ac:structured-macro><h1>Repository Name</h1><p>All Bancard GitHub repositories must be named according to the following rules.</p><ul><li><p>The name should start with <code>bancard</code></p></li><li><p>Use <code>-</code> as word separator</p></li></ul><p><strong>E.g.</strong></p><p><code>bancard-selling-service</code></p><p><code>bancard-payment-link-portal</code></p><p /><h1>Default Branch</h1><p>The default branch must be <code>develop</code> for all of our services and portals, and <code>master</code> for our gems.</p><p /><h1>General Configuration</h1><h2>Features Configuration</h2><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"786\" ac:original-width=\"786\" ac:custom-width=\"true\" ac:alt=\"image-20240321-202218.png\" ac:width=\"764\"><ri:attachment ri:filename=\"image-20240321-202218.png\" ri:version-at-save=\"1\" /></ac:image><h2>Pull Requests Configuration</h2><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"894\" ac:original-width=\"784\" ac:custom-width=\"true\" ac:alt=\"image-20240321-202345.png\" ac:width=\"764\"><ri:attachment ri:filename=\"image-20240321-202345.png\" ri:version-at-save=\"1\" /></ac:image><p /><h1>Colaborators and Teams</h1><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"556\" ac:original-width=\"787\" ac:custom-width=\"true\" ac:alt=\"image-20240321-204401.png\" ac:width=\"764\"><ri:attachment ri:filename=\"image-20240321-204401.png\" ri:version-at-save=\"1\" /></ac:image><p /><h1>Branches Configuration</h1><h2>Services and Portals</h2><h3>develop</h3><h5>Branch name pattern</h5><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"237\" ac:original-width=\"780\" ac:custom-width=\"true\" ac:alt=\"image-20240321-202828.png\" ac:width=\"764\"><ri:attachment ri:filename=\"image-20240321-202828.png\" ri:version-at-save=\"1\" /></ac:image><h5>Protect matching branches</h5><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"1756\" ac:original-width=\"779\" ac:custom-width=\"true\" ac:alt=\"image-20240321-204016.png\" ac:width=\"764\"><ri:attachment ri:filename=\"image-20240321-204016.png\" ri:version-at-save=\"1\" /></ac:image><h5>Rules applied to everyone including administrators</h5><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"205\" ac:original-width=\"774\" ac:custom-width=\"true\" ac:alt=\"image-20240321-204129.png\" ac:width=\"764\"><ri:attachment ri:filename=\"image-20240321-204129.png\" ri:version-at-save=\"1\" /></ac:image><h3>master</h3><h5>Branch name pattern</h5><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"235\" ac:original-width=\"776\" ac:custom-width=\"true\" ac:alt=\"image-20240321-204632.png\" ac:width=\"764\"><ri:attachment ri:filename=\"image-20240321-204632.png\" ri:version-at-save=\"1\" /></ac:image><h5>Protect matching branches</h5><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"1817\" ac:original-width=\"781\" ac:custom-width=\"true\" ac:alt=\"image-20240321-205213.png\" ac:width=\"764\"><ri:attachment ri:filename=\"image-20240321-205213.png\" ri:version-at-save=\"1\" /></ac:image><h5>Rules applied to everyone including administrators</h5><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"206\" ac:original-width=\"777\" ac:custom-width=\"true\" ac:alt=\"image-20240321-205318.png\" ac:width=\"764\"><ri:attachment ri:filename=\"image-20240321-205318.png\" ri:version-at-save=\"1\" /></ac:image><h3>feature/*</h3><h5>Branch name pattern</h5><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"139\" ac:original-width=\"778\" ac:custom-width=\"true\" ac:alt=\"image-20240321-213251.png\" ac:width=\"764\"><ri:attachment ri:filename=\"image-20240321-213251.png\" ri:version-at-save=\"1\" /></ac:image><h5>Protect matching branches</h5><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"1615\" ac:original-width=\"778\" ac:custom-width=\"true\" ac:alt=\"image-20240326-132146.png\" ac:width=\"764\"><ri:attachment ri:filename=\"image-20240326-132146.png\" ri:version-at-save=\"1\" /></ac:image><h5>Rules applied to everyone including administrators</h5><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"298\" ac:original-width=\"777\" ac:custom-width=\"true\" ac:alt=\"image-20240321-214053.png\" ac:width=\"764\"><ri:attachment ri:filename=\"image-20240321-214053.png\" ri:version-at-save=\"1\" /></ac:image><p /><h2>Gems</h2><h3>master</h3><h5>Branch name pattern</h5><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"236\" ac:original-width=\"775\" ac:custom-width=\"true\" ac:alt=\"image-20240322-141543.png\" ac:width=\"764\"><ri:attachment ri:filename=\"image-20240322-141543.png\" ri:version-at-save=\"1\" /></ac:image><h5>Protect matching branches</h5><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"1418\" ac:original-width=\"778\" ac:custom-width=\"true\" ac:alt=\"image-20240322-141821.png\" ac:width=\"764\"><ri:attachment ri:filename=\"image-20240322-141821.png\" ri:version-at-save=\"1\" /></ac:image><h5>Rules applied to everyone including administrators</h5><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"203\" ac:original-width=\"775\" ac:custom-width=\"true\" ac:alt=\"image-20240322-141903.png\" ac:width=\"764\"><ri:attachment ri:filename=\"image-20240322-141903.png\" ri:version-at-save=\"1\" /></ac:image><p /><p /><hr /><p><em>Siguiente Paso</em> &rarr; </p><ac:link ac:card-appearance=\"block\"><ri:page ri:content-title=\"Configuraci&oacute;n de Reminders en GitHub\" ri:version-at-save=\"8\" /><ac:link-body>Configuraci&oacute;n de Reminders en GitHub</ac:link-body></ac:link><p> </p>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/2270068737"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":351102752},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2270068737/child","restrictions":"/rest/api/content/2270068737/restriction/byOperation","history":"/rest/api/content/2270068737/history","draftVersion":"","descendants":"/rest/api/content/2270068737/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=2270068737","webui":"/spaces/BAN/pages/2270068737/Configuraci+n+de+Repositorios","edituiv2":"/spaces/BAN/pages/edit-v2/2270068737","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/2270068737","tinyui":"/x/AYBOhw","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}