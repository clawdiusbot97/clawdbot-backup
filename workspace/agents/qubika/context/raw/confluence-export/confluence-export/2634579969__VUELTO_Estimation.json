rsion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2178416778","tinyui":"/x/igDYgQ","editui":"/pages/resumedraft.action?draftId=2178416778","webui":"/spaces/BAN/overview","edituiv2":"/spaces/BAN/pages/edit-v2/2178416778"}},{"id":"2685108225","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2685108225","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjY4NTEwODIyNQ==","status":"current","title":"Iniciativas","macroRenderedOutput":{},"extensions":{"position":274391100},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2685108225/restriction/byOperation","history":"/rest/api/content/2685108225/history","body":"","version":"","descendants":"/rest/api/content/2685108225/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2685108225/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2685108225","tinyui":"/x/AYALo","editui":"/pages/resumedraft.action?draftId=2685108225","webui":"/spaces/BAN/pages/2685108225/Iniciativas","edituiv2":"/spaces/BAN/pages/edit-v2/2685108225"}},{"id":"2757296194","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2757296194","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjc1NzI5NjE5NA==","status":"current","title":"Archived Initiatives","macroRenderedOutput":{},"extensions":{"position":1091},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2757296194/restriction/byOperation","history":"/rest/api/content/2757296194/history","body":"","version":"","descendants":"/rest/api/content/2757296194/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2757296194/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2757296194","tinyui":"/x/QgBZp","editui":"/pages/resumedraft.action?draftId=2757296194","webui":"/spaces/BAN/pages/2757296194/Archived+Initiatives","edituiv2":"/spaces/BAN/pages/edit-v2/2757296194"}},{"id":"2685632522","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2685632522","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjY4NTYzMjUyMg==","status":"current","title":"Vuelto 2.0","macroRenderedOutput":{},"extensions":{"position":172683438},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2685632522/restriction/byOperation","history":"/rest/api/content/2685632522/history","body":"","version":"","descendants":"/rest/api/content/2685632522/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2685632522/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2685632522","tinyui":"/x/CoATo","editui":"/pages/resumedraft.action?draftId=2685632522","webui":"/spaces/BAN/pages/2685632522/Vuelto+2.0","edituiv2":"/spaces/BAN/pages/edit-v2/2685632522"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<p>CONFLUENCE: <a href=\"https://jira.bancardnet.dom/confluence/pages/viewpage.action?pageId=115658737\">https://jira.bancardnet.dom/confluence/pages/viewpage.action?pageId=115658737</a></p><p>JIRA: TO-DO</p><p /><table data-layout=\"full-width\" ac:local-id=\"248bfb78-bc7f-4125-a471-d49a077b16b5\"><colgroup><col style=\"width: 249.0px;\" /><col style=\"width: 706.0px;\" /><col style=\"width: 464.0px;\" /><col style=\"width: 165.0px;\" /></colgroup><tbody><tr><th><p><strong>PROYECTO</strong></p></th><th><p><strong>TAREA</strong></p></th><th><p><strong>NOTAS</strong></p></th><th><p><strong>ESTIMACI&Oacute;N (hrs)</strong></p></th></tr><tr><td><p>selling-service</p></td><td><p>Agregar columna <code>qr_source</code>  a la tabla <code>payment_hooks</code>, amonut_buy, amount_change (para vuelto) y validar si no agregamos otra columna para el caso de Extracci&oacute;n.</p></td><td><p /></td><td><p>8hs</p></td></tr><tr><td><p>selling-service</p></td><td><p>Recibir como par&aacute;metro los campos <code>qr_source</code>  en la operaci&oacute;n de <code>generate_qr_express</code> y almacenar en la base.</p><p /><p>Vamos a tener que agregar los siguientes campos:</p><p>Vuelto: amount_buy, amount_change =&gt; sumando estos deberia coincidir con el amount.</p><p>Extracci&oacute;n: por ahora no vemos un campo nuevo a agregar</p></td><td><ul><li><p>El campo qr_source debe ser opcional y puede tener los valores:</p><ul><li><p><strong>QR-BC</strong> para el caso de los QRs actuales</p></li><li><p><strong>QR-EXT</strong> para el caso de extracciones</p></li><li><p><strong>QR-CH</strong> para el caso de vuelto</p></li><li><p>En el caso de no recibir el campo <code>qr_source</code>, se debe usar <strong>QR-BC</strong> por defecto.</p></li><li><p>En el caso de los QRs ya creados y que tendr&aacute;n el campo <code>qr_source</code> en <code>nil</code>, se deber&aacute; considerar que son del tipo <strong>QR-BC</strong>.</p></li></ul></li></ul></td><td><p>20hs</p></td></tr><tr><td><p>selling-service</p></td><td><p>Modificar respuestas de payment_hook para incluir los datos <code>qr_source</code> </p></td><td><p /></td><td><p>12hs</p></td></tr><tr><td><p>selling-service</p></td><td><p>Modificar callback al comercio</p><p /></td><td><p>Enviar un campos mas correspondiente a la comisi&oacute;n, solo para el caso de <strong>QR-EXT.</strong><br />Para el caso de <strong>QR-CH</strong>, hay que mandar los montos desglosados (monto y vuelto)</p><p>En los casos de los QR &ldquo;comunes&rdquo;, los campos extras no se envian ni siquiera la clave.</p></td><td><p>16hs</p></td></tr><tr><td><p>selling-service</p></td><td><p>Modificar el endpoint de confirmaci&oacute;n de QR &ldquo;comun&rdquo;, para enviar los nuevos parametros al JPOS.</p><p>Fijarse si viene el bank_code (se llama entity_bank_code). </p><p>Consultar el servicio de comisi&oacute;n de las entidades (Redise&ntilde;o a traves de external-services) y obtener el monto de la comisi&oacute;n para esa entidad.</p><p>Guardar la comisi&oacute;n en la base (Payments.extraction_comission)</p><p /><p /></td><td><p>Estos parametros se definir&aacute;n durante el desarrollo</p></td><td><p>32hs</p></td></tr><tr><td><p>external-services</p></td><td><p>Agregar endpoint para consultar la comisi&oacute;n dado un importe y bank_code</p></td><td><p /></td><td><p>20hrs</p></td></tr><tr><td><p>selling-service</p></td><td><p>Agregar &ldquo;extraction_commission&rdquo; en la tabla Payments</p></td><td><p /></td><td><p>8hrs</p></td></tr><tr><td><p>billing-proxy</p></td><td><p>Si entity_bank_code = 0 (es pago m&oacute;vil), no lo dejamos confirmar QR-EXT y QR-CH.</p><p>Modificar operaci&oacute;n de confirmaci&oacute;n, retornar un error en caso de que la entidad no est&eacute; habilitada para operar QR-EXT y QR-CH.</p></td><td><p /></td><td><p>12hrs</p></td></tr><tr><td><p>billing-proxy</p></td><td><p>Agregar dos columnas en la tabla &ldquo;entity&rdquo; para indicar si puede operar Vuelto y/o Extracciones.</p><p>Tambi&eacute;n agregar 1 flag (o mas) mas indicando &ldquo;si hay que mandar los campos adicionales o no&rdquo;<br />Analizar tambi&eacute;n un json, por ejemplo:</p><p>{</p><p>vuelto: true</p><p>datos_adicionales: false</p><p>extraccion: true</p><p>datos_adicionales: true</p><p>}</p><p>Modificar el CRUD</p></td><td><p /></td><td><p>20hrs</p></td></tr><tr><td><p>external-commerce-service</p></td><td><p>Recibir como par&aacute;metro los campos <code>qr_source</code>  en la operaci&oacute;n de <code>generate_qr_express</code> y almacenar en la base.</p><p /><p>Vamos a tener que agregar los siguientes campos:</p><p>Vuelto: amount_buy, amount_change =&gt; sumando estos deberia coincidir con el amount.</p><p>Extracci&oacute;n: por ahora no vemos un campo nuevo a agregar</p></td><td><ul><li><p>El campo qr_source debe ser opcional y puede tener los valores:</p><ul><li><p><strong>QR-BC</strong> para el caso de los QRs actuales</p></li><li><p><strong>QR-EXT</strong> para el caso de extracciones</p></li><li><p><strong>QR-CH</strong> para el caso de vuelto</p></li><li><p>En el caso de no recibir el campo <code>qr_source</code>, se debe usar <strong>QR-BC</strong> por defecto.</p></li></ul></li></ul></td><td><p>16hs</p></td></tr><tr><td><p>selling-service</p></td><td><p>Modificar endpoint para la obtenci&oacute;n de un Payment, para que devuelva el &ldquo;extraction_comission&rdquo;</p></td><td><p /></td><td><p>12hrs</p></td></tr><tr><td><p>angus</p></td><td><p>Revisar e implementar la devoluci&oacute;n de parametros opcionales para que, en ciertos casos, no se devuelva ni siquiera la key</p></td><td><p /></td><td><p>30hrs</p></td></tr><tr><td><p>billing-proxy</p></td><td><p>Agregar campo <code>qr_source</code> , amount_buy, amount_change y la exchange_commission a la respuesta del <code>decode_qr_code</code></p><p /></td><td><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:macro-id=\"8569a24c-1255-4a75-870a-d23ce471a4e7\"><ac:plain-text-body><![CDATA[{\n    \"status\": \"success\",\n    \"data\": {\n        \"payment_alias\": \"9988\",\n        \"currency\": \"600\",\n        \"amount\": 10000,\n        \"commerce_name\": \"Supermercado Maravilla\",\n        \"description\": \"Compra Articulo\",\n        \"additional_data\":{\n            \"qr_source\": \"QR-EXT\",\n            \"exchange_commission\": 1234\n        }\n    }\n}\n\n{\n    \"status\": \"success\",\n    \"data\": {\n        \"payment_alias\": \"9988\",\n        \"currency\": \"600\",\n        \"amount\": 10000,\n        \"commerce_name\": \"Supermercado Maravilla\",\n        \"description\": \"Compra Articulo\",\n        \"additional_data\":{\n            \"qr_source\": \"QR-CH\",\n            \"amount_buy\": 7000,\n            \"amount_change\": 3000            \n        }\n    }\n}]]></ac:plain-text-body></ac:structured-macro></td><td><p>20hs</p></td></tr><tr><td><p>Contigencia</p></td><td><p /></td><td><p /></td><td><p>16hs</p></td></tr><tr><td><p /></td><td><p /></td><td><p /></td><td><p><strong>Total: 242</strong></p></td></tr></tbody></table><p />","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/2634579969"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":105024704},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2634579969/child","restrictions":"/rest/api/content/2634579969/restriction/byOperation","history":"/rest/api/content/2634579969/history","draftVersion":"","descendants":"/rest/api/content/2634579969/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=2634579969","webui":"/spaces/BAN/pages/2634579969/VUELTO+Estimation","edituiv2":"/spaces/BAN/pages/edit-v2/2634579969","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/2634579969","tinyui":"/x/AYAInQ","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}