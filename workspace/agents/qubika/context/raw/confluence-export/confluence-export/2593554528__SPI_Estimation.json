api/content/2763620355/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2763620355/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2763620355","tinyui":"/x/A4C5p","editui":"/pages/resumedraft.action?draftId=2763620355","webui":"/spaces/BAN/pages/2763620355/Tentative+Initiatives","edituiv2":"/spaces/BAN/pages/edit-v2/2763620355"}},{"id":"2685632556","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2685632556","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjY4NTYzMjU1Ng==","status":"current","title":"SPI (Proyecto Iniciadores de Pago)","macroRenderedOutput":{},"extensions":{"position":376300866},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2685632556/restriction/byOperation","history":"/rest/api/content/2685632556/history","body":"","version":"","descendants":"/rest/api/content/2685632556/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2685632556/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2685632556","tinyui":"/x/LIATo","editui":"/pages/resumedraft.action?draftId=2685632556","webui":"/spaces/BAN/pages/2685632556/SPI+Proyecto+Iniciadores+de+Pago","edituiv2":"/spaces/BAN/pages/edit-v2/2685632556"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<p>CONFLUENCE: <a href=\"https://jira.bancardnet.dom/confluence/display/PRYINPA/Flujo+QR+-+Mooveit\">https://jira.bancardnet.dom/confluence/display/PRYINPA/Flujo+QR+-+Mooveit</a></p><p>JIRA: <a href=\"https://jira.bancardnet.dom/projects/PRYINPA/issues/PRYINPA-1?filter=allissues\">https://jira.bancardnet.dom/projects/PRYINPA/issues/PRYINPA-1?filter=allissues</a></p><p>G Sheet: <a href=\"https://docs.google.com/spreadsheets/d/16HDK_bWPC3XjPYdoYtRvgg1oMP6FhEv6Z-XIwgNcUU4/edit#gid=0\" data-card-appearance=\"inline\">https://docs.google.com/spreadsheets/d/16HDK_bWPC3XjPYdoYtRvgg1oMP6FhEv6Z-XIwgNcUU4/edit#gid=0</a> </p><table data-layout=\"full-width\" ac:local-id=\"248bfb78-bc7f-4125-a471-d49a077b16b5\"><colgroup><col style=\"width: 249.0px;\" /><col style=\"width: 706.0px;\" /><col style=\"width: 464.0px;\" /><col style=\"width: 165.0px;\" /></colgroup><tbody><tr><th><p><strong>PROYECTO</strong></p></th><th><p><strong>TAREA</strong></p></th><th><p><strong>NOTAS</strong></p></th><th><p><strong>ESTIMACI&Oacute;N (hrs)</strong></p></th></tr><tr><td><p>selling-service</p></td><td><p>Agregar columna <code>qr_source</code> y <code>pos_box</code> a la tabla <code>payment_hooks</code></p></td><td><p /></td><td><p>8hs</p></td></tr><tr><td><p>selling-service</p></td><td><p>Recibir como par&aacute;metro los campos <code>qr_source</code> y <code>pos_box</code> en la operaci&oacute;n de <code>generate_qr_express</code> y almacenar en la base.</p></td><td><ul><li><p>El campo qr_source debe ser opcional y puede tener los valores:</p><ul><li><p><strong>QR-BC</strong> para el caso de los QRs actuales</p></li><li><p><strong>QR-SPI</strong> para los QRs de transferencia</p></li><li><p>En el caso de no recibir el campo <code>qr_source</code>, se debe usar <strong>QR-BC</strong> por defecto.</p></li><li><p>En el caso de los QRs ya creados y que tendr&aacute;n el campo <code>qr_source</code> en <code>nil</code>, se deber&aacute; considerar que son del tipo <strong>QR-BC</strong>.</p></li></ul></li><li><p>El campo pos_box debe ser opcional y puede tener los valores <strong>true</strong> y <strong>false</strong>. En caso de que el par&aacute;metro no sea enviado, por defecto es <strong>false</strong>.</p></li></ul></td><td><p>16hs</p></td></tr><tr><td><p>selling-service</p></td><td><p>Modificar respuestas de payment_hook para incluir los datos <code>qr_source</code> y <code>pos_box</code>.</p></td><td><p /></td><td><p>16hs</p></td></tr><tr><td><p>selling-service</p></td><td><p>Modificar callback al comercio</p></td><td><p>Modificar callback al comercio luego de confirmado un pago con QrExpress para enviar <code>account_type = TR</code> en el caso de que el QR sea del tipo SPI, es decir, que tenga el campo <code>qr_source</code> en <strong>QR-SPI</strong>.</p></td><td><p>16hs</p></td></tr><tr><td><p>selling-service</p></td><td><p>Desarrollar un endpoint para confirmaci&oacute;n de QRs SPI.</p></td><td><p>La operaci&oacute;n de confirmaci&oacute;n de QRs SPI debe utilizar la gema de integraci&oacute;n con servicios RPG para comunicarse con el servicio.<br /></p><p>Uno de los par&aacute;metros del servicio RPG dependera del valor de la columna pos_box del payment_hook:<br /><strong>pos_box</strong>=true&nbsp; -&gt; MET001 ME01NROLOT=1<br /><strong>pos_box</strong>=false -&gt; MET001 ME01NROLOT=0</p></td><td><p>32hs</p></td></tr><tr><td><p>selling-service</p></td><td><p>Agregar restricciones relacionadas a ambos tipos de QRs</p></td><td><ul><li><p>Si se intenta confirmar un QR con el endpoint de QR-BC pero es un QR-SDI, se debe retornar error.</p></li><li><p>Si se intenta revertir un QR con el endpoint de QR-BC pero es un QR-SDI, se debe retornar error.</p></li><li><p>Si se intenta confirmar un QR con el endpoint de QR-SDI pero es un QR-BC, se debe retornar error.</p></li></ul></td><td><p>24hs</p></td></tr><tr><td><p /></td><td><p /></td><td><p /></td><td><p /></td></tr><tr><td><p>bancard-external-rpg-services</p></td><td><p>Crear gema de integraci&oacute;n con servicios RPG</p></td><td><p>Requiere previa investigaci&oacute;n.</p></td><td><p>16hs</p></td></tr><tr><td><p>bancard-external-rpg-services</p></td><td><p>Agregar integraci&oacute;n con operaci&oacute;n de confirmaci&oacute;n de QR-SPI</p></td><td><p /></td><td><p>32hs</p></td></tr><tr><td><p /></td><td><p /></td><td><p /></td><td><p /></td></tr><tr><td><p>external-commerce-service</p></td><td><p>Recibir como par&aacute;metro los campos <code>qr_source</code> y <code>pos_box</code> en la operaci&oacute;n de <code>generate_qr_express</code> .</p></td><td><ul><li><p>El campo qr_source debe ser opcional y puede tener los valores:</p><ul><li><p><strong>QR-BC</strong> para el caso de los QRs actuales</p></li><li><p><strong>QR-SPI</strong> para los QRs de transferencia</p></li><li><p>En el caso de no recibir el campo <code>qr_source</code>, se debe usar <strong>QR-BC</strong> por defecto.</p></li></ul></li><li><p>El campo pos_box debe ser opcional y puede tener los valores <strong>true</strong> y <strong>false</strong>. En caso de que el par&aacute;metro no sea enviado, por defecto es <strong>false</strong>.</p></li></ul></td><td><p>16hs</p></td></tr><tr><td><p /></td><td><p /></td><td><p /></td><td><p /></td></tr><tr><td><p>billing-proxy</p></td><td><p>Agregar campo <code>qr_source</code> a la respuesta del <code>decode_qr_code</code></p></td><td><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:macro-id=\"f0d1c290-40ae-453f-8a57-960f1a781b1a\"><ac:plain-text-body><![CDATA[{\n    \"status\": \"success\",\n    \"data\": {\n        \"payment_alias\": \"9988\",\n        \"currency\": \"600\",\n        \"amount\": 10000,\n        \"commerce_name\": \"Supermercado Maravilla\",\n        \"description\": \"Compra Articulo\",\n        \"additional_data\":{\n            \"qr_source\": \"QR-SPI\"\n        }\n    }\n}]]></ac:plain-text-body></ac:structured-macro></td><td><p>16hs</p></td></tr><tr><td><p>billing-proxy</p></td><td><p>Desarrollar un endpoint para confirmaci&oacute;n de QRs SPI contra selling-service.</p></td><td><p>Si es un QR de selling y a su vez es QR-SDI, debe llamar al nuevo endpoint de selling-service.</p></td><td><p>24hs</p></td></tr><tr><td><p /></td><td><p /></td><td><p /></td><td><p /></td></tr><tr><td><p>research</p></td><td><p>Investigar herramientas para integrar una app Ruby a un servicio RPG.</p></td><td><p /></td><td><p>16hs</p></td></tr><tr><td><p /></td><td><p /></td><td><p /></td><td><p><strong>Total: 232</strong></p></td></tr></tbody></table><p />","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/2593554528"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":1406},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2593554528/child","restrictions":"/rest/api/content/2593554528/restriction/byOperation","history":"/rest/api/content/2593554528/history","draftVersion":"","descendants":"/rest/api/content/2593554528/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=2593554528","webui":"/spaces/BAN/pages/2593554528/SPI+Estimation","edituiv2":"/spaces/BAN/pages/edit-v2/2593554528","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/2593554528","tinyui":"/x/YICWmg","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}