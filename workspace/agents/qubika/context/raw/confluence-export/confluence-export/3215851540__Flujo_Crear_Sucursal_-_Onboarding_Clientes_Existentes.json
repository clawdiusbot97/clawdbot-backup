5/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2760147005/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2760147005","tinyui":"/x/PYCEp","editui":"/pages/resumedraft.action?draftId=2760147005","webui":"/spaces/BAN/pages/2760147005/Iniciativas+en+Curso","edituiv2":"/spaces/BAN/pages/edit-v2/2760147005"}},{"id":"2852094043","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2852094043","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjg1MjA5NDA0Mw==","status":"current","title":"Red Nro 1","macroRenderedOutput":{},"extensions":{"position":2146},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2852094043/restriction/byOperation","history":"/rest/api/content/2852094043/history","body":"","version":"","descendants":"/rest/api/content/2852094043/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2852094043/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2852094043","tinyui":"/x/W4D-qQ","editui":"/pages/resumedraft.action?draftId=2852094043","webui":"/spaces/BAN/pages/2852094043/Red+Nro+1","edituiv2":"/spaces/BAN/pages/edit-v2/2852094043"}},{"id":"3194028050","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/3194028050","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMzE5NDAyODA1MA==","status":"current","title":"Onboarding para Clientes Existentes","macroRenderedOutput":{},"extensions":{"position":2459},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/3194028050/restriction/byOperation","history":"/rest/api/content/3194028050/history","body":"","version":"","descendants":"/rest/api/content/3194028050/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3194028050/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/3194028050","tinyui":"/x/EgBhvg","editui":"/pages/resumedraft.action?draftId=3194028050","webui":"/spaces/BAN/pages/3194028050/Onboarding+para+Clientes+Existentes","edituiv2":"/spaces/BAN/pages/edit-v2/3194028050"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<ac:structured-macro ac:name=\"info\" ac:schema-version=\"1\" ac:macro-id=\"bbbd3413-6a73-4b4e-9c31-fa9e7a3fee06\"><ac:rich-text-body><p>Este documento contiene el flujo propuesto para la funci&oacute;n de crear una sucursal para un comercio desde el Portal de Comercios. </p><p>Actualmente, al usuario se le solicita seleccionar los productos que quiere agregar a la futura nueva sucursal antes de comenzar el flujo. Esto nos genera una complicaci&oacute;n al momento de armar el carrito, ya que los comercios pueden tener distintos tipos de moneda seg&uacute;n el producto que ofrecen para esa sucursal. Por ende, si TPago est&aacute; configurado en USD, y VPos en Gs, nos crear&iacute;a un carrito multimoneda, que afecta negativamente a la experiencia de usuario. </p><p>Lo que se propone, es cambiar ese flujo, para que el usuario abra la sucursal solo con un producto, y luego agregue el resto por el flujo normal. Tambi&eacute;n, pensamos que si el flujo es crear una sucursal, que lo mejor sea agregar primero la informaci&oacute;n de la sucursal, y por &uacute;ltimo el producto con el que se har&aacute; la apertura, para no confundir al usuario con el flujo normal, y que entienda lo que est&aacute; haciendo</p></ac:rich-text-body></ac:structured-macro><p><strong>Flujo Propuesto</strong>:</p><ol start=\"1\"><li><p>Seleccionamos la opci&oacute;n &ldquo;+ Crear Sucursal&rdquo; desde el portal de comercios. <br /></p><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"473\" ac:original-width=\"1440\" ac:custom-width=\"true\" ac:alt=\"Screenshot 2024-07-16 at 14.23.24.png\" ac:width=\"736\"><ri:attachment ri:filename=\"Screenshot 2024-07-16 at 14.23.24.png\" ri:version-at-save=\"1\" /></ac:image><p> </p></li><li><p>Esto nos lleva a la pantalla de informaci&oacute;n para la &ldquo;<a href=\"https://www.figma.com/design/q4Y1h3mLhjS3CeQU93p8Vw/Onboarding-Portal-de-Comercios-2024?node-id=1209-22512&amp;t=TVv6AN9FhgZU1dnh-4\">Configuraci&oacute;n de Negocio</a>&rdquo; <br /></p><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"362\" ac:original-width=\"382\" ac:custom-width=\"true\" ac:alt=\"Screenshot 2024-07-16 at 14.27.19.png\" ac:width=\"382\"><ri:attachment ri:filename=\"Screenshot 2024-07-16 at 14.27.19.png\" ri:version-at-save=\"1\" /></ac:image><p> A partir de ac&aacute;, el flujo contin&uacute;a como est&aacute; hoy en d&iacute;a, hasta el resumen<br /></p></li><li><p>Pantalla de &ldquo;<a href=\"https://www.figma.com/design/q4Y1h3mLhjS3CeQU93p8Vw/Onboarding-Portal-de-Comercios-2024?node-id=1209-20319&amp;t=TVv6AN9FhgZU1dnh-4\">Como se llama tu negocio?</a>&rdquo;<br /></p><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"252\" ac:original-width=\"370\" ac:custom-width=\"true\" ac:alt=\"Screenshot 2024-07-16 at 14.29.34.png\" ac:width=\"370\"><ri:attachment ri:filename=\"Screenshot 2024-07-16 at 14.29.34.png\" ri:version-at-save=\"1\" /></ac:image></li><li><p>Siguiendo por &ldquo;<a href=\"https://www.figma.com/design/q4Y1h3mLhjS3CeQU93p8Vw/Onboarding-Portal-de-Comercios-2024?node-id=1209-20594&amp;t=TVv6AN9FhgZU1dnh-4\">Ubica tu negocio</a>&rdquo; <br /></p><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"343\" ac:original-width=\"397\" ac:custom-width=\"true\" ac:alt=\"Screenshot 2024-07-16 at 14.30.22.png\" ac:width=\"397\"><ri:attachment ri:filename=\"Screenshot 2024-07-16 at 14.30.22.png\" ri:version-at-save=\"1\" /></ac:image><p /></li><li><p><a href=\"https://www.figma.com/design/q4Y1h3mLhjS3CeQU93p8Vw/Onboarding-Portal-de-Comercios-2024?node-id=1209-20892&amp;t=TVv6AN9FhgZU1dnh-4\">Ubicaci&oacute;n en el mapa </a><br /></p><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"339\" ac:original-width=\"408\" ac:custom-width=\"true\" ac:alt=\"Screenshot 2024-07-16 at 14.30.52.png\" ac:width=\"408\"><ri:attachment ri:filename=\"Screenshot 2024-07-16 at 14.30.52.png\" ri:version-at-save=\"1\" /></ac:image></li><li><p>Ingresamos los datos bancarios en las pantallas de &ldquo;<a href=\"https://www.figma.com/design/q4Y1h3mLhjS3CeQU93p8Vw/Onboarding-Portal-de-Comercios-2024?node-id=1209-21441&amp;t=ZB1ZYqB3RIqqbx9G-4\">Datos de Cuenta</a>&rdquo; <br /></p><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"555\" ac:original-width=\"703\" ac:custom-width=\"true\" ac:alt=\"Screenshot 2024-07-16 at 14.32.12.png\" ac:width=\"703\"><ri:attachment ri:filename=\"Screenshot 2024-07-16 at 14.32.12.png\" ri:version-at-save=\"1\" /></ac:image><p> </p></li><li><p>Reci&eacute;n en este paso, una vez que el usuario ya ingres&oacute; todos los datos de la sucursal, vamos a mostrar la lista de productos, con un mensaje que sea algo como &ldquo;Para abrir su sucursal, deber&aacute; asociar un producto&rdquo; y que el usuario seleccione solo 1 producto para hacer la apertura inicial, de esta manera, no vamos a tener el problema de la multimoneda<br /></p><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"614\" ac:original-width=\"716\" ac:custom-width=\"true\" ac:alt=\"Screenshot 2024-07-16 at 14.43.49.png\" ac:width=\"716\"><ri:attachment ri:filename=\"Screenshot 2024-07-16 at 14.43.49.png\" ri:version-at-save=\"1\" /></ac:image><p> </p></li><li><p>Una vez seleccionado el producto, avanzamos al resumen de la apertura de cuenta con los datos en la &ldquo;<a href=\"https://www.figma.com/design/q4Y1h3mLhjS3CeQU93p8Vw/Onboarding-Portal-de-Comercios-2024?node-id=1209-24846&amp;t=s9qbFW6fRjBV535C-4\">Pantalla de Resumen</a>&rdquo;<br /></p><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"591\" ac:original-width=\"1144\" ac:custom-width=\"true\" ac:alt=\"Screenshot 2024-07-16 at 14.44.37.png\" ac:width=\"736\"><ri:attachment ri:filename=\"Screenshot 2024-07-16 at 14.44.37.png\" ri:version-at-save=\"1\" /></ac:image><p> </p></li></ol>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/3215851540"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":810},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3215851540/child","restrictions":"/rest/api/content/3215851540/restriction/byOperation","history":"/rest/api/content/3215851540/history","draftVersion":"","descendants":"/rest/api/content/3215851540/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=3215851540","webui":"/spaces/BAN/pages/3215851540/Flujo+Crear+Sucursal+-+Onboarding+Clientes+Existentes","edituiv2":"/spaces/BAN/pages/edit-v2/3215851540","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/3215851540","tinyui":"/x/FACuvw","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}