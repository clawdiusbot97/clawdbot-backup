/2760147005/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2760147005/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2760147005","tinyui":"/x/PYCEp","editui":"/pages/resumedraft.action?draftId=2760147005","webui":"/spaces/BAN/pages/2760147005/Iniciativas+en+Curso","edituiv2":"/spaces/BAN/pages/edit-v2/2760147005"}},{"id":"4040654884","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/4040654884","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvNDA0MDY1NDg4NA==","status":"current","title":"Evolución del Portal de Comercios","macroRenderedOutput":{},"extensions":{"position":300},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/4040654884/restriction/byOperation","history":"/rest/api/content/4040654884/history","body":"","version":"","descendants":"/rest/api/content/4040654884/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/4040654884/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/4040654884","tinyui":"/x/JIDX8","editui":"/pages/resumedraft.action?draftId=4040654884","webui":"/spaces/BAN/pages/4040654884/Evoluci+n+del+Portal+de+Comercios","edituiv2":"/spaces/BAN/pages/edit-v2/4040654884"}},{"id":"4064509989","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/4064509989","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvNDA2NDUwOTk4OQ==","status":"current","title":"Requerimiento Evolución del Portal de Comercios","macroRenderedOutput":{},"extensions":{"position":192},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/4064509989/restriction/byOperation","history":"/rest/api/content/4064509989/history","body":"","version":"","descendants":"/rest/api/content/4064509989/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/4064509989/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/4064509989","tinyui":"/x/JYBD8g","editui":"/pages/resumedraft.action?draftId=4064509989","webui":"/spaces/BAN/pages/4064509989/Requerimiento+Evoluci+n+del+Portal+de+Comercios","edituiv2":"/spaces/BAN/pages/edit-v2/4064509989"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<ac:structured-macro ac:name=\"info\" ac:schema-version=\"1\" ac:macro-id=\"b989d2e9-d1e2-48d8-931d-847a6fcd0291\"><ac:rich-text-body><p>Este documento detalla el plan de trabajo y estimaci&oacute;n de tareas para reorganizar los portales actuales de la suite de comercios, con el objetivo de mejorar la mantenibilidad, escalabilidad y experiencia de desarrollo.</p><hr /><h3>\uD83D\uDD01 Contexto actual</h3><ul><li><p><code>commerce-suite</code> es el portal legado que contiene tanto vistas de comercios como de Boca Web.</p></li><li><p>Boca Web se va a migrar <strong>sin redise&ntilde;o</strong> a un nuevo portal llamado <code>epos-portal</code>.</p></li><li><p>Se cre&oacute; <code>commerce-portal</code>, un nuevo portal que reemplazar&aacute; gradualmente a <code>commerce-suite</code>.</p></li></ul><hr /><h3>\uD83C\uDFAF Objetivos</h3><ul><li><p><strong>Migrar progresivamente las vistas de </strong><code>commerce-suite</code><strong> a </strong><code>commerce-portal</code><strong>.</strong></p></li><li><p><strong>Desde </strong><code>commerce-portal</code><strong>, redireccionar inicialmente hacia </strong><code>commerce-suite</code> para acceder a vistas a&uacute;n no migradas.</p></li><li><p><strong>Actualizar e implementar nuevas vistas directamente en </strong><code>commerce-portal</code><strong>.</strong></p></li><li><p><strong>Apagar </strong><code>commerce-suite</code><strong> una vez que toda la funcionalidad est&eacute; en el nuevo portal.</strong></p></li><li><p><strong>Migrar Boca Web al nuevo </strong><code>epos-portal</code><strong> tal como est&aacute;</strong>, separ&aacute;ndolo definitivamente de <code>commerce-suite</code></p></li></ul><hr /><hr /><h3>\uD83E\uDDED Plan de transici&oacute;n</h3><ol start=\"1\"><li><p><strong>Desarrollar la estructura base de </strong><code>commerce-portal</code><strong> y </strong><code>epos-portal</code><strong>.</strong></p></li><li><p><strong>Montar las vistas nuevas de comercio directamente en </strong><code>commerce-portal</code><strong>.</strong></p></li><li><p><strong>Para vistas a&uacute;n no migradas</strong>, usar <code>commerce-portal</code> como entrypoint, redireccionando hacia <code>commerce-suite</code>.</p></li><li><p><strong>Migrar Boca Web completa a </strong><code>epos-portal</code><strong> sin redise&ntilde;o.</strong></p></li><li><p><strong>Desacoplar y apagar </strong><code>commerce-suite</code><strong> una vez que todos los m&oacute;dulos est&eacute;n migrados y validados.</strong></p></li></ol><hr /><p>Las horas estimadas son: <strong>262</strong></p><h3>Observaciones adicionales</h3><ol start=\"1\"><li><p>Este plan no contiene tareas de redise&ntilde;o, solo de arquitectura</p></li><li><p>Las tareas de redise&ntilde;o fueron enviadas en otro mail</p></li><li><p>Vamos a tener que planificar el &oacute;rden de ejecuci&oacute;n de las tareas en base a este portal para evitar conflictos en el desarrollo y retrabajo.</p></li></ol></ac:rich-text-body></ac:structured-macro><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"d127e8c3-3fed-4af2-bc1b-c09b7117def2\"><colgroup><col style=\"width: 444.0px;\" /><col style=\"width: 119.0px;\" /><col style=\"width: 196.0px;\" /></colgroup><tbody><tr><th><p><strong>Tarea</strong></p></th><th><p style=\"text-align: center;\"><strong>Estimaci&oacute;n (hs)</strong></p></th><th><p><strong>Servicio / Portal</strong></p></th></tr><tr><td><p>Crear nuevo portal para InfoNet Cobranzas con Rails 8, Dynatrace, OpenTellemetry y Cach&eacute; de commerce-services + migrar todas las vistas que tenemos hoy en d&iacute;a.</p></td><td><p style=\"text-align: center;\">40</p></td><td><p>epos-portal</p></td></tr><tr><td><p>Crear y hacer el setup de commerce-portal con Rails 8, Dynatrace, OpenTellemetry y cambios en Bancard Docker relacionados al deploy.</p></td><td><p style=\"text-align: center;\">16</p></td><td><p>commerce-portal</p></td></tr><tr><td><p>Cambios en nginx con el ruteo de un portal a otro a medida que vayamos avanzando con el desarrollo de las vistas.</p></td><td><p style=\"text-align: center;\">8</p></td><td><p>nginx config</p></td></tr><tr><td><p>Crear header (falta definir las dos opciones que le pasamos a luis, pero estimamos por la que demore m&aacute;s que ser&iacute;a el header con opciones distintas)</p><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"70\" ac:original-width=\"388\" ac:custom-width=\"true\" ac:alt=\"image-20250715-200235.png\" ac:width=\"388\"><ri:attachment ri:filename=\"image-20250715-200235.png\" ri:version-at-save=\"1\" /></ac:image><ul><li><p><em>Dise&ntilde;o del header</em></p></li><li><p><em>El header va a routear a commerce-suite para las vistas viejas y a commerce-portal para las nuevas</em></p></li><li><p><em>Agregar l&oacute;gica de permisos para cada vista / usuario / producto</em></p></li></ul></td><td><p style=\"text-align: center;\">32</p></td><td><p>commerce-suite / commerce-portal</p></td></tr><tr><td><p>Crear sidebar en commerce-portal y embeber las vistas de commerce-suite mientras no est&eacute;n desarrolladas. </p><ul><li><p><em>Dise&ntilde;o de la vista</em></p></li><li><p><em>El sidebar va a routear a commerce-suite para las vistas viejas y a commerce-portal para las nuevas</em></p></li><li><p><em>Agregar l&oacute;gica de permisos para cada vista / usuario</em></p></li></ul></td><td><p style=\"text-align: center;\">80</p></td><td><p>commerce-suite / commerce-portal</p></td></tr><tr><td><p>Renderizar vistas de commerce-suite sin header ni sidebar en commerce-portal</p><p><em>En cada ruta que no est&eacute; definida en el portal nuevo armar un iframe que te redireccione al portal viejo. </em></p></td><td><p style=\"text-align: center;\">40 (a revisar, puede ser menos o mas, miercoles <time datetime=\"2025-07-16\" /> vamos a hacer una prueba de concepto)</p></td><td><p>commerce-suite / commerce-portal</p></td></tr><tr><td><p>Salida a Staging</p><ul><li><p>Integraci&oacute;n de los flujos</p></li><li><p>Creaci&oacute;n y correci&oacute;n de PRs</p></li><li><p>Pruebas locales</p></li><li><p>Armado de ramas</p></li><li><p>Deploy a STG</p></li><li><p>Pruebas iniciales en STG</p></li></ul></td><td><p style=\"text-align: center;\">16</p></td><td><p /></td></tr><tr><td data-highlight-colour=\"#eae6ff\"><p><strong>Total Desarrollo</strong></p></td><td data-highlight-colour=\"#eae6ff\"><p style=\"text-align: center;\">232</p></td><td data-highlight-colour=\"#eae6ff\"><p /></td></tr><tr><td data-highlight-colour=\"#eae6ff\"><p><strong>Total Gesti&oacute;n 15% (para facturaci&oacute;n, no afecta el desarrollo)</strong></p><p><em>Incluye reuniones de estimaci&oacute;n, planificaci&oacute;n, t&eacute;cnicas y de seguimiento.</em></p></td><td data-highlight-colour=\"#eae6ff\"><p style=\"text-align: center;\">30</p></td><td data-highlight-colour=\"#eae6ff\"><p /></td></tr><tr><td data-highlight-colour=\"#eae6ff\"><p><strong>Total Desarrollo + Gesti&oacute;n</strong></p></td><td data-highlight-colour=\"#eae6ff\"><p style=\"text-align: center;\">262</p></td><td data-highlight-colour=\"#eae6ff\"><p /></td></tr></tbody></table>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/4079059454"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":458555138},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/4079059454/child","restrictions":"/rest/api/content/4079059454/restriction/byOperation","history":"/rest/api/content/4079059454/history","draftVersion":"","descendants":"/rest/api/content/4079059454/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=4079059454","webui":"/spaces/BAN/pages/4079059454/Nuevo+Portal+para+el+Portal+de+Comercios+-+Tasking+y+Estimaci+n","edituiv2":"/spaces/BAN/pages/edit-v2/4079059454","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/4079059454","tinyui":"/x/-oEh8w","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}