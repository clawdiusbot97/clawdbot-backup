t/api/content/2178416778/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2178416778","tinyui":"/x/igDYgQ","editui":"/pages/resumedraft.action?draftId=2178416778","webui":"/spaces/BAN/overview","edituiv2":"/spaces/BAN/pages/edit-v2/2178416778"}},{"id":"2794455140","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2794455140","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjc5NDQ1NTE0MA==","status":"current","title":"Metodologías de Trabajo","macroRenderedOutput":{},"extensions":{"position":846},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2794455140/restriction/byOperation","history":"/rest/api/content/2794455140/history","body":"","version":"","descendants":"/rest/api/content/2794455140/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2794455140/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2794455140","tinyui":"/x/ZACQpg","editui":"/pages/resumedraft.action?draftId=2794455140","webui":"/spaces/BAN/pages/2794455140/Metodolog+as+de+Trabajo","edituiv2":"/spaces/BAN/pages/edit-v2/2794455140"}},{"id":"2269937665","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2269937665","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjI2OTkzNzY2NQ==","status":"current","title":"GitHub Guidelines","macroRenderedOutput":{},"extensions":{"position":528594102},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2269937665/restriction/byOperation","history":"/rest/api/content/2269937665/history","body":"","version":"","descendants":"/rest/api/content/2269937665/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2269937665/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2269937665","tinyui":"/x/AYBMhw","editui":"/pages/resumedraft.action?draftId=2269937665","webui":"/spaces/BAN/pages/2269937665/GitHub+Guidelines","edituiv2":"/spaces/BAN/pages/edit-v2/2269937665"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<p>The purpose of this document is to provide our team with a comprehensive guide on the utilization of Git branches within our project. In the dynamic sphere of software development, our proficiency in managing Git branches is pivotal to our collaborative success, project organization, and codebase integrity.</p><p>Whether you are a long-standing member of our team or a recent addition, this guide aims to equip you with a thorough understanding of how we employ Git branches for effective collaboration, innovative development, and the maintenance of project stability. It is designed to be a clear and concise resource, offering practical insights that will enable you to seamlessly integrate with our development workflows.</p><p /><ac:structured-macro ac:name=\"toc\" ac:schema-version=\"1\" data-layout=\"default\" ac:local-id=\"4c161063-2f36-4d40-8456-a605375588e7\" ac:macro-id=\"4a03b259-b617-4849-b424-1b303ec64c38\" /><h1>Git Branches</h1><p>Every Bancard project has its own remote repository on GitHub. Additionally, each service and portal has two main branches, <code>master</code> and <code>develop</code>. As for gems, they typically use a single main branch, which is <code>master</code>.</p><h2>Portals and Services</h2><p>Two main branches.</p><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"92\" ac:original-width=\"648\"><ri:attachment ri:filename=\"image-20230914-193327.png\" ri:version-at-save=\"1\" /></ac:image><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"f659bfcd-fb9c-460d-b8dd-ad9046390508\"><colgroup><col style=\"width: 129.0px;\" /><col style=\"width: 629.0px;\" /></colgroup><tbody><tr><td><p><code>develop</code></p></td><td><p>The <code>develop</code> branch serves as an integration branch for <code>feature</code> branches and other changes. Changes are integrated into the <code>develop</code> branch only when they are deployed to production in the upcoming release.</p><p>The <code>develop</code> branch has no merge commits, so all merges into it will be performed using the 'Rebase and Merge' option.</p></td></tr><tr><td><p><code>master</code></p></td><td><p>The <code>master</code> branch serves as the official release history, meaning it points to the latest production release.</p><p>The <code>master</code> branch is the only branch where merge commits are created, so merges into this branch will be done using the 'Create a merge commit' option.</p></td></tr></tbody></table><p>In all services and portals, we use <code>feature</code> branches as the base for our initiatives and features.</p><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"87\" ac:original-width=\"208\"><ri:attachment ri:filename=\"image-20230915-133705.png\" ri:version-at-save=\"1\" /></ac:image><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"34813f1d-9064-4b15-ae10-4e9c60a42078\"><colgroup><col style=\"width: 129.0px;\" /><col style=\"width: 629.0px;\" /></colgroup><tbody><tr><td><p><code>feature</code></p></td><td><p>All new features should reside in their own branch. These branches, as well as hotfix branches, use the <code>develop</code> branch as their base branch, meaning they originate from and merge back into this branch. The feature branches shoul be named <code>feature/...</code></p></td></tr></tbody></table><p>Another type of branch used in the portals and services is the branch for each ticket.</p><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"83\" ac:original-width=\"205\"><ri:attachment ri:filename=\"image-20230915-142004.png\" ri:version-at-save=\"1\" /></ac:image><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"c37a3d0e-9759-46f9-98a6-72b6fb5bfa70\"><colgroup><col style=\"width: 129.0px;\" /><col style=\"width: 629.0px;\" /></colgroup><tbody><tr><td><p><code>TKT-123</code></p></td><td><p>The branches corresponding to tickets can be based on two different branches, either 'develop' or a 'feature' branch. If the ticket corresponds to a feature or initiative, it will use the branch associated with that initiative as its base. If the ticket is a hotfix destined for the next production deploy, <code>develop</code> can be used as the base branch.</p><p>In the case where the ticket corresponds to a simple fix that is neither part of an initiative nor scheduled for production deployment, it is recommended to use <code>feature/TKT-123</code> as the base branch.</p></td></tr></tbody></table><p>The last type of branch is the <code>provide</code> branch.</p><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"83\" ac:original-width=\"203\"><ri:attachment ri:filename=\"image-20230915-174429.png\" ri:version-at-save=\"1\" /></ac:image><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"b14edde7-208f-4b17-98a6-48f85686e97d\"><colgroup><col style=\"width: 129.0px;\" /><col style=\"width: 629.0px;\" /></colgroup><tbody><tr><td><p><code>provide</code></p></td><td><p>The <code>provide</code> branch is a resource we use to trigger image generation for branches other than <code>master</code>, <code>develop</code>, or <code>feature</code>. This branch is employed to consolidate feature branches into a single branch, allowing us to deploy all changes together to staging for testing.</p></td></tr></tbody></table><h2>Gems</h2><p>One main branch.</p><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"91\" ac:original-width=\"213\"><ri:attachment ri:filename=\"image-20230915-123629.png\" ri:version-at-save=\"1\" /></ac:image><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"eb36f593-8c4a-4f58-b4a6-d2dfcc2bdde0\"><colgroup><col style=\"width: 129.0px;\" /><col style=\"width: 629.0px;\" /></colgroup><tbody><tr><td><p><code>master</code></p></td><td><p>The <code>master</code> branch serves as the base branch for gems. All branches for changes start from and merge into <code>master</code>.</p><p>In the gems, the <code>master</code> branch has no merge commits, so all merges into it will be performed using the 'Rebase and Merge' option.</p></td></tr></tbody></table><p>Another type of branch used in the gems is the branch for each ticket.</p><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"83\" ac:original-width=\"205\"><ri:attachment ri:filename=\"image-20230915-142004.png\" ri:version-at-save=\"1\" /></ac:image><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"96ba8069-b104-42f5-b7a3-1d4a4b746c15\"><colgroup><col style=\"width: 129.0px;\" /><col style=\"width: 629.0px;\" /></colgroup><tbody><tr><td><p><code>TKT-123</code></p></td><td><p>The branches corresponding to tickets are based on <code>master</code>. All of these branches start from and merge into <code>master</code>.</p></td></tr></tbody></table><h1>Common Issues</h1><ul><li><p>Como crear una rama <code>provide</code> con varias ramas <code>feature</code> :</p></li></ul><p>Imaginemos que tenemos 2 feature branches, <code>feature/uno</code>, <code>feature/dos</code></p><p>(Con rebase)</p><ol start=\"1\"><li><p>Actualizar cada una de las ramas con la versi&oacute;n de develop mas actualizada.</p><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:macro-id=\"3dd0f7b5-c57b-4d42-8bb5-2bbbb19a39e8\"><ac:plain-text-body><![CDATA[git fetch\ngit checkout develop\ngit pull origin develop \ngit checkout feature/uno\ngit pull origin feature/uno\ngit rebase develop\ngit push origin feature/uno -f]]></ac:plain-text-body></ac:structured-macro></li><li><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:macro-id=\"ca409234-a2a4-4b13-9977-cd44ef0fcb93\"><ac:plain-text-body><![CDATA[git fetch\ngit checkout develop\ngit pull origin develop \ngit checkout feature/dos\ngit pull origin feature/dos\ngit rebase develop\ngit push origin feature/dos -f]]></ac:plain-text-body></ac:structured-macro></li><li><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:macro-id=\"b83f64f2-abd9-4dcf-8223-5fa029592075\"><ac:plain-text-body><![CDATA[Parados en una de las ramas de feature, por ejemplo feature/dos\n\ngit checkout -b provide/uno_dos\ngit rebase -i feature/uno]]></ac:plain-text-body></ac:structured-macro></li></ol><p>(Con cherry-pick)</p><ol start=\"1\"><li><p>Actualizar cada una de las ramas con la versi&oacute;n de develop mas actualizada.</p><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:macro-id=\"5f378d13-92f4-451a-8ee0-a84ebf43f929\"><ac:plain-text-body><![CDATA[git fetch\ngit checkout develop\ngit pull origin develop \ngit checkout feature/uno\ngit pull origin feature/uno\ngit rebase develop]]></ac:plain-text-body></ac:structured-macro></li><li><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:macro-id=\"5dc2b2c1-65a1-47ec-8508-a995a651b989\"><ac:plain-text-body><![CDATA[git fetch\ngit checkout develop\ngit pull origin develop \ngit checkout feature/dos\ngit pull origin feature/dos\ngit rebase develop]]></ac:plain-text-body></ac:structured-macro></li><li><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:macro-id=\"f863c080-88be-40c9-8574-aa75cea8c71c\"><ac:plain-text-body><![CDATA[Parados en una de las ramas de feature, por ejemplo feature/dos\n\ngit checkout -b provide/uno_dos\n\ngit log feature/uno (Sacamos el hash del primer y último commit que se desean agregar)\n\ngit cherry-pick <primer-hash>^..<ultimo-hash>]]></ac:plain-text-body></ac:structured-macro></li></ol><ul><li><p>Como agregar un commit de una feature en una rama <code>provide</code> : </p></li></ul><p><strong><span style=\"color: rgb(255,86,48);\">TBC</span></strong></p><hr /><p><em>Ahora que conoc&eacute;s nuestra forma de trabajar con Git, vayamos al siguiente paso: </em></p><ac:link ac:card-appearance=\"block\"><ri:page ri:content-title=\"Configuraci&oacute;n de Repositorios\" ri:version-at-save=\"3\" /><ac:link-body>Configuraci&oacute;n de Repositorios</ac:link-body></ac:link><p> </p>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/2711453730"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":575},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2711453730/child","restrictions":"/rest/api/content/2711453730/restriction/byOperation","history":"/rest/api/content/2711453730/history","draftVersion":"","descendants":"/rest/api/content/2711453730/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=2711453730","webui":"/spaces/BAN/pages/2711453730/Git+Branching","edituiv2":"/spaces/BAN/pages/edit-v2/2711453730","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/2711453730","tinyui":"/x/IoCdoQ","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}