{"id":"4743430149","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/4743430149","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvNDc0MzQzMDE0OQ==","status":"current","title":"Propuesta técnica sobre uso de PDF en reportes de gran volumen","version":{"by":{"type":"known","accountId":"5f0f0f5470b8a90025b61555","accountType":"atlassian","email":"","publicName":"Joel Alayon","profilePicture":{"path":"/wiki/aa-avatar/5f0f0f5470b8a90025b61555","width":48,"height":48,"isDefault":false},"displayName":"Joel Alayón","isExternalCollaborator":false,"isGuest":false,"locale":"en_US","accountStatus":"active","_expandable":{"operations":"","personalSpace":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/user?accountId=5f0f0f5470b8a90025b61555"}},"when":"2026-01-28T19:06:42.933Z","friendlyWhen":"Jan 28, 2026","message":"","number":3,"minorEdit":false,"ncsStepVersion":"188","ncsStepVersionSource":"ncs-ack","confRev":"confluence$content$4743430149.24","contentTypeModified":false,"_expandable":{"collaborators":"","content":"/rest/api/content/4743430149"},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/4743430149/version/3"}},"ancestors":[{"id":"2178416778","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2178416778","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjE3ODQxNjc3OA==","status":"current","title":"Bancard","macroRenderedOutput":{},"extensions":{"position":878},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2178416778/restriction/byOperation","history":"/rest/api/content/2178416778/history","body":"","version":"","descendants":"/rest/api/content/2178416778/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2178416778/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2178416778","tinyui":"/x/igDYgQ","editui":"/pages/resumedraft.action?draftId=2178416778","webui":"/spaces/BAN/overview","edituiv2":"/spaces/BAN/pages/edit-v2/2178416778"}},{"id":"2685108225","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2685108225","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjY4NTEwODIyNQ==","status":"current","title":"Iniciativas","macroRenderedOutput":{},"extensions":{"position":274391100},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2685108225/restriction/byOperation","history":"/rest/api/content/2685108225/history","body":"","version":"","descendants":"/rest/api/content/2685108225/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2685108225/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2685108225","tinyui":"/x/AYALo","editui":"/pages/resumedraft.action?draftId=2685108225","webui":"/spaces/BAN/pages/2685108225/Iniciativas","edituiv2":"/spaces/BAN/pages/edit-v2/2685108225"}},{"id":"2760147005","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2760147005","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjc2MDE0NzAwNQ==","status":"current","title":"Iniciativas en Curso","macroRenderedOutput":{},"extensions":{"position":258},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2760147005/restriction/byOperation","history":"/rest/api/content/2760147005/history","body":"","version":"","descendants":"/rest/api/content/2760147005/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2760147005/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2760147005","tinyui":"/x/PYCEp","editui":"/pages/resumedraft.action?draftId=2760147005","webui":"/spaces/BAN/pages/2760147005/Iniciativas+en+Curso","edituiv2":"/spaces/BAN/pages/edit-v2/2760147005"}},{"id":"2685632513","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2685632513","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjY4NTYzMjUxMw==","status":"current","title":"Tpago","macroRenderedOutput":{},"extensions":{"position":10589376},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2685632513/restriction/byOperation","history":"/rest/api/content/2685632513/history","body":"","version":"","descendants":"/rest/api/content/2685632513/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2685632513/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2685632513","tinyui":"/x/AYATo","editui":"/pages/resumedraft.action?draftId=2685632513","webui":"/spaces/BAN/pages/2685632513/Tpago","edituiv2":"/spaces/BAN/pages/edit-v2/2685632513"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<p local-id=\"6c547e5623f0\" /><h2 local-id=\"0beff2fe264c\">Contexto actual</h2><p local-id=\"9db0d29014c5\">Hoy el reporte de pagos de suscriptores ya existe y funciona correctamente para vol&uacute;menes peque&ntilde;os y medianos.</p><p local-id=\"c0461d474683\"><br />El procesamiento es:</p><ul local-id=\"1ebe9a75-4dde-4521-9859-da6d73d61c9b\"><li local-id=\"02f4c8a3-4cab-46a5-9e8f-4ac2da2d22e5\"><p local-id=\"f44d69dd59dd\"><strong>Sincr&oacute;nico</strong> para vol&uacute;menes normales.</p></li><li local-id=\"a6ed3c01-f597-44ea-9182-a12b69def112\"><p local-id=\"fea8a80634d6\"><strong>Asincr&oacute;nico</strong> (env&iacute;o por mail y almacenamiento en S4) cuando el volumen de datos es elevado.</p></li></ul><p local-id=\"0d5e946bd12d\">En los &uacute;ltimos d&iacute;as estuvimos trabajando en optimizaciones que lograron:</p><ul local-id=\"038a9d5c-7956-44df-b337-3dc5b9de8540\"><li local-id=\"6eafae7f-318f-4c29-b45b-ae6896433b9e\"><p local-id=\"fd9c02810a34\">Reducir significativamente el tama&ntilde;o del archivo.</p></li><li local-id=\"864afcd9-9545-4613-a100-79641c7db378\"><p local-id=\"e537514cff78\">Bajar el consumo de memoria del proceso.</p></li><li local-id=\"f35373ae-f174-4563-9b85-7b41f246245c\"><p local-id=\"eb0b11b1de0f\">Mantener tiempos de generaci&oacute;n estables.</p></li></ul><p local-id=\"e8e366b164de\">Los resultados t&eacute;cnicos son buenos y el comportamiento actual es estable.</p><p local-id=\"991927642c0d\">Sin embargo, m&aacute;s all&aacute; de las optimizaciones, el problema principal no es de implementaci&oacute;n sino de <strong>naturaleza del formato PDF</strong>.</p><hr local-id=\"03433cb8-34e9-40f7-adb7-cfb939829843\" /><h2 local-id=\"77d9adaefcbd\">Por qu&eacute; el PDF no es la mejor opci&oacute;n para grandes vol&uacute;menes?</h2><p local-id=\"1466a87c6173\">El PDF es un formato pensado para:</p><ul local-id=\"8523266b-3011-4054-91eb-dbc94eca3717\"><li local-id=\"44c00764-40fc-4b1a-9f88-136402468b71\"><p local-id=\"30e1d4917f9f\">Visualizaci&oacute;n.</p></li><li local-id=\"44ceb7b7-c433-41a4-b80b-76a7afc0f63e\"><p local-id=\"240a36a9e375\">Presentaci&oacute;n.</p></li><li local-id=\"0d4c3704-0751-4f20-bcf9-e1934cce5fe3\"><p local-id=\"1a412b1db7b5\">Impresi&oacute;n.</p></li><li local-id=\"d6e9f2f3-3b35-43a0-97bc-5a1fad0f6412\"><p local-id=\"51b5612bf83c\">Distribuci&oacute;n est&aacute;tica.</p></li></ul><p local-id=\"a1f034d9a3a7\">No est&aacute; pensado para manejar grandes vol&uacute;menes de datos tabulares extensos.</p><p local-id=\"8a979400e963\">Cuando el volumen crece:</p><ul local-id=\"eb42b9be-4295-4468-a7f0-d24674337754\"><li local-id=\"cd2af35c-9b7c-4a2e-8ecd-3c0ffc6b93d2\"><p local-id=\"f43a76769dea\">El tiempo de generaci&oacute;n aumenta.</p></li><li local-id=\"fb4e669d-0ebc-42f7-9ad2-c5fbf2533a1a\"><p local-id=\"4f1895b5d52b\">El consumo de memoria crece proporcionalmente.</p></li><li local-id=\"c085078b-1acb-4c02-bc46-8cd123d72b66\"><p local-id=\"597c630266da\">El archivo final se vuelve m&aacute;s pesado.</p></li><li local-id=\"02a6bd0f-6e89-4414-bd16-d3eb1228699e\"><p local-id=\"c3f8329aef18\">El costo de infraestructura (CPU, memoria, almacenamiento) aumenta.</p></li><li local-id=\"4f825730-f41b-48cf-b6c4-bae1947b2b86\"><p local-id=\"663cb127f8f8\">El proceso puede dejar de escalar correctamente.</p></li></ul><p local-id=\"d93f2115d723\">Es decir, podemos optimizar, pero no podemos cambiar la naturaleza del formato. <br />Siempre va a existir un l&iacute;mite pr&aacute;ctico.</p><hr local-id=\"71dfcbf9-a564-4f65-be7a-f9b62a005b62\" /><h2 local-id=\"b2026abaf668\">Comparaci&oacute;n real entre formatos (&asymp;850 registros)</h2><p local-id=\"84911c868829\">Tomando un volumen aproximado de <strong>850 registros</strong>, obtuvimos los siguientes resultados:</p><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"5a3d12bc-82e6-4dc0-9e86-6aab085d77e0\"><tbody><tr ac:local-id=\"ead77152-d38f-4c8e-9186-09f25a54473f\"><th ac:local-id=\"4b45ff68-3dbb-48cc-958b-5d9c07fb8dbb\"><p local-id=\"55c9ac36cf3d\">Formato</p></th><th ac:local-id=\"65e4a737-2919-49fe-9911-b0c95ca4c8a3\"><p local-id=\"cea6dedc720f\">Tama&ntilde;o archivo</p></th><th ac:local-id=\"a350054b-5c8c-4356-a04c-1760871ab310\"><p local-id=\"f2471803880f\">Memoria utilizada</p></th></tr><tr ac:local-id=\"946b5982-00b4-42d5-9a2b-5e867f99f212\"><td ac:local-id=\"0f1a2620-c533-4374-933f-92cde50d60d3\"><p local-id=\"4499f8b7ce1f\">PDF</p></td><td ac:local-id=\"2a839a4d-cfe7-4aeb-8bf0-fe3078ac1c6a\"><p local-id=\"c8367ac86b68\">~2.6 MB</p></td><td ac:local-id=\"1846f28a-d577-4588-b15c-58a74ee13d1e\"><p local-id=\"b193a5e88507\">~95 MB</p></td></tr><tr ac:local-id=\"e8c060a3-7a04-49ce-9cf0-81dddecca595\"><td ac:local-id=\"6ead41dd-8978-41aa-b4cd-8446aaf99193\"><p local-id=\"18741e13ae7a\">CSV</p></td><td ac:local-id=\"fca99caa-85a8-4c80-b693-668f2f8700d6\"><p local-id=\"3239ee79a182\">~190 KB</p></td><td ac:local-id=\"d9ad2f76-e850-41bc-8edb-4bc4dcbe0fdd\"><p local-id=\"2cbadde1bb47\">~33 MB</p></td></tr><tr ac:local-id=\"83d87803-7aa3-4a06-ae59-102308429b25\"><td ac:local-id=\"809fab8c-e778-4ffc-ae45-f7f7c70bce59\"><p local-id=\"f28c1d75768e\">TXT</p></td><td ac:local-id=\"aac2bd73-ec04-4cad-924d-d8fa8bf4026b\"><p local-id=\"117e770cdadd\">~500 KB</p></td><td ac:local-id=\"1911965b-0c8e-490b-ad6e-f52156c0f932\"><p local-id=\"8a565c510f28\">~33 MB</p></td></tr></tbody></table><p local-id=\"dab9c43c65a0\"><em>(Se omite el tiempo de generaci&oacute;n ya que las pruebas fueron realizadas en entorno local y no representan el comportamiento real en producci&oacute;n.)</em></p><h3 local-id=\"74cb03e5180b\">Diferencia porcentual</h3><p local-id=\"e19b1e552fa7\">Con el mismo volumen de datos:</p><ul local-id=\"c50a8b2b-8034-4834-957e-21fa82e70cf9\"><li local-id=\"d7ea1203-12af-42e9-b84b-a1805cf3c737\"><p local-id=\"22d9d29ad0c7\">El <strong>PDF utiliza aproximadamente 3 veces m&aacute;s memoria</strong> que CSV/TXT (&asymp; +190%).</p></li><li local-id=\"7f2eb78d-f71a-41ed-92bf-5303438fd1e1\"><p local-id=\"1c0e51db0575\">El <strong>PDF pesa entre 5 y 13 veces m&aacute;s en tama&ntilde;o final</strong> que TXT y CSV respectivamente (&asymp; +400% a +1.200%).</p></li></ul><p local-id=\"1b2c7d5dc9c5\">Es decir, incluso en un volumen moderado, la diferencia ya es estructuralmente significativa.</p><h3 local-id=\"75844d1d9e91\">&iquest;Por qu&eacute; el PDF consume m&aacute;s?</h3><p local-id=\"7582d4d50ec3\">El PDF no solo guarda datos. Tambi&eacute;n incluye:</p><ul local-id=\"942035d9-e8bd-4306-9b2b-72dfc4a41c23\"><li local-id=\"ce11a4d2-6775-4ac6-8d3c-a44b1d674b5b\"><p local-id=\"86d6610d0050\">Estructura visual.</p></li><li local-id=\"f60a7e64-6ed6-46ca-a0d0-53f871466b9d\"><p local-id=\"6ddcbfc43832\">Formato de tabla.</p></li><li local-id=\"f70187c0-5334-4a00-b0bb-f0e6168b59ac\"><p local-id=\"b52bab961797\">M&aacute;rgenes, fuentes y estilos.</p></li><li local-id=\"c08be522-c729-4018-87e5-857fdae86d73\"><p local-id=\"f31daddb7972\">Elementos gr&aacute;ficos.</p></li><li local-id=\"3624595b-8f31-45b8-a088-e16120099c95\"><p local-id=\"c8db0a1340e5\">Representaci&oacute;n lista para impresi&oacute;n.</p></li></ul><p local-id=\"86df889c516d\">Eso implica m&aacute;s procesamiento y m&aacute;s informaci&oacute;n embebida en el archivo.</p><p local-id=\"7a72fd2583f6\">En cambio, CSV y TXT son formatos planos:</p><ul local-id=\"45d31186-c2ad-477f-94ea-cf624fd2e459\"><li local-id=\"d6476a25-6e4e-4734-9ab7-89ba93ceca5b\"><p local-id=\"4538f3fa908b\">Guardan &uacute;nicamente datos.</p></li><li local-id=\"3692184d-4e2e-473c-9308-5f8260845246\"><p local-id=\"a0bb254a5129\">No incluyen formato visual.</p></li><li local-id=\"2a950f77-f330-4d0f-b283-8c7ffa2fa8e6\"><p local-id=\"6978886f32ad\">Son mucho m&aacute;s livianos y eficientes en memoria.</p></li></ul><hr local-id=\"e9c1c58d-69ef-4455-92b3-ff68699803f1\" /><h2 local-id=\"484b50b9a517\">El problema de escalabilidad</h2><p local-id=\"dc90aaf2dead\">Con ~850 registros la diferencia ya es significativa.</p><p local-id=\"f9a7715e5e18\">Ahora bien, nuestros comercios suelen manejar vol&uacute;menes considerablemente mayores (varios miles o decenas de miles de registros).</p><p local-id=\"7922f92950bd\">En esos escenarios:</p><ul local-id=\"fe00cb0f-6bbc-470c-8d16-9b7507ded412\"><li local-id=\"85676fea-0d83-442d-ba1b-8a17afee4ed0\"><p local-id=\"16840f8e028c\">El consumo de memoria del PDF crece de forma proporcional.</p></li><li local-id=\"72cdb023-638d-4fc5-9cdc-9a232ced9b19\"><p local-id=\"35cec782be58\">El tama&ntilde;o del archivo aumenta r&aacute;pidamente.</p></li><li local-id=\"0bbc7efc-f4e3-412e-a57a-af4db1deb20d\"><p local-id=\"adca56d62adb\">El costo de infraestructura (CPU, RAM y almacenamiento) se intensifica.</p></li><li local-id=\"933af3ef-10ea-4ca2-84f1-3d2f9ece7d13\"><p local-id=\"8cebfc979a5d\">El proceso puede volverse inestable o requerir mayor capacidad del servidor.</p></li></ul><p local-id=\"8631f7369687\">Es decir, aunque optimicemos, el PDF <strong>no est&aacute; pensado para escalar masivamente</strong>. </p><hr local-id=\"f6f781c1-6a4e-42f3-a97e-a3048768a867\" /><h2 local-id=\"0da1a6356834\">Propuesta del equipo t&eacute;cnico</h2><p local-id=\"94583c00c34c\">No proponemos eliminar el PDF.</p><p local-id=\"df6f4186ed43\">Sabemos que algunos comercios lo utilizan para:</p><ul local-id=\"bf7cf76b-f9a5-49d7-adc9-a0e1763816aa\"><li local-id=\"aae54284-d0ad-4b52-b99b-7bfd0ad2c04b\"><p local-id=\"8812dc25d2c7\">Imprimir reportes.</p></li><li local-id=\"363ca278-8fa4-4f91-beff-17aae70ad72e\"><p local-id=\"055758174e8e\">Compartir visualmente informaci&oacute;n.</p></li><li local-id=\"2981007b-0bfb-4f44-add3-ca9b6e5316d7\"><p local-id=\"f26ccfd35d51\">Tener un formato &ldquo;presentable&rdquo;.</p></li></ul><p local-id=\"c3da5eed7862\">Lo que proponemos es:</p><h3 local-id=\"31ee48af7aba\">1️⃣ Limitar el uso del PDF</h3><p local-id=\"bbaabd64f178\">Definir un l&iacute;mite m&aacute;ximo de registros configurable para generaci&oacute;n en PDF. Quedando disponible las opciones de exportar en formato TXT y/o CSV.</p><p local-id=\"ed40b0271b95\">Esto nos permite:</p><ul local-id=\"0a2e32cf-f4b9-4161-8746-4e760524599c\"><li local-id=\"4be1ad61-330d-4ec4-b5c3-838e9292458f\"><p local-id=\"e5dda3006ecb\">Proteger la estabilidad del sistema.</p></li><li local-id=\"b7816a46-4497-49ce-8e54-f29c415b94fc\"><p local-id=\"362caa366434\">Evitar consumos excesivos de infraestructura.</p></li><li local-id=\"5ece4f0d-8953-40b2-b5c7-af4a1959172d\"><p local-id=\"fb1beaf8deb6\">Reducir riesgos operativos.</p></li></ul><hr local-id=\"1c44640f-50c1-4ca6-a624-a038c89cdcda\" /><h3 local-id=\"3940f72ce748\">2️⃣ Mantener PDF optimizado para vol&uacute;menes razonables</h3><p local-id=\"73e52c7010ca\">Seguir optimizando el comportamiento actual, pero entendiendo que siempre tendr&aacute; un costo mayor que CSV/TXT.</p><hr local-id=\"1e406a56-ebac-4a6c-844e-aa686a47032c\" /><h3 local-id=\"3bcbbdc4530b\">3️⃣ Purgado autom&aacute;tico de archivos en S4</h3><p local-id=\"146afb8f88ff\">Actualmente los PDFs generados asincr&oacute;nicamente se almacenan en S4 y permanecen all&iacute;.</p><p local-id=\"ca81db8ee6d2\">Se propone implementar un <strong>purgado autom&aacute;tico cada 24 horas</strong>, ya que:</p><ul local-id=\"7d96d206-4f60-4a22-8163-6709997a1bf1\"><li local-id=\"5b5b7cfe-12e6-4f73-a23d-6e0d2dadd65c\"><p local-id=\"12c459803357\">Son archivos temporales.</p></li><li local-id=\"9306d545-ae50-4381-89c5-b6152b20e75a\"><p local-id=\"43cfc2b4e1c6\">No necesitan persistencia indefinida.</p></li><li local-id=\"46cd5572-220c-4c27-92f1-8575671d13a9\"><p local-id=\"a45829c4f956\">Est&aacute;n ocupando espacio innecesario.</p></li></ul><p local-id=\"785cf7e53702\">Esto reduce costos y mantiene el almacenamiento controlado.</p><hr local-id=\"e556193f-2d08-4112-9282-678876c34c99\" /><h2 local-id=\"ac81298d0ec0\">Contras de no limitar el l&iacute;mite de registros</h2><p local-id=\"14b9f434c690\">Si se decide mantener PDF para grandes vol&uacute;menes, se debe contemplar que eso implica:</p><ul local-id=\"4e20d3b8-b568-4e30-8317-22633ce53b2d\"><li local-id=\"805cb364-ce93-48fb-99b5-c12e5adcd8bf\"><p local-id=\"f0c308e14124\">Mayor uso de memoria.</p></li><li local-id=\"2b49b817-f9ad-4ed1-8adc-0816c9878995\"><p local-id=\"1e8b531ba48d\">Mayor tiempo de procesamiento.</p></li><li local-id=\"d08ca48a-abbd-4cec-98ec-8a1c6a27743b\"><p local-id=\"b90204d46664\">Mayor almacenamiento.</p></li><li local-id=\"c0c3cca4-dee1-437f-9acd-9e31c55228b2\"><p local-id=\"361c65798448\">Mayor costo de infraestructura.</p></li></ul><hr local-id=\"f8a336f8-2eb7-48c8-b548-256c208779c8\" /><h2 local-id=\"2bd029d25fc2\">Conclusi&oacute;n</h2><p local-id=\"217dce6ab7aa\">El PDF funciona bien para vol&uacute;menes peque&ntilde;os y medianos, y se puede mantener.<br />Pero para grandes vol&uacute;menes no es el formato adecuado por naturaleza.</p><p local-id=\"435519aa7b63\">La propuesta busca:</p><ul local-id=\"42016851-a8c3-4195-bedd-c3ef22d436e6\"><li local-id=\"8d7110ba-2480-422a-b452-873d6b8affa4\"><p local-id=\"f659184dc2c8\">Mantener la funcionalidad para quienes realmente la usan.</p></li><li local-id=\"6541f5ab-4529-49fb-ae8f-9b3c4c7d7629\"><p local-id=\"e6a94cc94361\">Evitar problemas de escalabilidad futuros.</p></li><li local-id=\"d2a324f0-6b9f-4739-b47f-927dfaa1ead5\"><p local-id=\"3b532ac42c41\">Controlar costos de infraestructura.</p></li><li local-id=\"30ff9f07-3b12-467f-ac3b-6c40338d0eda\"><p local-id=\"0d15d51fcf06\">Ofrecer alternativas m&aacute;s eficientes (CSV/TXT) cuando el volumen lo requiera.</p></li></ul>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/4743430149"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":91996891},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/4743430149/child","restrictions":"/rest/api/content/4743430149/restriction/byOperation","history":"/rest/api/content/4743430149/history","draftVersion":"","descendants":"/rest/api/content/4743430149/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=4743430149","webui":"/spaces/BAN/pages/4743430149/Propuesta+t+cnica+sobre+uso+de+PDF+en+reportes+de+gran+volumen","edituiv2":"/spaces/BAN/pages/edit-v2/4743430149","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/4743430149","tinyui":"/x/BQC7GgE","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}