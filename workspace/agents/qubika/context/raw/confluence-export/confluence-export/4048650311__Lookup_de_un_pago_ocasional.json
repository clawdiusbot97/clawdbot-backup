data[:buy].shop_process_id,\n  amount: buy_data[:buy].amount_in_gs,\n  billing_address_1: buy_data[:buy].billing_address_1 || '',\n  billing_city: buy_data[:buy].billing_city || '',\n  billing_first_name: buy_data[:buy].billing_first_name || '',\n  billing_last_name: buy_data[:buy].billing_last_name || '',\n  billing_postal_code: buy_data[:buy].billing_postal_code || '',\n  card_exp_month: params[:card_exp_month],\n  card_exp_year: params[:card_exp_year],\n  card_number: params[:card_number],\n  df_reference_id: params[:df_reference_id],\n  email: buy_data[:buy].email || '',\n  mobile_phone: buy_data[:buy].mobile_phone || '',\n  order_number: buy_data[:buy].shop_process_id,\n  browser_screen_width: params[:browser_screen_width],\n  browser_screen_height: params[:browser_screen_height],\n  browser_language: params[:browser_language],\n  browser_user_agent: params[:browser_user_agent],\n  browser_time_zone: params[:browser_time_zone],\n  browser_color_depth: params[:browser_color_depth]\n}]]></ac:plain-text-body></ac:structured-macro><p>VPOS service &rarr; external-services</p><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:macro-id=\"0f594c1f-7230-4409-9f27-5809bbba4bce\"><ac:parameter ac:name=\"language\">ruby</ac:parameter><ac:plain-text-body><![CDATA[{\n  billing_address_1: common_params[:billing_address_1],\n  billing_city: common_params[:billing_city],\n  billing_country_code: BILLING_COUNTRY_CODE,\n  billing_first_name: common_params[:billing_first_name],\n  billing_last_name: common_params[:billing_last_name],\n  billing_postal_code: common_params[:billing_postal_code],\n  card_exp_month: common_params[:card_exp_month],\n  card_exp_year: common_params[:card_exp_year],\n  card_number: common_params[:card_number],\n  df_reference_id: common_params[:df_reference_id],\n  email: '', # BAUSD-5157\n  mobile_phone: '', # BAUSD-5157\n  order_number: common_params[:order_number],\n  currency_code: CURRENCY_CODE,\n  browser_javascript_enabled: BROWSER_JA