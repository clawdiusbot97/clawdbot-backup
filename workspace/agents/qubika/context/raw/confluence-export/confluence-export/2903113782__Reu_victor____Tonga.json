pace/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2757296194/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2757296194","tinyui":"/x/QgBZp","editui":"/pages/resumedraft.action?draftId=2757296194","webui":"/spaces/BAN/pages/2757296194/Archived+Initiatives","edituiv2":"/spaces/BAN/pages/edit-v2/2757296194"}},{"id":"2788033784","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2788033784","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjc4ODAzMzc4NA==","status":"current","title":"VisaQR","macroRenderedOutput":{},"extensions":{"position":172686666},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2788033784/restriction/byOperation","history":"/rest/api/content/2788033784/history","body":"","version":"","descendants":"/rest/api/content/2788033784/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2788033784/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2788033784","tinyui":"/x/_AQupg","editui":"/pages/resumedraft.action?draftId=2788033784","webui":"/spaces/BAN/pages/2788033784/VisaQR","edituiv2":"/spaces/BAN/pages/edit-v2/2788033784"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:macro-id=\"83d4b0d3-5e2d-4074-944e-f404e0c91a26\"><ac:parameter ac:name=\"breakoutMode\">wide</ac:parameter><ac:plain-text-body><![CDATA[- El tipo de encryptacion que vamos a usar para la confirmacion es \n`aes-gsm256` con valor inicial (algo asi entendi) \n`404142434445464748494A4B4C4D4E4F4F4E4D4C4B4A49484746454443424140` -> Juan\n- El distrito se va a pasar por la creacion de la sucursal y se va a guardar en merchant o sucursal\n- En pricipio para lo que es visa qr no se necesita ese billing-number (Victor quedo en revisar eso para responderle a Bruno)\n- Tag 62 subtag 01 se puede ignorar mientras tanto\n- Juntarnos para ver los valores que se van a enviar a JPOS]]></ac:plain-text-body></ac:structured-macro><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"db56c195-e5cc-4c4c-af8e-6d1f5b72f2fd\"><colgroup><col style=\"width: 501.0px;\" /><col style=\"width: 257.0px;\" /></colgroup><tbody><tr><th><p><strong>Topic</strong></p></th><th><p><strong>Action item</strong></p></th></tr><tr><td><p>El tipo de encryptacion que vamos a usar para la confirmacion es </p><p>`aes-gsm256` con valor inicial (algo asi entendi) </p><p>`404142434445464748494A4B4C4D4E4F4F4E4D4C4B4A49484746454443424140`</p></td><td><p>Juancito a hablar con victor sobre esto</p></td></tr><tr><td><p>El departamento se va a pasar por la creacion de la sucursal y se va a guardar en merchant o sucursal</p></td><td><p>Vamos a guardarlo en merchant</p></td></tr><tr><td><p>En principio para lo que es visa qr no se necesita ese billing-number </p><p>Tag 62 subtag 01 se puede ignorar mientras tanto</p></td><td><p>se manda vac&iacute;o</p></td></tr><tr><td><p>Juntarnos para ver los valores que se van a enviar a JPOS</p></td><td><p>Victor se va a juntar con su equipo para resolver esto, hacer seguimiento a victor</p></td></tr></tbody></table>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/2903113782"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":2441},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2903113782/child","restrictions":"/rest/api/content/2903113782/restriction/byOperation","history":"/rest/api/content/2903113782/history","draftVersion":"","descendants":"/rest/api/content/2903113782/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=2903113782","webui":"/spaces/BAN/pages/2903113782/Reu+victor+Tonga","edituiv2":"/spaces/BAN/pages/edit-v2/2903113782","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/2903113782","tinyui":"/x/NgAKrQ","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}