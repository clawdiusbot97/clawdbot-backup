s":"/rest/api/content/2760147005/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2760147005/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2760147005","tinyui":"/x/PYCEp","editui":"/pages/resumedraft.action?draftId=2760147005","webui":"/spaces/BAN/pages/2760147005/Iniciativas+en+Curso","edituiv2":"/spaces/BAN/pages/edit-v2/2760147005"}},{"id":"2685632513","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2685632513","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjY4NTYzMjUxMw==","status":"current","title":"Tpago","macroRenderedOutput":{},"extensions":{"position":10589376},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2685632513/restriction/byOperation","history":"/rest/api/content/2685632513/history","body":"","version":"","descendants":"/rest/api/content/2685632513/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2685632513/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2685632513","tinyui":"/x/AYATo","editui":"/pages/resumedraft.action?draftId=2685632513","webui":"/spaces/BAN/pages/2685632513/Tpago","edituiv2":"/spaces/BAN/pages/edit-v2/2685632513"}},{"id":"2743992321","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2743992321","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjc0Mzk5MjMyMQ==","status":"current","title":"DBA Migration to Tpago","macroRenderedOutput":{},"extensions":{"position":91985998},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2743992321/restriction/byOperation","history":"/rest/api/content/2743992321/history","body":"","version":"","descendants":"/rest/api/content/2743992321/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2743992321/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2743992321","tinyui":"/x/AQCOow","editui":"/pages/resumedraft.action?draftId=2743992321","webui":"/spaces/BAN/pages/2743992321/DBA+Migration+to+Tpago","edituiv2":"/spaces/BAN/pages/edit-v2/2743992321"}},{"id":"3025043467","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/3025043467","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMzAyNTA0MzQ2Nw==","status":"current","title":"DBA en TPago Fase 1 - Tasking y Estimación","macroRenderedOutput":{},"extensions":{"position":160501016},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/3025043467/restriction/byOperation","history":"/rest/api/content/3025043467/history","body":"","version":"","descendants":"/rest/api/content/3025043467/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3025043467/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/3025043467","tinyui":"/x/C4BOt","editui":"/pages/resumedraft.action?draftId=3025043467","webui":"/spaces/BAN/pages/3025043467/DBA+en+TPago+Fase+1+-+Tasking+y+Estimaci+n","edituiv2":"/spaces/BAN/pages/edit-v2/3025043467"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<ac:structured-macro ac:name=\"info\" ac:schema-version=\"1\" ac:macro-id=\"8c21890f-60cd-4846-83f5-909d2bb9629b\"><ac:rich-text-body><p>Este documento presenta las dudas / preguntas / notas sobre el siguiente archivo</p><a href=\"https://bancard.atlassian.net/wiki/spaces/PRYLDP/pages/300875864/Definiciones+para+logs+vista+de+detalles+y+proceso+para+migraciones+DBA.\" data-card-appearance=\"block\">https://bancard.atlassian.net/wiki/spaces/PRYLDP/pages/300875864/Definiciones+para+logs+vista+de+detalles+y+proceso+para+migraciones+DBA.</a><p> </p></ac:rich-text-body></ac:structured-macro><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"826ab88e-a15f-4bba-8b7d-f26f38efd66d\"><colgroup><col style=\"width: 147.0px;\" /><col style=\"width: 613.0px;\" /></colgroup><tbody><tr><th><p /></th><th><p><strong>Nota</strong></p></th></tr><tr><td><p><strong>LOGS</strong></p></td><td><p>Crear un archivo log <strong>dedicado </strong>netamente a las migraciones DBA. El nombre puede ser dba_migrations_#{ENVIRONMENT}.log</p><p>Por cada migraci&oacute;n que se realice desde el <strong>Portal o la API</strong> se pide guardar los datos relacionados a la migraci&oacute;n y a los contratos que tuvieron inconvenientes al ser procesados.</p></td></tr><tr><td><p /></td><td><p>Posible formato del log:</p><p>Se indica un posible formato a continuaci&oacute;n:</p><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:macro-id=\"42d6f130-4f97-4a62-af40-f5918c73bd13\"><ac:plain-text-body><![CDATA[**************** NUEVA MIGRACIÓN #{NOMBRE-SUSCRIPCIÓN} ****************\n\nINICIO PROCESO: #{FECHA/HORA_ACTUAL}\n\nMONTO: #{MONTO}\n\nINICIO SUSCRIPCIÓN: #{FECHA_INICIO}\n\nFIN SUSCRIPCIÓN: #{FECHA_FIN}\n\nFIN PROCESO: #{FECHA/HORA_ACTUAL}\n\nTOTAL DE REGISTROS: #{TOTAL_FILAS_CSV}\n\nTOTAL DE ERRORES ENCONTRADOS: #{TOTAL_FILAS_CON_ERRORES}\n\nCONTRATO: #{NÚMERO_CONTRATO_CON_ERROR - MENSAJE_EXCEPCIÓN}\n\n---\n\nCONTRATO: #{OTRO_NÚMERO_CONTRATO_CON_ERROR - MENSAJE_EXCEPCIÓN}\n\n**************** FIN MIGRACIÓN ****************]]></ac:plain-text-body></ac:structured-macro></td></tr><tr><td><p /></td><td><p>Con respecto a los contratos con fallas, la cantidad de contratos mostrados en debe de ser igual a la cantidad mostrada en el total de errores. El mensaje de excepci&oacute;n tambi&eacute;n debe de ser lo m&aacute;s <strong>especifico y t&eacute;cnico</strong> posible ya que est&aacute; orientado a soporte.</p></td></tr><tr><td><p><strong>VISTA DE HIST&Oacute;RICO</strong></p></td><td><ol start=\"1\"><li><p>Vamos a tener una secci&oacute;n de Hist&oacute;rico de Migraciones. Ac&aacute; vamos a tener una <strong>tabla</strong> con una lista de los nombres de los archivos migrado, con los siguientes valores:</p><ol start=\"1\"><li><p>Fecha/Hora inicio procesamiento</p></li><li><p>Fecha/Hora fin procesamiento</p></li><li><p>Cantidad total de registros del archivo.</p></li><li><p>Cantidad de registros procesados exitosamente.</p></li><li><p>Cantidad de registros procesados con errores. (enlazar errores) </p></li><li><p>Link de suscripci&oacute;n generado. (Utilizar formato de enlace).</p></li><li><p>Nombre del archivo subido.</p></li><li><p>Usuario que cargo el archivo.</p></li><li><p>Detalle: Este campo va a descargar un archivo con los logs de la migaci&oacute;n</p></li></ol></li><li><p><strong>El usuario va a poder descargar el archivo con el detalle de los errores, con Titulo: </strong>{Nombre del archivo}</p><ol start=\"1\"><li><p>Los datos a mostrar son: </p><ol start=\"1\"><li><p>N&uacute;mero de contrato</p></li><li><p>Estado (No encontrado / error) </p></li><li><p>Mensaje (guardar en una tabla)</p></li><li><p>El mensaje no debe contener datos sensibles ni indicar porque ha habido error. Ejemplos: </p><ol start=\"1\"><li><p>Tarjeta no encontrada bajo el contrato indicado.</p></li><li><p>Error de proceso (Mostrar cuando es un fallo del proceso en si)</p></li></ol></li></ol></li><li><p>Esos datos de detalles deben ser guardados en una nueva tabla dba_migrations_details con una columna por cada dato de la tabla y </p><p>tambi&eacute;n guardar la excepci&oacute;n detallada en una columna separada que no se muestra al comercio. Esta columna servir&aacute; para hacer </p><p>soporte</p></li></ol></li></ol></td></tr><tr><td><p><strong>PROCESO DE MIGRACI&Oacute;N</strong></p></td><td><p>El proceso de migraci&oacute;n debe recorrer todas las migraci&oacute;n e intentar procesar la mayor cantidad de contratos posibles. Es decir que en </p><p>caso de encontrar error con un contrato, el proceso no debe parar sino que debe de realizar el registro del fallo y continuar con el </p><p>siguiente contrato. No realizar rollback en caso de errores.</p></td></tr><tr><td><p /></td><td><p>Idealmente este proceso debe ser as&iacute;ncrono. Esto implica que a nivel del portal se debe indicar que el archivo de migraci&oacute;n se ha cargado correctamente y se estar&aacute; procesando el documento. A nivel de API, al finalizar la petici&oacute;n de la migraci&oacute;n, se debe de contestar de manera s&iacute;ncrona que el proceso fue encolado exitosamente.</p></td></tr><tr><td><p /></td><td><p>Un detalle importante a tener en cuenta es que el proceso de migraci&oacute;n no debe de tener en cuenta el limite m&aacute;ximo de catastros de una tarjeta. Por ejemplo, hoy est&aacute; configurado el m&aacute;ximo de catastros de una misma tarjeta en 3 y si est&aacute; tarjeta vuelve a entrar mediante la migraci&oacute;n DBA entonces se le debe permitir el catastro.</p></td></tr><tr><td><p><strong>NOTIFICACI&Oacute;N DEL FIN DE PROCESO DE MIGRACI&Oacute;N</strong></p></td><td><p>Como el proceso de migraci&oacute;n se busca realizar de manera as&iacute;ncrona, se debe de notificar al usuario cuando el proceso a finalizado.</p></td></tr><tr><td><p /></td><td><p>Para el portal se puede notificar el usuario utilizando el cuadro flash utilizado en el portal de usuarios Tpago.</p></td></tr><tr><td><p /></td><td><p>Con respecto a la API, se pondr&aacute; a disposici&oacute;n del comercio un servicio de consulta donde se indique el estado actual de la migraci&oacute;n.</p></td></tr><tr><td><p /></td><td><p>Ejemplo exitoso: </p><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"253\" ac:original-width=\"751\" ac:custom-width=\"true\" ac:alt=\"Screenshot 2024-05-09 at 14.28.58.png\" ac:width=\"596\"><ri:attachment ri:filename=\"Screenshot 2024-05-09 at 14.28.58.png\" ri:version-at-save=\"1\" /></ac:image></td></tr><tr><td><p /></td><td><p>Ejemplo fallido:</p><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"196\" ac:original-width=\"752\" ac:custom-width=\"true\" ac:alt=\"Screenshot 2024-05-09 at 14.29.19.png\" ac:width=\"596\"><ri:attachment ri:filename=\"Screenshot 2024-05-09 at 14.29.19.png\" ri:version-at-save=\"1\" /></ac:image></td></tr></tbody></table><p />","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/3066069021"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":707},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3066069021/child","restrictions":"/rest/api/content/3066069021/restriction/byOperation","history":"/rest/api/content/3066069021/history","draftVersion":"","descendants":"/rest/api/content/3066069021/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=3066069021","webui":"/spaces/BAN/pages/3066069021/Notas+sobre+definiciones+para+logs+vista+de+detalles+y+proceso+para+migraciones+DBA","edituiv2":"/spaces/BAN/pages/edit-v2/3066069021","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/3066069021","tinyui":"/x/HYDAtg","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}