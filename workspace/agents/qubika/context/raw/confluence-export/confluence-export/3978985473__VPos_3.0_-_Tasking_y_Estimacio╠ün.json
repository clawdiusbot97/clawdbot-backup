est/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2760147005/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2760147005","tinyui":"/x/PYCEp","editui":"/pages/resumedraft.action?draftId=2760147005","webui":"/spaces/BAN/pages/2760147005/Iniciativas+en+Curso","edituiv2":"/spaces/BAN/pages/edit-v2/2760147005"}},{"id":"3233218577","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/3233218577","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMzIzMzIxODU3Nw==","status":"current","title":"VPos","macroRenderedOutput":{},"extensions":{"position":10592077},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/3233218577/restriction/byOperation","history":"/rest/api/content/3233218577/history","body":"","version":"","descendants":"/rest/api/content/3233218577/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3233218577/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/3233218577","tinyui":"/x/EQC3w","editui":"/pages/resumedraft.action?draftId=3233218577","webui":"/spaces/BAN/pages/3233218577/VPos","edituiv2":"/spaces/BAN/pages/edit-v2/3233218577"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<ac:structured-macro ac:name=\"info\" ac:schema-version=\"1\" ac:macro-id=\"a92d8a6e-26e5-499c-a78f-6599b35c1b62\"><ac:rich-text-body><p>Este documento representa el tasking y estimaci&oacute;n para la iniciativa <a href=\"https://bancard.atlassian.net/wiki/spaces/P3C/pages/1328939045/Portal+de+comercios+vpos+3.0\">VPos 3.0</a>, a cargo de <ac:link><ri:user ri:account-id=\"612e2e8063f7bb006976b761\" ri:local-id=\"d2a33c43-70ea-4c6d-892e-84e238145b76\" /></ac:link>.</p><p>Las horas estimadas son: <strong>441 horas ~ 55 d&iacute;as</strong></p><p>Fecha de Inicio:  <time datetime=\"2025-05-27\" /> </p><p>Fecha estimada de Entrega: <time datetime=\"2025-08-13\" /> </p></ac:rich-text-body></ac:structured-macro><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"d127e8c3-3fed-4af2-bc1b-c09b7117def2\"><colgroup><col style=\"width: 391.0px;\" /><col style=\"width: 153.0px;\" /><col style=\"width: 215.0px;\" /></colgroup><tbody><tr><th><p><strong>Tarea</strong></p></th><th><p style=\"text-align: center;\"><strong>Estimaci&oacute;n (hs)</strong></p></th><th><p style=\"text-align: center;\"><strong>Portal / Servicio</strong></p></th></tr><tr><td data-highlight-colour=\"#ffffff\"><p>Setup inicial y creaci&oacute;n de Proyecto de de Portal bancard-cybersource-portal</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">8</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">cybersource-portal</p></td></tr><tr><td data-highlight-colour=\"#ffffff\"><p>Dockerizaci&oacute;n con docker-compose</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">8</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">cybersource-portal</p></td></tr><tr><td data-highlight-colour=\"#ffffff\"><p>Configuraci&oacute;n de Sentry</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">4</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">cybersource-portal</p></td></tr><tr><td data-highlight-colour=\"#ffffff\"><p>Configuraci&oacute;n de GitHub Actions, Bito, RSpec, Rubocop</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">8</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">cybersource-portal</p></td></tr><tr><td data-highlight-colour=\"#ffffff\"><p>Creaci&oacute;n de Application Credentials</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">4</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">cybersource-portal</p></td></tr><tr><td data-highlight-colour=\"#ffffff\"><p>Integrar Redis para compartir sesi&oacute;n con commerce-suite</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">4</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">cybersource-portal</p></td></tr><tr><td data-highlight-colour=\"#ffffff\"><p>Agregar bancard-cybersource-portal en bancard-configurations</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">4</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">bancard-configurations</p></td></tr><tr><td data-highlight-colour=\"#ffffff\"><p>Configurar m&aacute;quina de staging para bancard-cybersource-portal</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">4</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">dockerized-nginx</p></td></tr><tr><td data-highlight-colour=\"#ffffff\"><p>Configurar proxy de servicios de staging para bancard-cybersource-portal</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">4</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">commerce-suite-nginx</p></td></tr><tr><td data-highlight-colour=\"#ffffff\"><p>Configurar maquina de producci&oacute;n para bancard-cybersource-portal</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">6</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">dockerized-nginx</p></td></tr><tr><td data-highlight-colour=\"#ffffff\"><p>Configurar proxy de servicios de producci&oacute;n para bancard-cybersource-portal</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">6</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">commerce-suite-nginx</p></td></tr><tr><td><p>Crear tarjeta del producto de VPos 3.0 &ldquo;Cybersource&rdquo; en secci&oacute;n de Mis Productos Contratados / Productos Adicionales.</p></td><td><p style=\"text-align: center;\">16</p></td><td><p style=\"text-align: center;\">commerce-suite</p></td></tr><tr><td data-highlight-colour=\"#ff8f73\"><p>Crear la landing (opportunity product) para contratar este nuevo producto VPos 3.0</p><ul><li><p><em>Pendiente logos, Precios y Dise&ntilde;o de Landing con textos. </em></p></li></ul></td><td data-highlight-colour=\"#ff8f73\"><p style=\"text-align: center;\">24</p></td><td data-highlight-colour=\"#ff8f73\"><p style=\"text-align: center;\">commerce-suite</p></td></tr><tr><td><p>Para la secci&oacute;n soporte, crear el producto y pasarlo al Controller gen&eacute;rico. Simular lo que hoy en d&iacute;a esta para VPos 2.0 pero para el nuevo producto.</p></td><td><p style=\"text-align: center;\">16</p></td><td><p style=\"text-align: center;\">commerce-suite</p></td></tr><tr><td><p>Crear vista al entrar a la configuraci&oacute;n del nuevo producto VPos 3.0. </p><p>Simular vista redise&ntilde;o nueva de TPago Portal (sidebar fija + centro cambiable)</p></td><td><p style=\"text-align: center;\">32</p></td><td><p style=\"text-align: center;\">commerce-suite</p></td></tr><tr><td><p>Crear SideBar con el Men&uacute;</p></td><td><p style=\"text-align: center;\">16</p></td><td><p style=\"text-align: center;\" /></td></tr><tr><td><p>Crear vista de '<em>Comercios Habilitados'</em> &rarr; esta vista mostrar&aacute; una tabla con datos de sucursales del comercio que est&eacute; logueado. </p><p><em>Para obtener estos datos consumiremos otro servicio RPG. Tambi&eacute;n manejar datos tanto de Sandbox como de Produccion.</em></p></td><td><p style=\"text-align: center;\">24</p></td><td><p style=\"text-align: center;\">commerce-suite</p></td></tr><tr><td><p>Crear vista de &lsquo;<em>Integraci&oacute;n con API</em>&rsquo; &rarr; contendr&aacute; secci&oacute;n para credenciales pub/priv, tanto para Sandbox como Prod (pesta&ntilde;as switcheables). </p><p>Para obtener estas credenciales consumiremos servicio RPG. Tambi&eacute;n tendr&aacute; una pesta&ntilde;a &lsquo;documentaci&oacute;n&rsquo; con texto, tarjetas de prueba, etc</p></td><td><p style=\"text-align: center;\">40</p></td><td><p style=\"text-align: center;\">commerce-suite</p></td></tr><tr><td><p>Crear vista de '<em>Movimientos</em>' &rarr; tabla para filtrar los movimientos hechos con Cybersource. </p><ul><li><p><em>Consumiremos un dataset de vpos-service para obtener estos datos. </em></p></li><li><p><em>La tabla tendr&aacute;: </em></p><ul><li><p><em>Datos de un pago Cybersource </em></p></li><li><p><em>Filtros sobre los datos numero de boleta, fecha, codigo de autorizacion, medio de pago y sucursal. (S&oacute;lo se mostrar&aacute;n pagos de Cybersource aprobados)</em></p></li><li><p><em>Opci&oacute;n de descargar un .csv con los datos mostrados en la tabla.</em></p></li></ul></li></ul></td><td><p style=\"text-align: center;\">40</p></td><td><p style=\"text-align: center;\">commerce-suite</p></td></tr><tr><td><p>Crear endpoint para consumir servicio REST que obtiene claves pub/priv para comercio Cybersource (sandbox y prod)</p></td><td><p style=\"text-align: center;\">16</p></td><td><p style=\"text-align: center;\">commerce-service</p></td></tr><tr><td><p>Crear endpoint para consumir servicio REST que obtiene comercios habilitados de Cybersource para un comercio dado.</p></td><td><p style=\"text-align: center;\">16</p></td><td><p style=\"text-align: center;\">commerce-service</p></td></tr><tr><td><p>Crear endpoint para dataset de nueva tabla Cybersource, para el reporte de movimientos. </p></td><td><p style=\"text-align: center;\">20</p></td><td><p style=\"text-align: center;\">commerce-service</p></td></tr><tr><td><p>Crear nueva tabla Cybersource donde persistir transacciones de Cybersource. </p><p><em>Las columnas ser&aacute;n:</em></p><ul><li><p><em>nro boleta, </em></p></li><li><p><em>transaction id de Cybersource, </em></p></li><li><p><em>Transaction id de commerce-service. </em></p></li></ul><p><em>Pendiente: consulta que otros datos se necesitan para la tabla nueva.</em></p></td><td><p style=\"text-align: center;\">4</p></td><td><p style=\"text-align: center;\">commerce-service</p></td></tr><tr><td data-highlight-colour=\"#e3fcef\"><p>Crear nueva tabla <em><strong>raw_trn_cybersource</strong></em> donde persistir transacciones raw de Cybersource y agregar nuevas columnas a la tabla <em><strong>transactions_cybersource</strong></em></p></td><td data-highlight-colour=\"#e3fcef\"><p style=\"text-align: center;\">4</p></td><td data-highlight-colour=\"#e3fcef\"><p>commerce-service</p></td></tr><tr><td data-highlight-colour=\"#e3fcef\"><p>Crear proceso Sidekiq que migre los datos de la tabla de <strong>raw_trn_cybersource</strong> a <strong>transactions_cybersource.</strong> </p></td><td data-highlight-colour=\"#e3fcef\"><p style=\"text-align: center;\">32</p></td><td data-highlight-colour=\"#e3fcef\"><p>commerce-service</p></td></tr><tr><td data-highlight-colour=\"#e3fcef\"><p>Crear endpoint para cargar raw transactions de Cybersource a la tabla <em><strong>raw_trn_cybersource</strong></em></p></td><td data-highlight-colour=\"#e3fcef\"><p style=\"text-align: center;\">16</p></td><td data-highlight-colour=\"#e3fcef\"><p>commerce-service</p></td></tr><tr><td data-highlight-colour=\"#e3fcef\"><p>Modificar validaciones de preauth confirm en el proceso que tenemos hoy en d&iacute;a de raw transactions </p></td><td data-highlight-colour=\"#e3fcef\"><p style=\"text-align: center;\">8</p></td><td data-highlight-colour=\"#e3fcef\"><p>commerce-service</p></td></tr><tr><td data-highlight-colour=\"#ffffff\"><p>Salida a Staging</p><ul><li><p>Integraci&oacute;n de los flujos</p></li><li><p>Creaci&oacute;n y correci&oacute;n de PRs</p></li><li><p>Pruebas locales</p></li><li><p>Armado de ramas</p></li><li><p>Deploy a STG</p></li><li><p>Pruebas iniciales en STG</p></li></ul></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\">&nbsp;32</p></td><td data-highlight-colour=\"#ffffff\"><p style=\"text-align: center;\" /></td></tr><tr><td data-highlight-colour=\"#eae6ff\"><p><strong>Total Desarrollo</strong></p></td><td data-highlight-colour=\"#eae6ff\"><p style=\"text-align: center;\">&nbsp;392</p></td><td data-highlight-colour=\"#eae6ff\"><p style=\"text-align: center;\" /></td></tr><tr><td data-highlight-colour=\"#eae6ff\"><p><strong>Total Gesti&oacute;n 15% (para facturaci&oacute;n, no afecta el desarrollo)</strong></p><p><em>Incluye reuniones de estimaci&oacute;n, planificaci&oacute;n, t&eacute;cnicas y de seguimiento.</em></p></td><td data-highlight-colour=\"#eae6ff\"><p style=\"text-align: center;\">&nbsp;49</p></td><td data-highlight-colour=\"#eae6ff\"><p style=\"text-align: center;\" /></td></tr><tr><td data-highlight-colour=\"#eae6ff\"><p><strong>Total Desarrollo + Gesti&oacute;n</strong></p></td><td data-highlight-colour=\"#eae6ff\"><p style=\"text-align: center;\"><strong>441</strong></p></td><td data-highlight-colour=\"#eae6ff\"><p style=\"text-align: center;\" /></td></tr></tbody></table>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/3978985473"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":179692414},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3978985473/child","restrictions":"/rest/api/content/3978985473/restriction/byOperation","history":"/rest/api/content/3978985473/history","draftVersion":"","descendants":"/rest/api/content/3978985473/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=3978985473","webui":"/spaces/BAN/pages/3978985473/VPos+3.0+-+Tasking+y+Estimaci+n","edituiv2":"/spaces/BAN/pages/edit-v2/3978985473","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/3978985473","tinyui":"/x/AYAq7Q","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}