tions":"","schedulePublishDate":"","children":"/rest/api/content/2178416778/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2178416778","tinyui":"/x/igDYgQ","editui":"/pages/resumedraft.action?draftId=2178416778","webui":"/spaces/BAN/overview","edituiv2":"/spaces/BAN/pages/edit-v2/2178416778"}},{"id":"2685108225","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2685108225","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjY4NTEwODIyNQ==","status":"current","title":"Iniciativas","macroRenderedOutput":{},"extensions":{"position":274391100},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2685108225/restriction/byOperation","history":"/rest/api/content/2685108225/history","body":"","version":"","descendants":"/rest/api/content/2685108225/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2685108225/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2685108225","tinyui":"/x/AYALo","editui":"/pages/resumedraft.action?draftId=2685108225","webui":"/spaces/BAN/pages/2685108225/Iniciativas","edituiv2":"/spaces/BAN/pages/edit-v2/2685108225"}},{"id":"2760147005","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2760147005","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjc2MDE0NzAwNQ==","status":"current","title":"Iniciativas en Curso","macroRenderedOutput":{},"extensions":{"position":258},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2760147005/restriction/byOperation","history":"/rest/api/content/2760147005/history","body":"","version":"","descendants":"/rest/api/content/2760147005/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2760147005/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2760147005","tinyui":"/x/PYCEp","editui":"/pages/resumedraft.action?draftId=2760147005","webui":"/spaces/BAN/pages/2760147005/Iniciativas+en+Curso","edituiv2":"/spaces/BAN/pages/edit-v2/2760147005"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<ac:structured-macro ac:name=\"info\" ac:schema-version=\"1\" ac:local-id=\"c147d27f-8caa-4b12-80a2-edb634ffc9c6\" ac:macro-id=\"afa40db3-5158-46b8-a999-6cea1ecb7b71\"><ac:rich-text-body><p local-id=\"e0da6cf2-7dd6-4d87-97f3-53225ddcd170\"><ac:inline-comment-marker ac:ref=\"80a0e5eb-7872-4968-ad44-f7f3e6b884e1\">Este documento representa el tasking y estimaci&oacute;n para Pago con Cuenta Bancaria, a cargo de </ac:inline-comment-marker><ac:link><ri:user ri:account-id=\"62cf58bd10fcc6f7ae3eaf41\" ri:local-id=\"4e9a222c-e8ac-4fcf-a8ee-e8e7065049f7\" /></ac:link> .</p><p local-id=\"0bda2e93-7c33-49ae-a837-5fc181cb0c3e\">Las horas estimadas son: 214 ~ 35 d&iacute;as teniendo en cuenta que <ac:link><ri:user ri:account-id=\"62cf58bd10fcc6f7ae3eaf41\" ri:local-id=\"551dcd32-2011-45da-973c-209f8be44d23\" /></ac:link> trabaja 6hs por d&iacute;a.</p><p local-id=\"ee32bfa1e7d5\">Fecha de Inicio: <time datetime=\"2026-02-02\" local-id=\"172b5b137716\" /> </p><p local-id=\"68960efd-5656-452a-b135-15641f692b86\">Fecha de Entrega: <time datetime=\"2026-03-24\" local-id=\"ebf44b2c77fc\" /> </p></ac:rich-text-body></ac:structured-macro><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"d127e8c3-3fed-4af2-bc1b-c09b7117def2\"><colgroup><col style=\"width: 362.0px;\" /><col style=\"width: 140.0px;\" /><col style=\"width: 258.0px;\" /></colgroup><tbody><tr ac:local-id=\"d2a2e97d-8fa4-4886-8125-f835de504a36\"><th ac:local-id=\"15b128c6-6640-433a-a3b8-06d149937bf6\"><p local-id=\"da72ded9-b7fe-4c42-8b4c-cd49f4b9783e\"><strong>Tarea</strong></p></th><th ac:local-id=\"9d06c34d-eff6-4282-8919-072990a814e9\"><p local-id=\"adcf0d04-8c4f-4cc6-8a76-0406db4a4dcd\"><strong>Servicio</strong></p></th><th ac:local-id=\"564fa32d-19a4-4008-ba94-b589fd6dd11e\"><p local-id=\"6d0eb572-95fe-4438-8cb5-4c5927d056da\" style=\"text-align: center;\"><strong>Estimaci&oacute;n (hs)</strong></p></th></tr><tr ac:local-id=\"60e92683-fa73-496f-8d81-1efc5683705a\"><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"8078f032-ea2d-417b-8c00-a27d7bce8abd\"><p local-id=\"586cc67c-eba3-46c1-937e-50c183e54201\">Agregar columnas para bank_account_original_number y account_holder a Account, </p><p local-id=\"ff52224e-62c5-4196-a0eb-0b099d84f2e8\">Crear modelo BankAccount &lt; Account<br />y validaciones de presencia de los valores mencionados</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"fa473f0d-1de2-4ee5-a98d-885fb27f57d3\"><p local-id=\"2270f4e2-d6eb-4f04-87a0-645874034c22\">billing-service</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"a179966f-b38f-4d09-9266-8f4f44010f24\"><p local-id=\"2f2e8298-625d-424a-b280-ea2548839907\">12</p></td></tr><tr ac:local-id=\"fa101e19-5482-4310-bddc-a03af5deda96\"><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"cd15b2ef-1f96-4a3f-9261-904ce2bfa158\"><p local-id=\"e38e60c7-84b9-452d-8c9c-a8fd36acbcc0\">Crear Tabla y modelo BankAccountAttempt con las siguientes columnas:<br /><br />- id (indexado, &uacute;nico)<br />- user_id (belongs_to)<br />- Account (belongs_to optional)<br /><ac:inline-comment-marker ac:ref=\"eb39c884-6a9b-4af4-b501-d9e3c6ac447b\">- otp</ac:inline-comment-marker></p><p local-id=\"8df7c3fe3499\">-otp_expires_at<br />- todos los campos requeridos para catastrar la cuenta bancaria (account_number, cel y CI ingresados por el usuario)<br />- <ac:inline-comment-marker ac:ref=\"704aba16-0f02-4f87-836b-1582ea1950e7\">status (pendiente/aceptado/rechazado validacion/ rechazado notificacion)</ac:inline-comment-marker><br /><br />Definir m&eacute;todos on-create para asignaci&oacute;n autom&aacute;tica de OTP<br /><br />Definir m&eacute;todos de instancia para renovar OTP</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"d46515d8-fde5-4ac6-9329-02485dde0f27\"><p local-id=\"e449560d-affe-44d9-b811-91b15183ccc3\" /></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"21750537-b9e6-406e-9cd8-81a5cbba0bd5\"><p local-id=\"a51be742-d3ca-48f0-ab75-ff26b575597f\">12</p></td></tr><tr ac:local-id=\"06402df0-8e80-47fd-94af-33fc7da3f57e\"><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"6fec71b8-3f3a-443b-af40-7d392111a1d8\"><p local-id=\"b2a6b33f-d2b4-4b35-868c-f2aac121b907\">Insertar en tabla FinancialInstitutions una columna accepts_bank_account <strong>boolean</strong> con <strong>default false</strong><br /><br />agregar la columna al dataset FinancialInstitutions</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"e5849572-8b38-4675-ab82-5b89e50c9798\"><p local-id=\"490b7882-a379-4d0c-bc44-99aa60637ae1\">billing_service</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"0d9f1f56-041a-454d-86cb-03b962841993\"><p local-id=\"aed39b22-b279-40d0-ad0f-c23bfb45c0a1\">4</p></td></tr><tr ac:local-id=\"cb83642992ce\"><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"23b3e51ec4b5\"><p local-id=\"81144a8fc32a\">Crear tabla financial_institution_messages que tenga columnas: financial_institution_id, message_key y el message</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"9345662c1aec\"><p local-id=\"2b2edf3e6048\">billing-srv</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"91da4dd8193a\"><p local-id=\"9ce41ba5588f\">4</p></td></tr><tr ac:local-id=\"d8f83599-0061-4600-aab9-9d8da1c4f02e\"><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"69836835-262d-4c7a-84cc-5a480927f04c\"><p local-id=\"219ea505-fccf-4cf5-a5fb-6838dc7475a0\">Implementar vista para elegir una entidad financiera (para catastrar una cuenta) (inicialmente solo Banco Continental)<br /><br />utilizar get_financial_institutions_report filtrando por accepts_bank_account = true</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"c0d2e312-00e9-4e75-ac15-a56f2496fdd4\"><p local-id=\"ea179933-ae24-4311-a6f9-63ee3e85d75c\">bportal</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"983394e2-48e7-446d-aa27-e4b33ea45649\"><p local-id=\"6c3060eb-f8a1-43a9-837b-c0ec6a6a776b\">8</p></td></tr><tr ac:local-id=\"cd6fc615-ac86-4a95-a363-6bca05074a63\"><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"d614beb4-170c-4608-824e-1b17a6d21657\"><p local-id=\"482bdec6-686a-40bc-88be-c7cac75c559a\">Vista formulario agregar medio de pago (Cuenta Bancaria)<br /><br />Al submittear el form se llama a billing-service y se redirecciona a la vista de OTP<br /><br />se submittea bank_account_original_number, ci(tomado del user), celular (tomado del user) y financial_institution_id(de la vista anterior)<br /><br />Ante error de la entidad de 'Catastro bloqueado' redirigir al index con un flash de error</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"68b9df18-cdbf-447d-8092-1bdf43d26563\"><p local-id=\"15135d74-c138-46f4-9408-8a12f30ede83\">bportal</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"23b55051-2569-4192-afb5-1d0085b340ff\"><p local-id=\"4024778f-883b-40e6-999d-5a09f58bdf94\">16</p></td></tr><tr ac:local-id=\"bfc0f9c1-1a4d-44f2-86f6-9cd68eda7a21\"><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"91cf3628-aa5f-453c-8360-d1342f38c82e\"><p local-id=\"bcf00562-2ff5-42ed-a97a-aa56f1421263\">Implementar endpoint de pre-registro de cuenta bancaria.<br /></p><p local-id=\"34410990-070f-4115-b906-e677ba6ae51c\">Se crear&aacute; un nuevo registro en la tabla BankAccountAttempt con los datos de la cuenta y un OTP generado en el momento</p><p local-id=\"833ada15-8787-4598-ade7-e6e825c6a3ad\">Se llama a la entidad y se le env&iacute;a el OTP<br />(Usar FinancialInstitutionOperations)</p><p local-id=\"83b663e6-9d12-4c52-88db-b91ed547a854\">Timeout configurable globalmente para este llamado (5 seg originalmente)</p><p local-id=\"96ae1f13-880e-48ef-ae4c-16df3d84d326\">Se retorna a bportal el otp_expires_at</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"0f538081-9875-43f3-8877-3cd88cc112e5\"><p local-id=\"131b9b43-0d33-4f31-b44c-6f0ac45c9f0f\">billing-service</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"e449b475-d522-4966-a264-6cb2a1dc9258\"><p local-id=\"d1c1bc8c-8cf5-4ac6-b56f-51e99c1a3ea7\">18</p></td></tr><tr ac:local-id=\"408b59680e85\"><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"ec006d9e5c54\"><p local-id=\"5fc6d0552dc0\">Agregar endpoint de reenvio de otp</p><p local-id=\"05093a53efd5\">Recibe el id del bank_account_attempt, genera un nuevo otp y llama a la misma operaci&oacute;n de la entidad de validaci&oacute;n de cuenta (con la informacion que ya esta guardada en el bank_account_attempt)</p><p local-id=\"207d498352f0\">Validar que el status sea pendiente, levantar error en caso contrario.</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"e25fe8e90821\"><p local-id=\"135bff31664b\">billing-srv</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"255e879571d3\"><p local-id=\"2526440a5282\">8</p></td></tr><tr ac:local-id=\"443e38a6-9fb0-442a-86b1-4e423f5383fc\"><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"f19a5c9d-d7e3-439d-8a96-d078cc6bcb18\"><p local-id=\"1e49a8c8-2e68-4384-bf35-28c9fdb505c3\"><span style=\"color: rgb(76,154,255);\">Implementar vista de ingreso de OTP</span><br /><br />Al submittear el OTP se llama a Billing-service<br />para validar el OTP de registro de cuenta, y completar el catastro.<br /><br />Se debe incluir boton de reenvio de OTP, recordar bloquearlo por 30 seg despues de clickeado (mostrar este contador?)</p><p local-id=\"456e73304921\">Se debe mostrar un contador del tiempo de validez del OTP. Este contador no se reinicia si se ingresa OTP invalido, pero si si se reenvia el OTP</p><p local-id=\"5004180ddab0\"><br />En caso de &eacute;xito se redirecciona a la vista de medios de pago<br /><br />En caso de fracaso, se debe soportar estos dos flujos:<br />- Reintentar hasta que el back-end indique que no se puede m&aacute;s<br />- Flash de error y redirecci&oacute;n a vista de medios de pago</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"c1518785-954c-4197-9753-c7dbc303c202\"><p local-id=\"481c5686-3200-46d2-aba4-32cdf8c657dd\"><span style=\"color: rgb(7,71,166);\">bportal</span></p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"bb87afd5-669e-436e-b67f-77afec9de395\"><p local-id=\"9fed91e8-e386-4e54-b834-67fb9c5af532\"><span style=\"color: rgb(7,71,166);\">20</span></p></td></tr><tr ac:local-id=\"b1e7cf07-70f9-4330-ac79-6ca7a0893470\"><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"fe141f82-88b6-4206-ba84-6f473bb6ff88\"><p local-id=\"3aa43baf-4f52-446e-b02a-90a21f9f2bfb\">Implementar endpoint confirm_bank_account<br /><br />Se valida OTP contra el guardado</p><p local-id=\"a3886e58a74e\">Se llama al endpoint de notificacion en caso de otp fallido con key otp_failed, y en caso de exito con key approved/otp_success. Siempre esperando la respuesta de la entidad.<br /></p><p local-id=\"eec7e895083b\">Si el otp fue exitoso y la entidad responde un 200 solo entonces se crea el entry BankAccount en la DB</p><p local-id=\"da9ea7eec49d\">En caso de que el otp falle y la entidad responda con 200, no se crea la cuenta pero se permite reintentar otp</p><p local-id=\"052e6580bb95\">Si la entidad responde error, responder un error y en el front se redirige a medios de pago<br /></p><p local-id=\"556c799dc264\">Enviar a audit-srv el resultado si el otp coincide y la respuesta de la entidad, con bank_account_attempt_id. y user_id. Ver que datos mandar.</p><p local-id=\"1a3dbc0210a4\">Loggear todas las requests a la entidad (ver si se puede extender GenericRequest para redefinir el metodo logger)</p><p local-id=\"36c8a2674311\"><br />Se actualiza el BankAccountAttempt acorde al resultado (status).</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"6fb6ced3-5c9b-4627-a84e-7e65decbd8d4\"><p local-id=\"0ed06fae-8051-4b18-be7b-60c49652e94c\"><span style=\"color: rgb(7,71,166);\">billing-service</span></p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"fea97cb5-1b08-4f01-9d73-f1ace64ba5ef\"><p local-id=\"4cf6c2bf-476b-4621-91a3-394d7fa6abe8\">20</p></td></tr><tr ac:local-id=\"9454089f-b75a-4c57-9f28-d69d5abf8588\"><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"439b0781-e35c-40bd-86f7-1103acb693c7\"><p local-id=\"0e0219c7-97bb-4f3d-a6fa-2eff2b2806f3\">En vista de Mis Transacciones agregar filtro de BankAccount</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"e54c1116-bd23-479f-ae6d-efd3c3dcd16e\"><p local-id=\"98a3e92a-7432-4936-a643-db83109b9b3c\">bportal</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"abcec36a-3369-4e62-a77d-c3d49a76bbab\"><p local-id=\"368262b8-d022-4d57-b235-bc0ecb9f0244\">12</p></td></tr><tr ac:local-id=\"83c7413f-4e77-44fa-bb99-8c2a513e0f0e\"><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"26caede0-a9d9-41d2-bc84-3cc2464b50fb\"><p local-id=\"7c07d845-cf5f-455f-811e-1782844e4c68\">Agregar cuenta bancaria a Reportes de transacciones</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"1b957e8b-d158-4523-a6d8-f5480c03d94a\"><p local-id=\"7a300967-3f64-4c74-b372-8e02353ae55d\">bportal/notification-service</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"a25bb5e8-d2a3-4ed4-a7f0-ba12fa65b38a\"><p local-id=\"52fea338-5bd3-4eb3-9db7-204a92f2ca58\">12</p></td></tr><tr ac:local-id=\"0ca2f5e5-7ebb-4f54-baff-ad4a417a793a\"><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"fc290a1a-4bef-47be-a42a-52654240889b\"><p local-id=\"47145343-3ae2-481e-a4bc-e1eece4dbcc8\">en <code>confirm_payment</code> asegurar soporte para pagos de QR con cuentas de tipo BankAccount</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"9754d773-3c39-4a05-860e-6fef4c0c54a4\"><p local-id=\"2d65919c-acb9-4551-b6f0-8d569e34284e\">billing-service</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"20dbfd08-a42f-47b9-b266-1308fbf108a4\"><p local-id=\"6178cbfe-5f4c-40d8-999e-dd8231645530\">4</p></td></tr><tr ac:local-id=\"865e5e89-60e9-4f8c-b675-281879df1093\"><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"744525e5-4b28-4427-b0bf-e2104a058ec5\"><p local-id=\"880b0e0a-80fc-49a8-b7cc-6227e0ae20e1\">Para borrado de Accounts, adaptar para el borrado de BankAccounts</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"af0f3b1d-02c5-4cc7-b649-c8e865981050\"><p local-id=\"f55a63de-1db8-421c-8e61-014439049e37\">billing-service</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"61a59d23-4da2-4135-a2fb-6c6389d54156\"><p local-id=\"5d05e239-2817-40a6-a6a2-142d46258ad5\">8</p></td></tr><tr ac:local-id=\"ee012463-4698-435b-9b93-a02d7f42f4e6\"><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"7dfa6327-a8c0-404e-86ba-2a8191647fa8\"><p local-id=\"b85ab8df-0954-4bb7-a6b3-0b8fbff3a1c5\">Notificar catastros borrados de una cuenta al banco correspondiente (asincr&oacute;nico)</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"b08b9a83-8ab1-43c5-b3cc-46efb57e8819\"><p local-id=\"14afd825-aa8e-41ce-8199-52c9e05969b0\">billing-service</p></td><td data-highlight-colour=\"#57d9a3\" ac:local-id=\"eca00848-3f19-4052-bc7d-24f707a3cc74\"><p local-id=\"b165528d-f357-4f8c-8afa-c7fb9b124ee1\">8</p></td></tr><tr ac:local-id=\"5c797bc3-d2a1-4d7b-848e-d1774317d592\"><td ac:local-id=\"af1b1ab2-7fc6-4155-b7a0-79a0ae965530\"><p local-id=\"162b7ed1-9b6f-4902-b9da-d9f6a789983b\">Salida a Staging</p><ul local-id=\"358f88bc-9086-4189-9230-e07404a79410\"><li local-id=\"d81b6c02-1b76-43cb-bfa6-c2513125a9d7\"><p local-id=\"585e79ac-30bb-4330-9510-b89ba95b2f1c\">Integraci&oacute;n de los flujos</p></li><li local-id=\"bf79edcf-ef91-4aeb-81da-ec196393684e\"><p local-id=\"cc7e0e28-e44d-4385-97a6-f72cb62b92aa\">Creaci&oacute;n y correci&oacute;n de PRs</p></li><li local-id=\"fdce481a-ef79-42d2-b487-5317fc826b30\"><p local-id=\"3fa164d7-9303-4118-aff2-5bb1ec262927\">Pruebas locales</p></li><li local-id=\"8109aa1e-24e5-477f-a66f-37705dbc0bca\"><p local-id=\"bdfcd0d8-bd1b-4834-b181-488890ce56f8\">Armado de ramas</p></li><li local-id=\"8a076857-0dac-4011-9f5c-6b726889bfd3\"><p local-id=\"cce53483-c62c-4a64-b0d3-a0bf241c16b7\">Deploy a STG</p></li><li local-id=\"34f256e7-a97d-403e-b937-187e29548602\"><p local-id=\"c0a4e13f-695c-4015-a73f-a63d34ef31d3\">Pruebas iniciales en STG</p></li></ul></td><td ac:local-id=\"24f8c750-bd9c-4f29-afb3-e8b04724c5e4\"><p local-id=\"dabebf89-3abf-4479-b0db-aa9e8ff81e52\" /></td><td ac:local-id=\"49c0bd42-39c5-4967-8ff9-feaa612ed271\"><p local-id=\"12937b4c-0d09-4506-8e7d-93fa6a94979d\">20</p></td></tr><tr ac:local-id=\"84974ac9-86d8-45bc-9463-38caa1bc7d92\"><td data-highlight-colour=\"#eae6ff\" ac:local-id=\"2775ca75-3d55-4dce-b2bc-0e914c41476b\"><p local-id=\"338b6936-d27c-4980-bbed-5bd387b3b450\"><strong>Total Desarrollo</strong></p></td><td data-highlight-colour=\"#eae6ff\" ac:local-id=\"09381e7b-1507-4d5a-8d30-f22064b38e08\"><p local-id=\"ee87c529-a397-4f65-985d-fdfd41ad40d6\" /></td><td data-highlight-colour=\"#eae6ff\" ac:local-id=\"9121b8e8-9e34-4760-956b-235177a9bf1e\"><p local-id=\"43b98ac9-169a-40bc-8214-5daf88261035\" style=\"text-align: center;\">186</p></td></tr><tr ac:local-id=\"b58c1376-a5cf-4ca8-bab8-6930d3dbc990\"><td data-highlight-colour=\"#eae6ff\" ac:local-id=\"9a0552fd-eb09-4f0e-8785-ccbcc2a57c9b\"><p local-id=\"e14667fb-2e3d-4036-9f04-223a74292e09\"><strong>Total Gesti&oacute;n 15% (para facturaci&oacute;n, no afecta el desarrollo)</strong></p><p local-id=\"21cec02e-9ed0-441c-878c-ce6f095788c1\"><em>Incluye reuniones de estimaci&oacute;n, planificaci&oacute;n, t&eacute;cnicas y de seguimiento.</em></p></td><td data-highlight-colour=\"#eae6ff\" ac:local-id=\"ada76c80-28fb-42cf-b8c7-d0f268626