02/restriction/byOperation","history":"/rest/api/content/4470308902/history","body":"","version":"","descendants":"/rest/api/content/4470308902/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/4470308902/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/4470308902","tinyui":"/x/JoBzCgE","editui":"/pages/resumedraft.action?draftId=4470308902","webui":"/spaces/BAN/pages/4470308902/Archived+-+Ruby+Upgrade","edituiv2":"/spaces/BAN/pages/edit-v2/4470308902"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<ac:structured-macro ac:name=\"info\" ac:schema-version=\"1\" ac:macro-id=\"9dbabb06-49d0-46b5-a3ec-fd662b7bd52b\"><ac:rich-text-body><p>En este documento vamos a listar las horas que conlleva llevar los servicios de billing-dbs a que apunten al Cluster, tambi&eacute;n las pruebas requeridas, tiempo de desarrollo / bugs fixing y el pase a producci&oacute;n.</p><p>El total es de 552 para todos los servicios, incluyendo QA y Desarrollo. Al no tener tareas claras aumentamos el margen de lo que pueden llevar estas tareas, m&aacute;s que nada las de bug fixing. En el caso que se requieran menos horas, no se facturar&aacute;n.</p><p>Las tareas que pueden surgir m&aacute;s que nada son:</p><ul><li><p>Errores de datos</p></li><li><p>Errores de Percona que impliquen tiempos muertos</p></li><li><p>Errores que haya que verificar en producci&oacute;n para confirmar que no sean conocidos</p></li></ul></ac:rich-text-body></ac:structured-macro><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"e548e811-f30a-4e45-821f-3b4b61e936f7\"><colgroup><col style=\"width: 181.0px;\" /><col style=\"width: 467.0px;\" /><col style=\"width: 109.0px;\" /></colgroup><tbody><tr><th><p><strong>Servicio</strong></p></th><th><p><strong>Tarea </strong></p></th><th><p style=\"text-align: center;\"><strong>Estimaci&oacute;n</strong></p></th></tr><tr><th><p><em>billing-public-proxy</em></p></th><td><p>Pruebas QA</p></td><td><p style=\"text-align: center;\">40</p></td></tr><tr><th><p /></th><td><p>Tareas Dev</p><p><em>Apuntar al cluster en staging, bug fixing, pase a producci&oacute;n</em></p></td><td><p style=\"text-align: center;\">60</p></td></tr><tr><th><p><em>auth-service</em></p></th><td><p>Pruebas QA</p></td><td><p style=\"text-align: center;\">40</p></td></tr><tr><th><p /></th><td><p>Tareas Dev</p><p><em>Apuntar al cluster en staging, bug fixing, pase a producci&oacute;n</em></p></td><td><p style=\"text-align: center;\">50</p></td></tr><tr><th><p><em>biller-service</em></p></th><td><p>Pruebas QA</p></td><td><p style=\"text-align: center;\">30</p></td></tr><tr><th><p /></th><td><p>Tareas Dev</p><p><em>Apuntar al cluster en staging, bug fixing, pase a producci&oacute;n</em></p></td><td><p style=\"text-align: center;\">40</p></td></tr><tr><th><p><em>mpos-service</em></p></th><td><p>Pruebas QA</p></td><td><p style=\"text-align: center;\">40</p></td></tr><tr><th><p /></th><td><p>Tareas Dev</p><p><em>Apuntar al cluster en staging, bug fixing, pase a producci&oacute;n</em></p></td><td><p style=\"text-align: center;\">40</p></td></tr><tr><th><p><em>billing-service</em></p></th><td><p>Pruebas QA </p><p><em>pagos, facturas, registro de pagos en varios productos</em></p></td><td><p style=\"text-align: center;\">60</p><p style=\"text-align: center;\" /></td></tr><tr><th><p /></th><td><p>Tareas Dev</p><p><em>Apuntar al cluster en staging, bug fixing, pase a producci&oacute;n</em></p></td><td><p style=\"text-align: center;\">80</p></td></tr><tr><th><p><strong>Total Desarrollo + QA</strong></p></th><td><p /></td><td><p style=\"text-align: center;\">480</p></td></tr><tr><th><p><strong>Total Gesti&oacute;n</strong></p></th><td><p /></td><td><p style=\"text-align: center;\">72</p></td></tr><tr><th data-highlight-colour=\"#eae6ff\"><p><strong>Total</strong></p></th><td data-highlight-colour=\"#eae6ff\"><p /></td><td data-highlight-colour=\"#eae6ff\"><p style=\"text-align: center;\">552</p></td></tr></tbody></table>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/3163226116"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":51783602},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3163226116/child","restrictions":"/rest/api/content/3163226116/restriction/byOperation","history":"/rest/api/content/3163226116/history","draftVersion":"","descendants":"/rest/api/content/3163226116/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=3163226116","webui":"/spaces/BAN/pages/3163226116/Ruby+Upgrade+-+Estimaci+n+billing-dbs+apuntando+al+Cluster","edituiv2":"/spaces/BAN/pages/edit-v2/3163226116","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/3163226116","tinyui":"/x/BACLv","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}