{"id":"4864311386","type":"page","subType":"live","subtype":"live","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/4864311386","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvNDg2NDMxMTM4Ng==","status":"current","title":"Friday Sessions - Dinámicas","version":{"by":{"type":"known","accountId":"622640bedb58c100687be853","accountType":"atlassian","email":"","publicName":"Bruno Morena","profilePicture":{"path":"/wiki/aa-avatar/622640bedb58c100687be853","width":48,"height":48,"isDefault":false},"displayName":"Bruno Morena","isExternalCollaborator":false,"isGuest":false,"locale":"en_US","accountStatus":"active","_expandable":{"operations":"","personalSpace":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/user?accountId=622640bedb58c100687be853"}},"when":"2026-02-13T15:34:34.648Z","friendlyWhen":"Feb 13, 2026","message":"Autosaved","number":2,"minorEdit":false,"ncsStepVersion":"19","ncsStepVersionSource":"ncs-ack","confRev":"confluence$content$4864311386.14","contentTypeModified":false,"_expandable":{"collaborators":"","content":"/rest/api/content/4864311386"},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/4864311386/version/2"}},"ancestors":[{"id":"2178416778","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2178416778","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjE3ODQxNjc3OA==","status":"current","title":"Bancard","macroRenderedOutput":{},"extensions":{"position":878},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2178416778/restriction/byOperation","history":"/rest/api/content/2178416778/history","body":"","version":"","descendants":"/rest/api/content/2178416778/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2178416778/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2178416778","tinyui":"/x/igDYgQ","editui":"/pages/resumedraft.action?draftId=2178416778","webui":"/spaces/BAN/overview","edituiv2":"/spaces/BAN/pages/edit-v2/2178416778"}},{"id":"4865785942","type":"page","subType":"live","subtype":"live","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/4865785942","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvNDg2NTc4NTk0Mg==","status":"current","title":"Friday Sessions","macroRenderedOutput":{},"extensions":{"position":709},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/4865785942/restriction/byOperation","history":"/rest/api/content/4865785942/history","body":"","version":"","descendants":"/rest/api/content/4865785942/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/4865785942/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/4865785942","tinyui":"/x/VgAGIgE","editui":"/spaces/BAN/pages/4865785942/Friday+Sessions","webui":"/spaces/BAN/pages/4865785942/Friday+Sessions","edituiv2":"/spaces/BAN/pages/4865785942/Friday+Sessions"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<h1 local-id=\"52163a723cdb\"><strong>\uD83D\uDC1B Random Bug Resolution</strong></h1><p local-id=\"25b8eb705ecc\"><strong>&iquest;Qu&eacute; es?</strong></p><p local-id=\"2f5a2a623fd0\">Una sesi&oacute;n pr&aacute;ctica donde investigamos y resolvemos en vivo un error real de Sentry o un ticket.</p><p local-id=\"203267e5e05b\"><strong>C&oacute;mo funciona:</strong></p><p local-id=\"d645ca9253fd\">Cada sesi&oacute;n se asigna aleatoriamente a una persona del equipo para que:</p><ul local-id=\"f8ecd9b3-fc73-4de3-8250-d56d7e45e679\"><li local-id=\"a7c4a576-cc37-450c-aaa1-04baf939a24f\"><p local-id=\"f3d21324f38c\">Elija un error real en Sentry o un Ticket</p></li><li local-id=\"b97bde72-4d08-4e06-893d-956962b8b46b\"><p local-id=\"ada3b238700f\">Traiga el contexto m&iacute;nimo necesario</p></li><li local-id=\"19397656-db74-43c8-8b54-2c8d14e6a769\"><p local-id=\"d31dd2c047f5\">Gu&iacute;e la investigaci&oacute;n durante la sesi&oacute;n</p></li></ul><p local-id=\"602e6edac6ac\"><strong>Durante la hora:</strong></p><ul local-id=\"c02e5bda-3963-425a-a976-7785d337800a\"><li local-id=\"c648821b-7e22-4e6d-bcd0-3f5501c91630\"><p local-id=\"221e2c2acd32\">Analizamos el stack trace</p></li><li local-id=\"b5d2d14b-e6c4-4b2b-868e-fc3d41b7cb70\"><p local-id=\"fc470e2c0fbc\">Proponemos hip&oacute;tesis</p></li><li local-id=\"427ac496-6bd3-4996-ab71-1a8e808c7b5a\"><p local-id=\"1dd052b666a8\">Buscamos en el c&oacute;digo</p></li><li local-id=\"932126eb-7695-4bc5-8228-db52f13488bc\"><p local-id=\"2c3f4f498a6e\">Discutimos posibles soluciones</p></li><li local-id=\"431c7034-75a5-43b7-826d-172c68dbcb15\"><p local-id=\"a879954c6890\">Si es viable, lo resolvemos en vivo o definimos el plan</p></li></ul><p local-id=\"4bf847d09c10\"><strong>Objetivo:</strong></p><p local-id=\"1d08fc1c9772\">Mejorar nuestras habilidades de debugging, compartir conocimiento del sistema y aprender c&oacute;mo otros investigan problemas. No buscamos &ldquo;encontrar al culpable&rdquo;, sino entender el sistema y mejorar nuestra capacidad de diagn&oacute;stico.</p><p local-id=\"8e88d0547fff\"><strong>Ejemplos:</strong></p><ul local-id=\"4c86f927-b722-4ffe-a8e8-d1d43d722862\"><li local-id=\"669be4a2-2434-4f1c-816b-027f318e3bf6\"><p local-id=\"572a919fa579\">Un NoMethodError intermitente en producci&oacute;n</p></li><li local-id=\"61ee45a0-73e6-4427-993d-0b49594b3295\"><p local-id=\"9b64715c783c\">Un job de Sidekiq que falla bajo ciertas condiciones</p></li><li local-id=\"de39756b-cb3c-47b6-89c0-a1ccd3e249d9\"><p local-id=\"0148b03c0bce\">Un error 500 dif&iacute;cil de reproducir</p></li></ul><h1 local-id=\"dc2db6455820\"><strong>\uD83D\uDDFA Team Knowledge Map</strong></h1><p local-id=\"21a193565d53\"><strong>&iquest;Qu&eacute; es?</strong></p><p local-id=\"1a66a5500627\">Una sesi&oacute;n para mapear y entender mejor una parte del sistema.</p><p local-id=\"fc4e2549a4d3\"><strong>C&oacute;mo funciona:</strong></p><p local-id=\"77cecc0d8f6e\">Cada sesi&oacute;n una persona presenta un &aacute;rea espec&iacute;fica del sistema:</p><ul local-id=\"8f7fb51b-2a80-4f67-950d-ba2ad6ff7deb\"><li local-id=\"b1a57619-7179-41e1-9640-4263ddb864b5\"><p local-id=\"8ba585878cef\">Qu&eacute; hace</p></li><li local-id=\"594823ae-3fba-4e4f-8124-9e97a92d97c5\"><p local-id=\"fb674f1d64d3\">D&oacute;nde vive en el repo</p></li><li local-id=\"335013d3-f14b-4e1e-a014-d27dad060d4d\"><p local-id=\"9f65dab48ecd\">Modelos principales</p></li><li local-id=\"28f0cee3-b3fd-4ce0-9e2d-98e4e5d8b1f8\"><p local-id=\"d5d2d8719678\">Endpoints clave</p></li><li local-id=\"1bdf4ade-2c4b-4369-be1f-b860195f7e45\"><p local-id=\"a124cb8ac5bc\">Integraciones externas</p></li><li local-id=\"d5c9ead1-cfa7-4947-ada5-5f5a9cae334e\"><p local-id=\"f4d08e1a5f1f\">Cosas que suelen romperse</p></li></ul><p local-id=\"580be4caec1a\"><strong>Objetivo:</strong></p><p local-id=\"1a07d29a8b80\">Reducir knowledge silos y aumentar la visi&oacute;n global del producto. Se espera que el resto del equipo haga preguntas y comparta experiencias relacionadas con ese m&oacute;dulo.</p><p local-id=\"56da7fcb01fa\"><strong>Ejemplos de temas:</strong></p><ul local-id=\"a5cccef2-0cf3-4fa1-aed4-2c9bc7cb66cd\"><li local-id=\"9aae9135-7acd-44e4-908f-325afa884d80\"><p local-id=\"326e8dd032bb\">Pago de Servicios</p></li><li local-id=\"fbc730fe-14bc-4be7-9a2d-87191c29e37a\"><p local-id=\"0260f252a0fd\">Pagos con QR (VentasQR)</p></li><li local-id=\"ea14b7eb-22a9-4fb7-9f9c-39eb32897669\"><p local-id=\"9a14d98a2995\">Pagos Agendados</p></li><li local-id=\"4a61f91d-8666-4f19-9732-d5208e92f557\"><p local-id=\"7ffbb83e3253\">Pagos con Link (TPago)</p></li><li local-id=\"0b565e6b-abc6-4aab-835e-9fa397a76bbf\"><p local-id=\"caf3e3c9f627\">Links de Suscripci&oacute;n</p></li><li local-id=\"42b224cc-9dfe-417a-98f4-1fd2ba73044b\"><p local-id=\"293a6e55b459\">&ldquo;Cards&rdquo; de billing/notification</p></li></ul><h1 local-id=\"352291831677\"><strong>\uD83C\uDFD7</strong> Rails Pattern</h1><p local-id=\"de003f79770a\"><strong>&iquest;Qu&eacute; es?</strong></p><p local-id=\"5d069cecc6c1\">Una sesi&oacute;n enfocada en conocer diferentes patrones cl&aacute;sicos y ver como los usamos en nuestro c&oacute;digo (si los usamos \uD83D\uDC40).</p><p local-id=\"089afcef8227\"><strong>C&oacute;mo funciona:</strong></p><p local-id=\"bda3e48ceb85\">Un responsable elige un patr&oacute;n o pr&aacute;ctica a desarrollar, da una introducci&oacute;n al equipo sobre el mismo y se analizan ejemplos reales del proyecto:</p><ul local-id=\"62f10631-979a-4e16-a5db-ab2b9d65978b\"><li local-id=\"0bce313d-0e19-479b-bf83-dbc3d9d4cde7\"><p local-id=\"81a60f1c5349\">C&oacute;mo lo estamos usando hoy</p></li><li local-id=\"7ab45af4-4170-44b3-bee1-8a447485fb7b\"><p local-id=\"62f08ef2f209\">Qu&eacute; est&aacute; bien</p></li><li local-id=\"a99a051a-c36a-4878-a68b-50ddd6326659\"><p local-id=\"364b1c469d7c\">Qu&eacute; podemos mejorar</p></li><li local-id=\"b908a39a-0de9-4a57-a696-3acb87b3cfd1\"><p local-id=\"e3f0aee52a48\">Qu&eacute; deber&iacute;amos estandarizar</p></li></ul><p local-id=\"b0c5e800beb6\"><strong>Objetivo:</strong></p><p local-id=\"61eb70c68cdb\">Alinear criterios t&eacute;cnicos y mejorar consistencia.</p><p local-id=\"9b47689417bd\"><strong>Ejemplos:</strong></p><ul local-id=\"dc945a46-1b41-4481-9734-b73cbc4dac95\"><li local-id=\"825a2368-35d4-4a25-ad75-79828e69ee77\"><p local-id=\"ea3ab2278879\">Service Objects: cu&aacute;ndo usar y cu&aacute;ndo no</p></li><li local-id=\"db168480-bb05-4713-8576-a100982335b1\"><p local-id=\"17cfef92c71b\">Uso de callbacks</p></li><li local-id=\"e44d44ca-1098-4d40-b411-461789f0d3e0\"><p local-id=\"4b3239030273\">Policies</p></li><li local-id=\"b4bcc736-b02b-4b50-8f48-9174f0714529\"><p local-id=\"7cc72184a88a\">Background jobs e idempotencia</p></li><li local-id=\"6f0fab32-4c50-4d15-94f7-24567a54baae\"><p local-id=\"df46345dc500\">Transaction boundaries</p></li><li local-id=\"a265f74a-0e84-421d-8207-2117e493d75b\"><p local-id=\"aef7f2c93646\">Validaciones complejas</p></li></ul><h1 local-id=\"f3d00d2f21ce\"><strong>\uD83D\uDD27 Live Refactor Session</strong></h1><p local-id=\"fae1837d18ec\"><strong>&iquest;Qu&eacute; es?</strong></p><p local-id=\"d5e0f3e1065c\">Refactor en vivo de c&oacute;digo real del proyecto.</p><p local-id=\"0be374e887a0\"><strong>C&oacute;mo funciona:</strong></p><p local-id=\"39c19bbd429b\">Un miembro del equipo trae un fragmento de c&oacute;digo peque&ntilde;o y:</p><ul local-id=\"d5869a30-ce7e-4e1f-a85d-2f281f68792d\"><li local-id=\"f1224a4e-b49d-4129-a129-8b87e20b5a50\"><p local-id=\"6980f8ae873d\">Se analiza en conjunto</p></li><li local-id=\"0310b668-7a25-44fa-aa63-9ac4c0a0ffa7\"><p local-id=\"cf8cf647bb27\">Se proponen mejoras</p></li><li local-id=\"15a22809-34d5-49a6-b658-a8c457a92ccb\"><p local-id=\"78c76dde48c4\">Se exploran distintas soluciones</p></li></ul><p local-id=\"ec886f9984de\">No se trata de criticar, sino de pensar colectivamente.</p><p local-id=\"846a37324d53\"><strong>Objetivo:</strong></p><p local-id=\"a5b01ca893c7\">Entrenar dise&ntilde;o, legibilidad y pensamiento cr&iacute;tico.</p><p local-id=\"9e7890702e2a\"><strong>Ejemplos:</strong></p><ul local-id=\"37b81384-c5e5-48ac-82cc-4ae3b2adc613\"><li local-id=\"60178ec1-308e-4d78-9a75-9c6b39ff6201\"><p local-id=\"7746a83e9427\">Un controller/resource con demasiada l&oacute;gica</p></li><li local-id=\"7e851b83-0706-46d5-9857-b3398ea15494\"><p local-id=\"b19b9d2047c4\">Un m&eacute;todo largo con muchos if</p></li><li local-id=\"0f252298-a29e-4811-a063-c1f4688f0aa6\"><p local-id=\"424172b7cbef\">Una spec repetitiva</p></li><li local-id=\"ac2b7a43-48b4-46e2-b8b5-65e60537921f\"><p local-id=\"cffdc23aae7a\">Un modelo con demasiadas responsabilidades</p></li><li local-id=\"b16a5250-6b2a-46ba-b474-13a0fe9fb2af\"><p local-id=\"f96fa13e9e03\">Un modulo Business con responsabilidades poco claras</p></li></ul><h1 local-id=\"750ea59e3c10\"><strong>☕ Architecture Coffee</strong></h1><p local-id=\"45138a66f28a\"><strong>&iquest;Qu&eacute; es?</strong></p><p local-id=\"6990334ee81c\">Espacio abierto de discusi&oacute;n t&eacute;cnica sobre decisiones arquitect&oacute;nicas.</p><p local-id=\"1109840b3401\"><strong>C&oacute;mo funciona:</strong></p><p local-id=\"1d51066c69f0\">Se plantea una pregunta o problema y se abre debate guiado.</p><p local-id=\"5c66957aa298\">No necesariamente se toma una decisi&oacute;n formal, el objetivo es explorar perspectivas.</p><p local-id=\"d423efdcbd3c\"><strong>Objetivo:</strong></p><p local-id=\"2f425a92d6a6\">Pensar en el largo plazo y mejorar criterios de dise&ntilde;o.</p><p local-id=\"6ba5a4c8c848\"><strong>Ejemplos:</strong></p><ul local-id=\"a0cdd7a3-4795-4823-8a4f-bd1f5f9cf078\"><li local-id=\"2dadc98a-294e-4f82-831d-e097aede5693\"><p local-id=\"23bea580c77d\">&iquest;C&oacute;mo modularizamos mejor un sistema?</p></li><li local-id=\"7f9a027f-e7b0-4863-943e-c5b07b873c2a\"><p local-id=\"b049c47441da\">&iquest;D&oacute;nde estamos acumulando deuda t&eacute;cnica?</p></li><li local-id=\"9cddb9b4-f59f-46d7-b0d8-db462254bfae\"><p local-id=\"e6c65d75aa9c\">&iquest;C&oacute;mo manejamos integraciones externas?</p></li><li local-id=\"ba159052-a3e0-4575-8f39-f125d7680fed\"><p local-id=\"22e2915b6065\">&iquest;Qu&eacute; l&iacute;mites deber&iacute;a tener cada dominio?</p></li></ul><h1 local-id=\"30433114c24c\"><strong>\uD83D\uDEE0 Tool Swap</strong></h1><p local-id=\"c84c52771a7d\"><strong>&iquest;Qu&eacute; es?</strong></p><p local-id=\"21d4b8fde80f\">Un espacio para compartir herramientas, workflows o trucos &uacute;tiles. Puede durar entre 10 y 20 minutos, manteni&eacute;ndolo liviano y pr&aacute;ctico.</p><p local-id=\"b6b892174a75\"><strong>C&oacute;mo funciona:</strong></p><p local-id=\"e5d0df2fc487\">Una persona muestra algo que usa y que le mejora la productividad.</p><p local-id=\"686a6c7e6321\"><strong>Objetivo:</strong></p><p local-id=\"03ad96f2af6b\">Elevar la productividad colectiva compartiendo conocimiento pr&aacute;ctico.</p><p local-id=\"923ac1b54eec\"><strong>Ejemplos:</strong></p><ul local-id=\"dda3a2af-94d0-4f2b-9b2c-33d7cb1af774\"><li local-id=\"89fd0ff4-fd7b-4945-9067-aad1980c2d3b\"><p local-id=\"114410faf802\">Shortcuts de VSCode o Cursor</p></li><li local-id=\"91890e83-04ad-49bc-a463-3ffc0de3180c\"><p local-id=\"d5cec8e93453\">Git aliases</p></li><li local-id=\"c3f84cba-ae8a-48e9-a6bd-dcba5a739ab9\"><p local-id=\"66ecfe51c22d\">C&oacute;mo usar Rack Mini Profiler</p></li><li local-id=\"268398cf-eb0d-4655-80e0-644acecbf2d9\"><p local-id=\"1c4f3f192617\">Feature flags</p></li><li local-id=\"95568e55-6100-4da6-8a6e-f255dbbf30cb\"><p local-id=\"88ef52f80c05\">Herramientas para debugging</p></li><li local-id=\"9a5f9420-cf55-498d-b8d4-993ee2d816cd\"><p local-id=\"357d16fd3da1\">Configuraci&oacute;n de entorno de desarrollo</p></li></ul><h1 local-id=\"f1b1e165ed82\"><strong>\uD83C\uDFAD Tech Debate</strong></h1><p local-id=\"91f31966b558\"><strong>&iquest;Qu&eacute; es?</strong></p><p local-id=\"e2862b7452b8\">Debates t&eacute;cnicos con roles asignados.</p><p local-id=\"5e5abb4da887\"><strong>C&oacute;mo funciona:</strong></p><p local-id=\"07b6d77844ea\">Se elige un tema pol&eacute;mico.</p><ul local-id=\"ddf7b88c-67c4-4321-bb0f-b1f687cced7a\"><li local-id=\"775a9484-61e1-4667-9c7e-3b631e7e5f5b\"><p local-id=\"40183e730b64\">Una persona defiende una postura</p></li><li local-id=\"1f53f8a9-94cf-4c58-875f-4f301cd1e35a\"><p local-id=\"1ecb710f53cd\">Otra persona defiende la opuesta</p></li><li local-id=\"84ad1c24-7992-4255-8dff-8454da880fce\"><p local-id=\"5f4345de5b7f\">El resto participa con preguntas y opiniones</p></li></ul><p local-id=\"a819d689e012\"><strong>Objetivo:</strong></p><p local-id=\"853cd7186307\">Explorar trade-offs y aprender a argumentar decisiones t&eacute;cnicas. Se prioriza el respeto y la argumentaci&oacute;n t&eacute;cnica por sobre &ldquo;ganar&rdquo; la discusi&oacute;n.</p><p local-id=\"3ba94b4109b6\"><strong>Ejemplos:</strong></p><ul local-id=\"1e01eaf8-d794-4544-b7b2-089ab1603a31\"><li local-id=\"89997b59-b54d-4147-bd24-37b14c15a3df\"><p local-id=\"6fac485c1288\">Callbacks vs l&oacute;gica expl&iacute;cita</p></li><li local-id=\"9208f1aa-9ab7-4ee1-bf6a-db44949bc107\"><p local-id=\"66c4dce4b82c\">Fat models vs Service layer</p></li><li local-id=\"3cbb83d6-10f6-4250-9353-521904a3ae30\"><p local-id=\"dd3004f92ce9\">Tests m&aacute;s unitarios vs m&aacute;s integraci&oacute;n</p></li><li local-id=\"11587167-f6f2-4b37-8295-4d7957a0c4cc\"><p local-id=\"cddd1f69c588\">Rspec vs Minitest</p></li></ul><h1 local-id=\"23fe7de452e8\"><strong>\uD83C\uDFA4 Guest Friday</strong></h1><p local-id=\"ef5102718a9e\"><strong>&iquest;Qu&eacute; es?</strong></p><p local-id=\"534760f5d1e8\">Invitamos developers Rails de otros proyectos o equipos para intercambiar experiencias.</p><p local-id=\"9551d36f896c\"><strong>C&oacute;mo funciona:</strong></p><p local-id=\"f81eb06a7de4\">Un invitado externo comparte:</p><ul local-id=\"460085be-f37e-44f0-9388-ceeb79f46666\"><li local-id=\"cb941fde-79ae-44fc-aba3-940c8468c5f6\"><p local-id=\"40d63874ddc8\">C&oacute;mo trabajan en su proyecto</p></li><li local-id=\"8ac8ac6f-fbe2-4f7b-9555-77d57b22c03f\"><p local-id=\"a57a3b73e504\">Decisiones arquitect&oacute;nicas</p></li><li local-id=\"d5f761d3-5eea-4e84-bf58-39cfa678397b\"><p local-id=\"a97cf4ec8332\">Problemas que resolvieron</p></li><li local-id=\"7d2bed31-6951-473b-955d-5d7177a994c8\"><p local-id=\"99dae9618c56\">Lecciones aprendidas</p></li></ul><p local-id=\"2e69c92fe463\">Luego abrimos conversaci&oacute;n.</p><p local-id=\"9cab2a8756dd\"><strong>Objetivo:</strong></p><p local-id=\"c1b51a1e16bc\">Salir de nuestra burbuja y enriquecer perspectiva t&eacute;cnica.</p><h1 local-id=\"e6a3c1a56337\"><strong>\uD83C\uDFAE Friday Challenge</strong></h1><p local-id=\"ef8360132b94\"><strong>&iquest;Qu&eacute; es?</strong></p><p local-id=\"a788262ccd3c\">Desaf&iacute;os interactivos y preguntas relacionadas con negocio, producto o conocimiento t&eacute;cnico del sistema.</p><p local-id=\"ebc0c28eea86\"><strong>C&oacute;mo funciona:</strong></p><p local-id=\"a5d47e8a53bb\">Se presentan preguntas, escenarios o peque&ntilde;os retos y el equipo responde en vivo mediante chat, votaci&oacute;n o discusi&oacute;n abierta.</p><p local-id=\"50474b55224b\">Puede ser individual o en equipos peque&ntilde;os.</p><p local-id=\"435aee9ab848\"><strong>Objetivo:</strong></p><ul local-id=\"aa68fb2b-611d-449d-849e-7ca5d6ddc9b4\"><li local-id=\"d070f430-b08b-4421-874d-7de3ae8fba8f\"><p local-id=\"f2ffc1ed375a\">Entender mejor el negocio</p></li><li local-id=\"f3258a71-127f-410e-912d-d7b30d426d5c\"><p local-id=\"98e9478cef20\">Detectar gaps de conocimiento</p></li><li local-id=\"52e7273f-ba33-4bee-8a53-b1eb1fb8c3aa\"><p local-id=\"6743495000fe\">Fomentar participaci&oacute;n activa</p></li><li local-id=\"31c7c9d4-3b30-4d1c-b58c-b7ee4c099c5d\"><p local-id=\"d08b0b1fa378\">Romper la rutina con una din&aacute;mica m&aacute;s l&uacute;dica</p></li></ul><p local-id=\"014b74f91276\"><strong>Ejemplos:</strong></p><ul local-id=\"9c8cdbd6-ab50-4cc8-9fd4-387e53839cd4\"><li local-id=\"ca00fbdf-2374-4705-9563-85a5ce835c5f\"><p local-id=\"412de6e5ad0b\">Ni idea, hay de todo pero estoy con las ultimas energ&iacute;as del d&iacute;a</p></li></ul><h1 local-id=\"b7d28a5ba0c0\"><strong>\uD83D\uDCF0 Tech News</strong></h1><p local-id=\"82b51293b8b6\"><strong>&iquest;Qu&eacute; es?</strong></p><p local-id=\"96ba945c1931\">Espacio para compartir novedades del ecosistema tech o Ruby/Rails.</p><p local-id=\"75ff4b6821e9\"><strong>C&oacute;mo funciona:</strong></p><p local-id=\"4da24e3c1904\">Alguien trae una noticia relevante no relacionada con el proyecto y la comenta brevemente. Idealmente se comparte previamente el art&iacute;culo o recurso en Slack para que el equipo pueda revisarlo antes de la sesi&oacute;n.</p><p local-id=\"074d24563b5f\"><strong>Objetivo:</strong></p><p local-id=\"fab7550a4a78\">Mantenernos actualizados sin necesidad de una charla formal.</p><p local-id=\"27d3f5e32ecc\"><strong>Ejemplos:</strong></p><ul local-id=\"c8989741-251c-4533-b1ef-d7e051ef64f2\"><li local-id=\"aec5644b-02a2-460d-86ba-977068c1d2b3\"><p local-id=\"efb1024b45a2\">Novedades de Rails 8</p></li><li local-id=\"b3884437-f98b-4e22-ab20-302bf3201adb\"><p local-id=\"5b37b1506921\">Cambios en gems que usamos</p></li><li local-id=\"4aef6a0b-c22e-403f-8fa6-39766be81b00\"><p local-id=\"6f9027c01f2b\">Tendencias en testing</p></li><li local-id=\"a53c15be-3009-486b-a67e-00badd4b20fe\"><p local-id=\"2a0140c7a85c\">Nuevas pr&aacute;cticas de seguridad</p></li><li local-id=\"4a24d487-574e-46ce-9c39-193a2dc0f023\"><p local-id=\"ab0605ffdde5\">Art&iacute;culos t&eacute;cnicos interesantes</p></li></ul>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/4864311386"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":455},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/4864311386/child","restrictions":"/rest/api/content/4864311386/restriction/byOperation","history":"/rest/api/content/4864311386/history","draftVersion":"","descendants":"/rest/api/content/4864311386/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/spaces/BAN/pages/4864311386/Friday+Sessions+-+Din+micas","webui":"/spaces/BAN/pages/4864311386/Friday+Sessions+-+Din+micas","edituiv2":"/spaces/BAN/pages/4864311386/Friday+Sessions+-+Din+micas","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/4864311386","tinyui":"/x/WoDvIQE","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}