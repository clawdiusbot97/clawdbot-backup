pi/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2760147005/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2760147005","tinyui":"/x/PYCEp","editui":"/pages/resumedraft.action?draftId=2760147005","webui":"/spaces/BAN/pages/2760147005/Iniciativas+en+Curso","edituiv2":"/spaces/BAN/pages/edit-v2/2760147005"}},{"id":"2685632547","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2685632547","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjY4NTYzMjU0Nw==","status":"current","title":"Vulnerabilidades","macroRenderedOutput":{},"extensions":{"position":10593389},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2685632547/restriction/byOperation","history":"/rest/api/content/2685632547/history","body":"","version":"","descendants":"/rest/api/content/2685632547/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2685632547/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2685632547","tinyui":"/x/I4ATo","editui":"/pages/resumedraft.action?draftId=2685632547","webui":"/spaces/BAN/pages/2685632547/Vulnerabilidades","edituiv2":"/spaces/BAN/pages/edit-v2/2685632547"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<h1>Punto 1</h1><p>Proyecto: TPago portal</p><p>Hay problemas en la navegacion a traves del sitio. Por ejemplo:</p><ul><li><p>/home/your_activity</p></li><li><p>/home/your_cards</p></li><li><p>/home/your_subscriptions</p></li><li><p>/home/your_profile</p></li></ul><p>Llevan a p&aacute;ginas que se ven asi:</p><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"1398\" ac:original-width=\"2560\"><ri:attachment ri:filename=\"image-20230817-054748.png\" ri:version-at-save=\"1\" /></ac:image><p>Las mismas no estan bien resueltas, ya que no muestran el layout general de la aplicacion. Solo muestran el turbo frame respectivo.</p><p>Sugiero poder vincular dichas rutas a sus respectivas vistas en la pantalla principal, de modo que esas rutas puedan ser colocadas en el navegador y lleve a la pantalla correcta.</p><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"1399\" ac:original-width=\"2560\"><ri:attachment ri:filename=\"image-20230817-054937.png\" ri:version-at-save=\"1\" /></ac:image><h1>Punto 2</h1><p>Proyecto TPago portal</p><p>Sesiones de usuario son almacenadas en cookies de navegador. <a href=\"https://api.rubyonrails.org/classes/ActionDispatch/Session/CookieStore.html\" data-card-appearance=\"inline\">https://api.rubyonrails.org/classes/ActionDispatch/Session/CookieStore.html</a>. Es la estrategia por default que traen las aplicaciones hechas en Rails ya que otorga varios beneficios. Principalmente performance. </p><p>Esto genera que no hay control del lado del servidor acerca de sesiones expiradas/cerradas.</p><p>Ejemplos de problemas generados por esta estrategia de sesiones:</p><ul><li><p>Una cookie vieja de una sesion &ldquo;cerrada&rdquo; se puede reutilizar, y la sesion se vuelve a activar.</p><ul><li><p>Se loguea un usuario. Se setea una cookie <code>_bancard_tpago_portal_session</code> cuyo valor es una sesion v&aacute;lida. </p></li><li><p>El usuario cierra sesion. Se sobreescribe el valor de la cookie <code>_bancard_tpago_portal_session</code> borrando el user_id, haciendo que la sesion quede cerrada en ese navegador.</p></li><li><p>Se restaura manualmente el valor de la cookie obtenido en el paso 1 luego del login. La sesion vuelve a estar activa.</p></li></ul></li><li><p>Requests paralelas.</p><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"1080\" ac:original-width=\"1920\" ac:width=\"680\"><ri:attachment ri:filename=\"Issue session CookieStore.mp4\" ri:version-at-save=\"2\" /></ac:image><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"718\" ac:original-width=\"1055\"><ri:attachment ri:filename=\"Issue session CookieStore.jpg\" ri:version-at-save=\"1\" /></ac:image><p /><p /></li></ul>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/2682355775"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":499143459},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2682355775/child","restrictions":"/rest/api/content/2682355775/restriction/byOperation","history":"/rest/api/content/2682355775/history","draftVersion":"","descendants":"/rest/api/content/2682355775/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=2682355775","webui":"/spaces/BAN/pages/2682355775/Mejoras+encontradas","edituiv2":"/spaces/BAN/pages/edit-v2/2682355775","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/2682355775","tinyui":"/x/P4Dhnw","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}