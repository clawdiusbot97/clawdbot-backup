est/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2760147005/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2760147005","tinyui":"/x/PYCEp","editui":"/pages/resumedraft.action?draftId=2760147005","webui":"/spaces/BAN/pages/2760147005/Iniciativas+en+Curso","edituiv2":"/spaces/BAN/pages/edit-v2/2760147005"}},{"id":"3233218577","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/3233218577","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMzIzMzIxODU3Nw==","status":"current","title":"VPos","macroRenderedOutput":{},"extensions":{"position":10592077},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/3233218577/restriction/byOperation","history":"/rest/api/content/3233218577/history","body":"","version":"","descendants":"/rest/api/content/3233218577/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3233218577/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/3233218577","tinyui":"/x/EQC3w","editui":"/pages/resumedraft.action?draftId=3233218577","webui":"/spaces/BAN/pages/3233218577/VPos","edituiv2":"/spaces/BAN/pages/edit-v2/3233218577"}},{"id":"3067052052","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/3067052052","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMzA2NzA1MjA1Mg==","status":"current","title":"Preautorizaciones en vpos","macroRenderedOutput":{},"extensions":{"position":179688196},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/3067052052/restriction/byOperation","history":"/rest/api/content/3067052052/history","body":"","version":"","descendants":"/rest/api/content/3067052052/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3067052052/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/3067052052","tinyui":"/x/FIDPtg","editui":"/pages/resumedraft.action?draftId=3067052052","webui":"/spaces/BAN/pages/3067052052/Preautorizaciones+en+vpos","edituiv2":"/spaces/BAN/pages/edit-v2/3067052052"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<h1>Mejoras</h1><ul><li><p><span style=\"color: rgb(171,245,209);\"><del>Agregar tests de RSpec.</del></span></p></li><li><p><span style=\"color: rgb(171,245,209);\"><del>Revisar messages de todas las operaciones involucradas en PCI preauth.</del></span></p></li><li><p><span style=\"color: rgb(171,245,209);\"><del>Revisar pay_pci_encrypted_buy (NO preauth) que haya mantenido mismo comportamiento.</del></span></p></li><li><p><span style=\"color: rgb(171,245,209);\"><del>Ver manera de validar que el comercio y sucursal en la confirmaci&oacute;n pertenezcan a la preauth a ser confirmada. Ver si hay un /refund que hace algo similar</del></span></p></li><li><p><span style=\"color: rgb(171,245,209);\"><del>checkear campos response y response_details de la respuesta del endpoint de confirmacion. Se podr&iacute;a hacer similar al endpoint de la creaci&oacute;n? </del></span></p></li><li><p><span style=\"color: rgb(171,245,209);\"><del>corregir typo fu&eacute;</del></span></p></li><li><p><span style=\"color: rgb(171,245,209);\"><del>enviar string vacio al RPG cuando se hace una preauth sin cvv</del></span></p></li><li><p><span style=\"color: rgb(171,245,209);\"><del>revisar token de respuesta en </del></span><code>pay_pci_buy</code><span style=\"color: rgb(171,245,209);\">, </span><code>pay_pci_encrypted_buy</code><span style=\"color: rgb(171,245,209);\"> <del>y si hay alguna operaci&oacute;n mas que pueda haber sido afectada:</del></span></p><ul><li><p><span style=\"color: rgb(171,245,209);\"><del>pay_pci_encrypted_buy: volver a como era antes. Formato</del> </span><code>&quot;confirm#{shop_process_id}&quot; + &quot;#{amount_in_gs_for_token}#{currency_for_token}&rdquo;</code><span style=\"color: rgb(171,245,209);\"><del> y MD5.</del></span></p></li><li><p><span style=\"color: rgb(171,245,209);\"><del>confirm_pci_preauthorization: devolver mismo token que la request.</del></span></p></li></ul></li><li><p>Con ruby-upgrade</p><ul><li><p>logger de rpg. Vpos ya tiene integrado bancard-loggers?</p></li><li><p>revisar logs de puma de ruby-upgrade</p></li></ul></li></ul><h1>Deploy</h1><ul><li><p>Correr migraci&oacute;n</p></li><li><p>Hacer inserts:</p><ul><li><p>INSERT INTO service_operations(name) VALUES ('confirm_pci_preauthorization')</p></li><li><p>INSERT INTO application_permissions(application_id, service_operation_id) VALUES (_, _)</p></li></ul></li><li><p>Prestar atenci&oacute;n a <code>update!</code> / <code>update_attributes!</code>. En caso de deployar junto a ruby-upgrade, se debe usar <code>update!</code>. En caso de deployar unicamente la rama feature/pci-preauthorizations se debe usar <code>update_attributes!</code>. <a href=\"https://github.com/bancardsa/bancard-vpos-service/commit/5a99f4b091d89afc2c186a7ad586d501bb01ecb4\" data-card-appearance=\"inline\">https://github.com/bancardsa/bancard-vpos-service/commit/5a99f4b091d89afc2c186a7ad586d501bb01ecb4</a> </p></li><li><p>Agregar archivos de RPG middleware a bancard-configurations en ambiente prod, etc.</p></li></ul><p />","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/3184001078"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":1009},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3184001078/child","restrictions":"/rest/api/content/3184001078/restriction/byOperation","history":"/rest/api/content/3184001078/history","draftVersion":"","descendants":"/rest/api/content/3184001078/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=3184001078","webui":"/spaces/BAN/pages/3184001078/Pendientes+PCI+preauth","edituiv2":"/spaces/BAN/pages/edit-v2/3184001078","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/3184001078","tinyui":"/x/NgDIvQ","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}