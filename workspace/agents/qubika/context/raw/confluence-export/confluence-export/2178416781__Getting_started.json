{"id":"2178416781","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2178416781","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjE3ODQxNjc4MQ==","status":"archived","title":"Getting started","version":{"by":{"type":"known","accountId":"5ad8f697d8b95a2b34f27719","accountType":"atlassian","email":"","publicName":"Pablo Garin","profilePicture":{"path":"/wiki/aa-avatar/5ad8f697d8b95a2b34f27719","width":48,"height":48,"isDefault":false},"displayName":"Pablo Garin","isExternalCollaborator":false,"isGuest":false,"locale":"en_US","accountStatus":"active","_expandable":{"operations":"","personalSpace":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/user?accountId=5ad8f697d8b95a2b34f27719"}},"when":"2022-04-19T17:55:08.590Z","friendlyWhen":"Apr 19, 2022","message":"","number":1,"minorEdit":false,"syncRev":"0.Pq-XxeoYutsnJkylWEb42g.0","syncRevSource":"synchrony-ack","confRev":"confluence$content$2178416781.4","contentTypeModified":false,"_expandable":{"collaborators":"","content":"/rest/api/content/2178416781?status=archived"},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2178416781/version/1"}},"ancestors":[],"macroRenderedOutput":{},"body":{"storage":{"value":"<ac:layout><ac:layout-section ac:type=\"two_right_sidebar\"><ac:layout-cell><ac:structured-macro ac:name=\"tip\"><ac:rich-text-body><p><span>Here are some tips to get you started. You can edit this page to see how it works!</span></p></ac:rich-text-body></ac:structured-macro><h2>1. Create a page</h2><ul><li>Click &quot;Create&quot; and select &quot;Blank Page&quot; to create your first page.</li><li>New pages are created as children of the page you are currently viewing.</li></ul><h2>2. Add to your page</h2><ul><li>Click &quot;Edit&quot; to enter the Confluence editor and use the page layouts feature to structure your content using sections and columns.</li><li>Use headings to format your text and drag and drop images into your page to provide visual interest.</li><li>Click &quot;Insert&quot; and select &quot;Other Macros&quot; to add macros for navigation, special formatting and other media.</li></ul></ac:layout-cell><ac:layout-cell><ac:structured-macro ac:name=\"panel\"><ac:rich-text-body><p><strong>On this page:</strong></p><p><ac:structured-macro ac:name=\"toc\" /></p></ac:rich-text-body></ac:structured-macro></ac:layout-cell></ac:layout-section><ac:layout-section ac:type=\"single\"><ac:layout-cell><h2>3. Organise your pages</h2><p>Here are some tips for organising your content.</p><ul><li><h4>Change the page order</h4></li></ul><p style=\"margin-left: 60.0px;\">The sidebar on the left displays your pages in a hierarchy. If you have Space Administrator permissions you can click &quot;Space Tools&quot; &gt; &quot;Reorder Pages&quot; to move pages around.</p><ul><li><h4>Add labels</h4></li></ul><p style=\"margin-left: 60.0px;\">Labels help keep pages organised and make it easier for you to find the information you need. Click &quot;Labels&quot; at the bottom of a page to add or edit. The &quot;Related pages&quot; section on this page uses labels too!</p><ul><li><h4>Make templates</h4></li></ul><p style=\"margin-left: 60.0px;\">Standardise and speed up the page creation process with templates. You can create and format a template with page layouts, standard headings and instructional text for hints and guidelines. Check out our sample page on\n                &quot;<ac:link><ri:page ri:content-title=\"Making a template\" /></ac:link>&quot;\n            </p></ac:layout-cell></ac:layout-section><ac:layout-section ac:type=\"single\"><ac:layout-cell><p><strong>Related pages</strong></p><p><ac:structured-macro ac:name=\"contentbylabel\"><ac:parameter ac:name=\"spaces\">BAN</ac:parameter><ac:parameter ac:name=\"showLabels\">false</ac:parameter><ac:parameter ac:name=\"sort\">title</ac:parameter><ac:parameter ac:name=\"labels\">documentation-space-sample</ac:parameter><ac:parameter ac:name=\"showSpace\">false</ac:parameter><ac:parameter ac:name=\"type\">page</ac:parameter></ac:structured-macro></p></ac:layout-cell></ac:layout-section></ac:layout>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/2178416781?status=archived"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":620},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2178416781/child","restrictions":"/rest/api/content/2178416781/restriction/byOperation","history":"/rest/api/content/2178416781/history","draftVersion":"","descendants":"/rest/api/content/2178416781/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=2178416781","webui":"/spaces/BAN/pages/2178416781/Getting+started","edituiv2":"/spaces/BAN/pages/edit-v2/2178416781","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/2178416781?status=archived","tinyui":"/x/jQDYgQ","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}