<p><time datetime=\"2024-05-27\" /> </p><p>-&gt;</p><p><time datetime=\"2024-07-01\" /> </p></td><td><p>60</p></td></tr><tr><td><p>Tareas audit - QA</p></td><td><p><time datetime=\"2024-05-27\" /> </p><p>-&gt;</p><p><time datetime=\"2024-07-01\" /> </p></td><td><p>30</p></td></tr><tr><td><p>Tareas s4 - Dev </p></td><td><p><time datetime=\"2024-05-27\" /> </p><p>-&gt;</p><p><time datetime=\"2024-07-01\" /> </p></td><td><p>60</p></td></tr><tr><td><p>Tareas s4 - QA</p></td><td><p><time datetime=\"2024-05-27\" /> </p><p>-&gt;</p><p><time datetime=\"2024-07-01\" /> </p></td><td><p>30</p></td></tr><tr><td><p>Tareas vpos - Dev + QA (rebase, deploy, pruebas y bugfixing y preparaci&oacute;n para staging y prod, todo en la base sin cluster)</p></td><td><p><time datetime=\"2024-05-27\" /> </p><p>-&gt;</p><p><time datetime=\"2024-07-15\" /> </p></td><td><p>120</p></td></tr><tr><td><p>Tareas 3DSec - 40</p></td><td><p><time datetime=\"2024-05-27\" /> </p><p>-&gt;</p><p><time datetime=\"2024-07-15\" /> </p></td><td><p>40</p></td></tr><tr><td data-highlight-colour=\"#eae6ff\"><p><strong>Total Desarrollo + Gesti&oacute;n 10% (Para facturaci&oacute;n)</strong></p></td><td data-highlight-colour=\"#eae6ff\"><p /></td><td data-highlight-colour=\"#eae6ff\"><p><strong>450</strong></p></td></tr></tbody></table>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/3102801924"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":51783379},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3102801924/child","restrictions":"/rest/api/content/3102801924/restriction/byOperation","history":"/rest/api/content/3102801924/history","draftVersion":"","descendants":"/rest/api/content/3102801924/descendant","space":"/rest/