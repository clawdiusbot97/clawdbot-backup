dant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2763620355/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2763620355","tinyui":"/x/A4C5p","editui":"/pages/resumedraft.action?draftId=2763620355","webui":"/spaces/BAN/pages/2763620355/Tentative+Initiatives","edituiv2":"/spaces/BAN/pages/edit-v2/2763620355"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<ac:structured-macro ac:name=\"info\" ac:schema-version=\"1\" ac:local-id=\"0ef414d6-be97-42d0-929d-444b4656ee15\" ac:macro-id=\"00354c09-cabc-4fb3-a2f8-553f36ad38ec\"><ac:rich-text-body><p local-id=\"57cba722-0e7a-4e75-9815-3b07f02e1132\">Este documento representa el tasking y estimaci&oacute;n para Kount 360, a cargo de <ac:link><ri:user ri:account-id=\"712020:bd6be9b3-2ff0-412b-8fb1-57e9e188f6cf\" ri:local-id=\"2c7df34d-30f9-4c85-b8e0-5e36008b5130\" /></ac:link> y <ac:link><ri:user ri:account-id=\"632e0ea3409249995ee8d951\" ri:local-id=\"e5678d41-b932-4f87-b6e2-809c461e47e3\" /></ac:link>.</p><p local-id=\"fb834cf5-d553-4aae-9fd8-45d60d36a325\">Las horas estimadas son: 32h ~ 4d</p><p local-id=\"b81c1b80-d74e-4f6c-a5b9-4aead114bcb0\">Fecha de Inicio: A definir</p><p local-id=\"70795c5e-6faf-40fc-a13f-280b5078c3f3\">Fecha de Entrega: A definir</p></ac:rich-text-body></ac:structured-macro><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"d127e8c3-3fed-4af2-bc1b-c09b7117def2\"><colgroup><col style=\"width: 539.0px;\" /><col style=\"width: 221.0px;\" /></colgroup><tbody><tr ac:local-id=\"260662d0-6a71-46fa-85a4-8c7c62610adf\"><th ac:local-id=\"132e3390-ad7a-434f-8f06-c091cf68b84d\"><p local-id=\"8b69b2a3-c83f-4a16-aab4-4a2fb2d27859\"><strong>Tarea</strong></p></th><th ac:local-id=\"bed87d20-e7db-4b76-a816-52d1e6205d26\"><p local-id=\"7c7204a6-1c3d-4a59-a96f-29c03cc2bd77\" style=\"text-align: center;\"><strong>Estimaci&oacute;n (hs)</strong></p></th></tr><tr ac:local-id=\"999e8b0f-5d26-4ae1-bc5f-21a722784f62\"><td ac:local-id=\"1e34b99a-39a4-4326-b0b2-1aa6a17a72f6\"><p local-id=\"ec20c904-4b2b-4fba-b2ad-7aed5c438ef7\">PLS - Business - Kount Login con ExternalServices</p></td><td ac:local-id=\"a846b89c-9efd-47a8-bb8d-d375496aaaea\"><p local-id=\"ecafa807-1eaa-4cc6-b802-3d704169535d\">4h</p></td></tr><tr ac:local-id=\"64085c3e-ce82-4faa-86ee-c30a7dfadc0a\"><td ac:local-id=\"3249ce5a-d9f7-4798-b737-b39005afb335\"><p local-id=\"52b8fea8-56bf-4e23-b29f-76064c3e4ae0\">PLS - Business - Kount evaluate_order con ExternalServices</p></td><td ac:local-id=\"1c015963-3075-4f83-968f-375b827641b0\"><p local-id=\"27347015-f938-4de8-be6a-41a5beb9a648\">4h</p></td></tr><tr ac:local-id=\"b804d738-d736-4c39-a97c-506d5bc5ef2e\"><td ac:local-id=\"fbc67ced-d096-406a-b50d-4463230dcb26\"><p local-id=\"127cc156-c671-40f1-99cd-6a9eb6ec70b3\">PLS - Business - Kount update_order con ExternalServices</p></td><td ac:local-id=\"e2bc7bd6-717d-49ce-ba72-d653734ee29a\"><p local-id=\"25fc3934-b4d5-439e-81e5-c12dd310430c\">4h</p></td></tr><tr ac:local-id=\"d2d1837c-2d86-44de-b275-c9c262c48ae6\"><td ac:local-id=\"7e19e103-9600-4a34-89d5-ad9a0e66210d\"><p local-id=\"72bf499b-9dc7-4a9d-808d-a23fb052dfb7\">PLS - Crear endpoint de EvaluateOrder</p></td><td ac:local-id=\"35e0b207-bfde-443b-913c-6629193ee76e\"><p local-id=\"e78464e9-6bb4-468f-ae62-7ee61006f8a1\">4h</p></td></tr><tr ac:local-id=\"4b48296c-b6ef-47c1-8c7c-b7eb70790c04\"><td ac:local-id=\"866f2d4e-b3e0-4bab-8a85-70ccc904f3f2\"><p local-id=\"9b227dbe-3391-4ac8-a2be-f880d28d0436\">PLS - Tras autorizar, Kount update_order as&iacute;ncrono (Sidekiq job)</p></td><td ac:local-id=\"a0673dfa-45f0-46de-acc1-c5d6685bc97f\"><p local-id=\"1ebd8751-755b-431d-bf6f-807626f849a5\">4h</p></td></tr><tr ac:local-id=\"e4c71722-7b98-4d44-8c96-ddda20603323\"><td ac:local-id=\"52b812cf-6500-4464-86e0-944457d2d1d1\"><p local-id=\"eab2cecd-c626-4052-b309-c8893e6fe71a\">Tpago - Eliminar gema kount-complete y reemplazar su uso con llamados a PLS</p></td><td ac:local-id=\"2b9fca58-0f20-4598-9e9a-628352600cda\"><p local-id=\"695d1826-a8c1-400d-af9a-629f2e3388eb\">4h</p></td></tr><tr ac:local-id=\"f10f6733-603a-4003-89ca-cd64dc93401c\"><td ac:local-id=\"da27adea-43e6-41b9-b4b4-d62c23e34173\"><p local-id=\"63cc966e-2fac-4939-9591-ef95c791f7d5\">Tpago - KountBusiness s&oacute;lo para kount_enabled? (tabla Configurations)</p></td><td ac:local-id=\"9df3f46d-5b32-48e0-89e5-af2180a1d9e1\"><p local-id=\"780a675f-ef57-414c-8f81-cb6ee8a684f5\">1h</p></td></tr><tr ac:local-id=\"fe7ad5e6-1681-4014-926d-0b7e8fa9be0d\"><td ac:local-id=\"2a21e25e-7fb1-42e0-b55f-0c9601052729\"><p local-id=\"3e6721c5-9038-4f15-a16e-5d0e5fe439e8\">Tpago - Remover updateOrder (se realizar&aacute; desde PLS)</p></td><td ac:local-id=\"2459f2fe-cd7d-4dae-9fca-57c5906c602a\"><p local-id=\"147a3faa-8ac1-49b5-a831-d6d558c94756\">1h</p></td></tr><tr ac:local-id=\"5c5386fb-37d9-4b56-a806-21ae5141cee0\"><td ac:local-id=\"be172b0b-4012-4863-b156-b5426dca2c10\"><p local-id=\"4c9e2719-6504-4bc2-8907-22f6740ed9b6\">Tpago - Para evaluateOrder, traficar hook_alias en vez de amount y datos de payer, y bin + last_4 en vez de cardNum</p></td><td ac:local-id=\"460edd1a-1eba-48ba-b564-65da559a0b62\"><p local-id=\"2219d805-63f1-420b-8f44-5fc41c39f329\">1h</p></td></tr><tr ac:local-id=\"df46cdd4-2c87-4da9-ad5b-12a3a2d4e769\"><td ac:local-id=\"ab9a2ce6-5379-4c45-82dd-c03e55f83c66\"><p local-id=\"99667e2d-7f00-4c39-87f2-ea6d83da9fd1\">Bancard-Configurations - Agregar restool de kount_orders y kount_login</p></td><td ac:local-id=\"3bc85525-88c8-403e-8847-61dec2d723fd\"><p local-id=\"de5878a9-2a1f-4175-a3eb-ea3918e606e3\">1/2h</p></td></tr><tr ac:local-id=\"9d44e0ee-98e0-4cba-beff-b8e2a5b27d21\"><td ac:local-id=\"acf8ac8a-b7ee-47ed-9e87-d8f28d3fb0fb\"><p local-id=\"00488c87-178d-4c9e-87b6-c06ed058f587\">Bancard-Constants - Agregar constante de 'Tpago Pago Casual'</p></td><td ac:local-id=\"a7b320dc-9fcb-48fe-8442-43af1ce6e9cf\"><p local-id=\"5dedecc4-2dd2-4dc5-afa5-cf5b32268349\">1/2h</p></td></tr><tr ac:local-id=\"cb8a30cc-f435-49f3-b554-3c931fcca9c6\"><td ac:local-id=\"53201133-1e4b-4c19-835a-695f04b7a7ce\"><p local-id=\"3e30b0e8-7c4c-4122-82c1-5fa09fd83643\">Salida a Staging</p><ul local-id=\"fd693777-86af-44ab-922a-997cff540364\"><li local-id=\"e7ef5f75-2e08-4807-b47d-27ec8241ca58\"><p local-id=\"07dedc90-a9e7-4c62-86a6-7446e4c3c17d\">Integraci&oacute;n de los flujos</p></li><li local-id=\"825424be-bc35-4766-a417-1cfc52e06791\"><p local-id=\"ee0be61f-8e20-4dcc-aee5-6b39992678d6\">Creaci&oacute;n y correci&oacute;n de PRs</p></li><li local-id=\"5bed96de-0719-4454-93eb-fd7de2f62fa2\"><p local-id=\"e817c32f-a4c3-44db-9634-24d1638ddbec\">Pruebas locales</p></li><li local-id=\"231786e3-1c33-4ab9-a935-68f7d3fe0ca7\"><p local-id=\"cc82a3a4-6451-4a4f-ae81-c366ee32ba88\">Armado de ramas</p></li><li local-id=\"6890ae07-c97a-4e82-bbfc-01c490e7e9d4\"><p local-id=\"af002c3b-be98-454a-9a17-99a7b45ed976\">Deploy a STG</p></li><li local-id=\"05b1d31e-7b23-4e35-8de9-fc804401086f\"><p local-id=\"e71b85da-734b-410f-ace3-fdc946562718\">Pruebas iniciales en STG</p></li></ul></td><td ac:local-id=\"f5ed7ffa-a444-4d38-be30-b9ccb32fc472\"><p local-id=\"60d9588f-592f-4213-acaf-b3e187aa8d40\">4h</p></td></tr><tr ac:local-id=\"39dab538-a6ef-43c5-9153-c0a4f33d691e\"><td data-highlight-colour=\"#eae6ff\" ac:local-id=\"0d3d7d3b-dbae-4403-bff7-972912616915\"><p local-id=\"2c745a87-0c0a-49bd-b972-4b9a3765385c\"><strong>Total Desarrollo</strong></p></td><td data-highlight-colour=\"#eae6ff\" ac:local-id=\"b6b631ca-e1ee-4728-8280-3fd237460849\"><p local-id=\"e8cf418c-01c7-4558-8007-621da22ee034\" style=\"text-align: center;\">32h (4 dias)</p></td></tr><tr ac:local-id=\"258ef838-bf06-404b-a2b2-f5dc9f8228ee\"><td data-highlight-colour=\"#eae6ff\" ac:local-id=\"dff3bc82-0776-4dbe-8a6b-82f3d0df8bc6\"><p local-id=\"c0df9c4f-fdc9-451a-9745-c6cd4aeafbf4\"><strong>Total Gesti&oacute;n 15% (para facturaci&oacute;n, no afecta el desarrollo)</strong></p><p local-id=\"9232923b-3640-40e9-9494-aa8962449626\"><em>Incluye reuniones de estimaci&oacute;n, planificaci&oacute;n, t&eacute;cnicas y de seguimiento.</em></p></td><td data-highlight-colour=\"#eae6ff\" ac:local-id=\"2d1ab7ac-0c3d-479a-b74f-b174de32aab1\"><p local-id=\"3ac9b79e-9367-4d65-bf73-897a47754b40\" style=\"text-align: center;\" /></td></tr><tr ac:local-id=\"d09e15c3-4b3a-4533-b16a-c2f7c5fc2c13\"><td data-highlight-colour=\"#eae6ff\" ac:local-id=\"62058753-f2eb-4c30-ae61-2ea1a3d32076\"><p local-id=\"245a04c7-64ae-4cb5-a8f7-794085e6634b\"><strong>Total Desarrollo + Gesti&oacute;n</strong></p></td><td data-highlight-colour=\"#eae6ff\" ac:local-id=\"a008bef4-5b51-480c-af58-ba43a71b6057\"><p local-id=\"48e2a616-813d-4f82-b492-7f353834cb93\" style=\"text-align: center;\" /></td></tr></tbody></table><p local-id=\"d8b38230-e94f-41a6-96cf-7d0007943ca7\">Consultas</p><ol start=\"1\" local-id=\"1e603e93-47eb-41c8-ac9e-5a23900bcb80\"><li local-id=\"a872ab20-4860-4982-a3c7-a3c643c0ab00\"><p local-id=\"4de24055-2cfc-4f0b-8a31-9b4933f3ec86\">Hoy tpago manda a kount siempre CreditCard como constante. Continuamos as&iacute;? Sino habr&iacute;a que usar get_card_info</p></li><li local-id=\"95a58660-4f91-40c2-98bd-079eec51c046\"><p local-id=\"469637c1-2aa9-4305-8c6f-2b4c4d5ac807\">Actualizamos la documentaci&oacute;n de los llamados a Kount 360 via API, para que verifiquen que mandamos en cada par&aacute;metro.<br /><a href=\"https://bancard.atlassian.net/wiki/pages/resumedraft.action?draftId=1697775691\" local-id=\"d00d22cc-8f12-409e-9da9-0ae2c7c2f65d\" data-card-appearance=\"inline\">https://bancard.atlassian.net/wiki/pages/resumedraft.action?draftId=1697775691</a> <br /><del>En particular, en tpago s&iacute; se usan los commerce_id y commerce_branch_id en lugar de los codes.</del> Usar precarga de comercios y enviar el commerce_code.</p></li><li local-id=\"6e389b93-e02e-4928-984e-a5ca8ffecd8c\"><p local-id=\"020e7e05-a341-4945-8d21-490a8811edd9\">Existe alg&uacute;n par&aacute;metro que sea &uacute;nico con el cual tener cuidado cuando un pago:</p><ol start=\"1\" local-id=\"728d41b0-3410-4a43-9301-a9f9ca93aa44\"><li local-id=\"1d31aa26-e52d-43e8-9bbe-f844af9f3993\"><p local-id=\"6dd86ee6-efe7-477f-8007-8d169812fee6\">Se valida con Kount, luego</p></li><li local-id=\"976409a3-f992-49f6-9e88-8065b9ef9d89\"><p local-id=\"bb3bf0cd-ec48-47dc-971b-2e0ae0425601\">Falla y</p></li><li local-id=\"c83de296-229d-4a3a-9fbe-d73e6ee448ad\"><p local-id=\"b46dbaa6-ab5c-4295-965c-995f7c033b88\">Se vuelve a reintentar, validando con Kount<br />(Recomendamos como caso de prueba)</p></li></ol></li><li local-id=\"b5ef1ef5-ea28-488a-986d-58f73eb7e33e\"><p local-id=\"ad46489f-29f2-46cb-b184-416ac255b136\">Al llamar al JPOS para autorizar el pago, va a ser diferente el formato en el que enviaremos el resultado de kount. (Va a ser como se envia en vPOS):</p><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:local-id=\"83ee609f-f26e-4da5-be3a-be25757d8102\" ac:macro-id=\"acde57e4-5eb6-4e36-8f55-0130581fb60a\"><ac:parameter ac:name=\"language\">json</ac:parameter><ac:plain-text-body><![CDATA[kount: { orderResponse: order_response._raw, status: 'success' } # en caso exitoso. order_response es la respuesta de la API kount 360.\nkount: { description: exception.message, status: 'error' } # en caso de una excepcion]]></ac:plain-text-body></ac:structured-macro></li></ol><p local-id=\"58cd7b15-22df-4008-9498-3d4c94cac3d0\" />","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/4481548313"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":1900},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/4481548313/child","restrictions":"/rest/api/content/4481548313/restriction/byOperation","history":"/rest/api/content/4481548313/history","draftVersion":"","descendants":"/rest/api/content/4481548313/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=4481548313","webui":"/spaces/BAN/pages/4481548313/Tpago+-+Kount+360+-+Tasking+y+Estimaci+n","edituiv2":"/spaces/BAN/pages/edit-v2/4481548313","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/4481548313","tinyui":"/x/GQAfCwE","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}