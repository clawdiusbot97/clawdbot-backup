tent/2760147005/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2760147005/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2760147005","tinyui":"/x/PYCEp","editui":"/pages/resumedraft.action?draftId=2760147005","webui":"/spaces/BAN/pages/2760147005/Iniciativas+en+Curso","edituiv2":"/spaces/BAN/pages/edit-v2/2760147005"}},{"id":"3022520346","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/3022520346","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMzAyMjUyMDM0Ng==","status":"current","title":"BAU","macroRenderedOutput":{},"extensions":{"position":868},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/3022520346/restriction/byOperation","history":"/rest/api/content/3022520346/history","body":"","version":"","descendants":"/rest/api/content/3022520346/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3022520346/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/3022520346","tinyui":"/x/GgAot","editui":"/pages/resumedraft.action?draftId=3022520346","webui":"/spaces/BAN/pages/3022520346/BAU","edituiv2":"/spaces/BAN/pages/edit-v2/3022520346"}},{"id":"3067117571","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/3067117571","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMzA2NzExNzU3MQ==","status":"current","title":"Refactor Reseteo de Password","macroRenderedOutput":{},"extensions":{"position":1695},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/3067117571/restriction/byOperation","history":"/rest/api/content/3067117571/history","body":"","version":"","descendants":"/rest/api/content/3067117571/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3067117571/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/3067117571","tinyui":"/x/A4DQtg","editui":"/pages/resumedraft.action?draftId=3067117571","webui":"/spaces/BAN/pages/3067117571/Refactor+Reseteo+de+Password","edituiv2":"/spaces/BAN/pages/edit-v2/3067117571"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<ac:structured-macro ac:name=\"info\" ac:schema-version=\"1\" ac:macro-id=\"b2418b4c-d8ef-4d28-b8ac-259b6de8ff5b\"><ac:rich-text-body><p>Esta estimaci&oacute;n es en base al ticket </p><a href=\"https://bancard.atlassian.net/browse/PDA-388\" data-card-appearance=\"block\">https://bancard.atlassian.net/browse/PDA-388</a><p /></ac:rich-text-body></ac:structured-macro><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"14652069-58dd-4de5-b36c-c143b47f96b2\"><colgroup><col style=\"width: 392.0px;\" /><col style=\"width: 116.0px;\" /><col style=\"width: 254.0px;\" /></colgroup><tbody><tr><th><p><strong>Tarea</strong></p></th><th><p style=\"text-align: center;\"><strong>Estimaci&oacute;n (hs)</strong></p></th><th><p><strong>Servicio / Portal</strong></p></th></tr><tr><td><p>Modificar vista de ingreso de correo - </p><p /><p><em>Cambiar t&iacute;tulo a Olvidaste tu Contrase&ntilde;a? y agregar el texto sobre el campo</em></p></td><td><p style=\"text-align: center;\">1.5</p></td><td><p>[auth-portal]</p></td></tr><tr><td><p>Modificar endpoint para inicio de reseteo de contrase&ntilde;a</p><p /><p><em>Revisar</em></p></td><td><p style=\"text-align: center;\">1</p></td><td><p>[auth-portal]</p></td></tr><tr><td><p>Modificar el endpoint de inicio de reseteo de contrase&ntilde;a para que no env&iacute;e el OTP y refactorear el correo. </p><p>Ademas verificar y si el reset_token no est&aacute; expirado, enviar el mismo.</p></td><td><p style=\"text-align: center;\">16</p></td><td><p>[auth-service]</p></td></tr><tr><td><p>Vista de success en el envio de correo con boton para reenviar el correo</p><p /><p><em>Para el reenv&iacute;o de correo, llamar el endpoint de reinicio de contrase&ntilde;a</em></p></td><td><p style=\"text-align: center;\">20</p></td><td><p>[auth-portal]</p></td></tr><tr><td><p>Modificar vista para el ingreso de nueva contrase&ntilde;a. </p><p /><p><em>En el caso de requerir OTP, pegarle a un endpoint para enviar el mismo, mostrar el input para ingresarlo y bot&oacute;n para reenviarlo</em></p></td><td><p style=\"text-align: center;\">28</p></td><td><p>[auth-portal]</p></td></tr><tr><td><p>Endpoint para el env&iacute;o de OTP</p></td><td><p style=\"text-align: center;\">8</p></td><td><p>[auth-portal]</p></td></tr><tr><td><p>Endpoint para generaci&oacute;n y env&iacute;o de OTP para reseteo de contrase&ntilde;a. Modificar texto de SMS</p></td><td><p style=\"text-align: center;\">16</p></td><td><p>[auth-service]</p></td></tr><tr><td><p>Revisar y refactorear endpoint de reseteo de contrase&ntilde;a</p></td><td><p style=\"text-align: center;\">8</p></td><td><p>[auth-service]</p></td></tr><tr><td><p>Vista de success en el reseteo de contrase&ntilde;a con bot&oacute;n de redirect a la return_url</p></td><td><p style=\"text-align: center;\">8</p></td><td><p>[auth-portal]</p></td></tr><tr><td><p>Refactor del endpoint request_reset en auth-service</p><p /><p><em>Agregar columna requires_otp en la tabla services y modificar operaci&oacute;n validate_otp? para que en lugar de recibir el requires_otp por par&aacute;metro lo consulte desde la tabla servicios por el servicio asociado al usuario. </em></p></td><td><p style=\"text-align: center;\">12</p></td><td><p>[auth-service]</p></td></tr><tr><td data-highlight-colour=\"#f4f5f7\"><p>Gestion 15% (no altera el scope, es por tema de facturaci&oacute;n)</p></td><td data-highlight-colour=\"#f4f5f7\"><p style=\"text-align: center;\">18hs</p></td><td data-highlight-colour=\"#f4f5f7\"><p /></td></tr><tr><td data-highlight-colour=\"#f4f5f7\"><p>Total desarrollo </p></td><td data-highlight-colour=\"#f4f5f7\"><p style=\"text-align: center;\">119hs</p></td><td data-highlight-colour=\"#f4f5f7\"><p /></td></tr><tr><td data-highlight-colour=\"#e3fcef\"><p>Total hs desarrollo + gesti&oacute;n</p></td><td data-highlight-colour=\"#e3fcef\"><p style=\"text-align: center;\">137hs</p></td><td data-highlight-colour=\"#e3fcef\"><p /></td></tr></tbody></table>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/3022061647"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":86255185},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3022061647/child","restrictions":"/rest/api/content/3022061647/restriction/byOperation","history":"/rest/api/content/3022061647/history","draftVersion":"","descendants":"/rest/api/content/3022061647/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=3022061647","webui":"/spaces/BAN/pages/3022061647/Refactor+del+Portal+de+Reseteo+de+Contrase+a+-+Tasking+y+Estimaci+n","edituiv2":"/spaces/BAN/pages/edit-v2/3022061647","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/3022061647","tinyui":"/x/TwAht","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}