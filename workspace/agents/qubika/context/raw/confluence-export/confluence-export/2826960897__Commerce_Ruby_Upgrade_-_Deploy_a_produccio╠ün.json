yOperation","history":"/rest/api/content/4470308902/history","body":"","version":"","descendants":"/rest/api/content/4470308902/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/4470308902/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/4470308902","tinyui":"/x/JoBzCgE","editui":"/pages/resumedraft.action?draftId=4470308902","webui":"/spaces/BAN/pages/4470308902/Archived+-+Ruby+Upgrade","edituiv2":"/spaces/BAN/pages/edit-v2/4470308902"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<h1>Feature Branch</h1><ul><li><p>feature/ruby_upgrade</p><ul><li><p><a href=\"https://github.com/bancardsa/bancard-commerce-service/tree/feature/ruby-upgrade\">commerce-service</a></p></li><li><p><a href=\"https://github.com/bancardsa/bancard-commerce-suite/tree/feature/ruby-upgrade\">commerce-suite</a></p></li></ul></li><li><p>feature/commerce-suite-upgrade</p><ul><li><p><a href=\"https://github.com/bancardsa/bancard-payment-link-portal/tree/feature/commerce-suite-upgrade\">payment-link-portal</a></p></li><li><p><a href=\"https://github.com/bancardsa/bancard-selling-portal/tree/feature/commerce-suite-upgrade\">selling-portal</a></p></li></ul></li><li><p>feature/commerce_ruby_upgrade</p><ul><li><p><a href=\"https://github.com/bancardsa/bancard-docker/tree/feature/commerce_ruby_upgrade\">bancard-docker</a></p></li></ul></li></ul><p /><h1>Proyectos involucrados</h1><ul><li><p>bancard-commerce-service</p></li><li><p>bancard-commerce-suite</p></li><li><p>bancard-payment-link-portal</p></li><li><p>bancard-selling-portal</p></li><li><p>bancard-docker</p></li><li><p>bancard-configurations</p></li></ul><h1>Consideraciones Generales</h1><ac:task-list>\n<ac:task>\n<ac:task-id>69</ac:task-id>\n<ac:task-status>incomplete</ac:task-status>\n<ac:task-body><span class=\"placeholder-inline-tasks\">Necesita conexi&oacute;n con servicios externos (Coordinar con Denis).</span></ac:task-body>\n</ac:task>\n<ac:task>\n<ac:task-id>70</ac:task-id>\n<ac:task-status>incomplete</ac:task-status>\n<ac:task-body><span class=\"placeholder-inline-tasks\">Necesita conexi&oacute;n con otros servidores (Revisar conectividad y coordinar con Denis).</span></ac:task-body>\n</ac:task>\n<ac:task>\n<ac:task-id>71</ac:task-id>\n<ac:task-status>complete</ac:task-status>\n<ac:task-body><span class=\"placeholder-inline-tasks\">Necesita ejecutar migraciones en la db (Coordinar con DBA). </span></ac:task-body>\n</ac:task>\n<ac:task-list>\n<ac:task>\n<ac:task-id>85</ac:task-id>\n<ac:task-status>incomplete</ac:task-status>\n<ac:task-body><span class=\"placeholder-inline-tasks\">Necesita migrar la DB al cluster de mysql 8.0</span></ac:task-body>\n</ac:task>\n</ac:task-list><ac:task>\n<ac:task-id>72</ac:task-id>\n<ac:task-status>incomplete</ac:task-status>\n<ac:task-body><span class=\"placeholder-inline-tasks\">Necesita Buckets de S4?</span></ac:task-body>\n</ac:task>\n<ac:task>\n<ac:task-id>73</ac:task-id>\n<ac:task-status>incomplete</ac:task-status>\n<ac:task-body><span class=\"placeholder-inline-tasks\">Necesita cargar im&aacute;genes o datos est&aacute;ticos?</span></ac:task-body>\n</ac:task>\n</ac:task-list><p /><h1>Migraciones a ejecutar</h1><ul><li><p>No aplica. Si es necesario migrar la base de datos al cluster de mysql 8.0</p></li></ul><h1>Datos a insertar</h1><ul><li><p>No aplica.</p></li></ul><h1>Link a configuraciones</h1><ul><li><p><a href=\"https://github.com/bancardsa/bancard-configurations/pull/224\" data-card-appearance=\"inline\">https://github.com/bancardsa/bancard-configurations/pull/224</a> </p></li></ul><h1>Pull requests a develop</h1><ul><li><p><a href=\"https://github.com/bancardsa/bancard-commerce-suite/pull/280\" data-card-appearance=\"inline\">https://github.com/bancardsa/bancard-commerce-suite/pull/280</a> </p></li><li><p><a href=\"https://github.com/bancardsa/bancard-commerce-service/pull/340\" data-card-appearance=\"inline\">https://github.com/bancardsa/bancard-commerce-service/pull/340</a> </p></li><li><p><a href=\"https://github.com/bancardsa/bancard-selling-portal/pull/9\" data-card-appearance=\"inline\">https://github.com/bancardsa/bancard-selling-portal/pull/9</a> </p></li><li><p><a href=\"https://github.com/bancardsa/bancard-payment-link-portal/pull/126\" data-card-appearance=\"inline\">https://github.com/bancardsa/bancard-payment-link-portal/pull/126</a> </p></li></ul><h1>Pull requests a Master</h1><ul><li><p><a href=\"https://github.com/bancardsa/bancard-configurations/pull/224\" data-card-appearance=\"inline\">https://github.com/bancardsa/bancard-configurations/pull/224</a> </p></li><li><p><a href=\"https://github.com/bancardsa/bancard-docker/pull/98\" data-card-appearance=\"inline\">https://github.com/bancardsa/bancard-docker/pull/98</a> </p><ul><li><p>Es necesario mergearlo recien al llevar a producci&oacute;n, ya que bancard-docker no distingue la configuraci&oacute;n del webserver seg&uacute;n el entorno</p></li></ul></li><li><p><a href=\"https://github.com/bancardsa/bancard-commerce-suite/pull/402\" data-card-appearance=\"inline\">https://github.com/bancardsa/bancard-commerce-suite/pull/402</a> </p></li><li><p><a href=\"https://github.com/bancardsa/bancard-commerce-service/pull/341\" data-card-appearance=\"inline\">https://github.com/bancardsa/bancard-commerce-service/pull/341</a> </p></li><li><p><a href=\"https://github.com/bancardsa/bancard-payment-link-portal/pull/127\" data-card-appearance=\"inline\">https://github.com/bancardsa/bancard-payment-link-portal/pull/127</a> </p></li><li><p><a href=\"https://github.com/bancardsa/bancard-selling-portal/pull/10\" data-card-appearance=\"inline\">https://github.com/bancardsa/bancard-selling-portal/pull/10</a> </p></li></ul>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/2826960897"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":