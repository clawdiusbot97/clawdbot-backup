{"id":"2818015246","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2818015246","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjgxODAxNTI0Ng==","status":"current","title":"Baas Token Authentication","version":{"by":{"type":"known","accountId":"5f3d2a10ea5e2f003979db69","accountType":"atlassian","email":"","publicName":"Ignacio Jorge","profilePicture":{"path":"/wiki/aa-avatar/5f3d2a10ea5e2f003979db69","width":48,"height":48,"isDefault":false},"displayName":"Ignacio Jorge","isExternalCollaborator":false,"isGuest":false,"locale":"en_US","accountStatus":"active","_expandable":{"operations":"","personalSpace":""},"_links":{"self":"[PRIVATE_URL_WITH_CREDENTIALS] plain_signature</p><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:macro-id=\"ea9414a3-e688-4872-97f6-c83f9cc0761b\"><ac:plain-text-body><![CDATA[plain_signature = \"<DATE>\\n<METHOD>\\n<URL>\"\n\nEXAMPLE:\nplain_signature = \"Thu, 23 Jun 2022 18:30:10 GMT\\nGET\\n/auth/api/0.2/users/1/profile\"]]></ac:plain-text-body></ac:structured-macro></li><li><p>Generate SHA1 hash signature</p><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:macro-id=\"b52dcaaa-79e2-4595-affd-abaae849b92a\"><ac:plain-text-body><![CDATA[token = <user_token>\nplain_signature = <plain_signature>\nsignature = Digest::SHA1.hexdigest(\"#{token}\\n#{plain_signature}\")\n\nEXAMPLE:\ntoken = \"bc5d0894c972c8e6df1249d4c968b38c6aff74686a0c186789d287966057bf7e\"\n\nplain_signature = \"Thu, 23 Jun 2022 18:30:10 GMT\\nGET\\n/auth/api/0.2/users/1/profile\"\n\nsignature = Digest::SHA1.hexdigest(\"#{token}\\n#{plain_signature}\")\n=> \"43b105ddcfebe6e73ac3f3cb59fd25619ad1bd72\"]]></ac:plain-text-body></ac:structured-macro></li><li><p>Make requests using baas authentication with the signature and the date used to create it</p><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:macro-id=\"3721e9df-71df-4d90-a636-8a22ef50baf4\"><ac:plain-text-body><![CDATA[curl --location --request GET 'https://desa.infonet.com.py/auth/api/0.2/users/1/profile' \\\n--header 'Authorization: BAAS v1 user-tokens/<EMAIL>:<SIGNATURE>' \\\n--header 'Date: <DATE>'\n\nEXAMPLE:\ncurl --location --request GET 'https://desa.infonet.com.py/auth/api/0.2/users/1/profile' \\\n--header 'Authorization: BAAS v1 user-tokens/bancard@moove-it.com:43b105ddcfebe6e73ac3f3cb59fd25619ad1bd72' \\\n--header 'Date: Thu, 23 Jun 2022 18:30:10 GMT']]></ac:plain-text-body></ac:structured-macro></li></ol>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/2818015246"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":860},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2818015246/child","restrictions":"/rest/api/content/2818015246/restriction/byOperation","history":"/rest/api/content/2818015246/history","draftVersion":"","descendants":"/rest/api/content/2818015246/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=2818015246","webui":"/spaces/BAN/pages/2818015246/Baas+Token+Authentication","edituiv2":"/spaces/BAN/pages/edit-v2/2818015246","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/2818015246","tinyui":"/x/DoD3pw","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}[PRIVATE_URL_WITH_CREDENTIALS]