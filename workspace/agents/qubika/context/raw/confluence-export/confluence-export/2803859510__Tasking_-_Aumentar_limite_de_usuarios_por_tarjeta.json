"history":"/rest/api/content/2749431812/history","body":"","version":"","descendants":"/rest/api/content/2749431812/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2749431812/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2749431812","tinyui":"/x/BADhow","editui":"/pages/resumedraft.action?draftId=2749431812","webui":"/spaces/BAN/pages/2749431812/Tpago+flujo+Stripe","edituiv2":"/spaces/BAN/pages/edit-v2/2749431812"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"2ffc11cf-80e8-4394-b78b-41ebe36b981d\"><tbody><tr><th><p><strong>Tarea</strong></p></th><th><p><strong>Estimaci&oacute;n (hs) </strong></p></th></tr><tr><td><p>Crear nueva tabla en la base para las configuraciones (incluyendo config de limite de usuarios) </p></td><td><p>2hs</p></td></tr><tr><td><p>Modificar el endpoint de external-services para enviar el service code de TPago (cr&eacute;dito)</p></td><td><p>12hs</p></td></tr><tr><td><p>Modicar el llamado desde payment-link-service para cambiar el service code a external-services (cr&eacute;dito) </p></td><td><p>12hs</p></td></tr><tr><td><p>Obtener la config de la cantidad de tarjs desde payment-link-service </p><ul><li><p>Agregar validaciones</p><ul><li><p>Si valor de config es 0 &rarr; Validar que la tarjeta sea del usuario (desde jpos)</p></li><li><p>Si valor de config es 1 o + &rarr; No importa si la tarjeta es del due&ntilde;o o no</p></li><li><p>Validar que no se registren mas usuarios a una ci del valor seteado en la config</p></li></ul></li></ul></td><td><p>38hs</p></td></tr><tr><td><ul><li><p>Manejo de errores </p><ul><li><p>Avisar cuando se supera el l&iacute;mite de usuarios por tarjeta</p></li><li><p>Avisar cuando el config es 0 que solo puede catastrarla el due&ntilde;o</p></li></ul></li></ul></td><td><p>3hs</p></td></tr></tbody></table><p />","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/2803859510"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":82431785},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2803859510/child","restrictions":"/rest/api/content/2803859510/restriction/byOperation","history":"/rest/api/content/2803859510/history","draftVersion":"","descendants":"/rest/api/content/2803859510/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=2803859510","webui":"/spaces/BAN/pages/2803859510/Tasking+-+Aumentar+limite+de+usuarios+por+tarjeta","edituiv2":"/spaces/BAN/pages/edit-v2/2803859510","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/2803859510","tinyui":"/x/NoAfpw","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}