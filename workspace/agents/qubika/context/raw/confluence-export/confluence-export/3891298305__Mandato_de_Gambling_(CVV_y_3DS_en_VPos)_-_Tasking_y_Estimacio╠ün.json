760147005/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2760147005/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2760147005","tinyui":"/x/PYCEp","editui":"/pages/resumedraft.action?draftId=2760147005","webui":"/spaces/BAN/pages/2760147005/Iniciativas+en+Curso","edituiv2":"/spaces/BAN/pages/edit-v2/2760147005"}},{"id":"3233218577","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/3233218577","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMzIzMzIxODU3Nw==","status":"current","title":"VPos","macroRenderedOutput":{},"extensions":{"position":10592077},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/3233218577/restriction/byOperation","history":"/rest/api/content/3233218577/history","body":"","version":"","descendants":"/rest/api/content/3233218577/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3233218577/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/3233218577","tinyui":"/x/EQC3w","editui":"/pages/resumedraft.action?draftId=3233218577","webui":"/spaces/BAN/pages/3233218577/VPos","edituiv2":"/spaces/BAN/pages/edit-v2/3233218577"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<ac:structured-macro ac:name=\"info\" ac:schema-version=\"1\" ac:macro-id=\"9a9a47ae-6c50-4532-93e2-abfe1acd2bb0\"><ac:rich-text-body><p>Este documento representa el tasking y estimaci&oacute;n para los cambios relacionados a los requerimientos en VPos en cuanto a las transacciones de Gambling, a cargo de <ac:link><ri:user ri:account-id=\"632e0ea3409249995ee8d951\" ri:local-id=\"642f1174-1022-4335-bf89-17415cea241b\" /></ac:link> .</p><p>Las horas estimadas son: 40</p><p>Fecha de Inicio: <strong>Martes</strong> <time datetime=\"2025-04-15\" /></p><p>Fecha de Entrega: <strong>Mi&eacute;rcoles</strong> <time datetime=\"2025-04-23\" /> </p></ac:rich-text-body></ac:structured-macro><ac:structured-macro ac:name=\"note\" ac:schema-version=\"1\" ac:macro-id=\"2f5d6454-1e4b-4787-9745-9986fed8ed9f\"><ac:rich-text-body><p>La tarea de la primera fila es dependiente de unos cambios del lado de Bancard, que es un endpoint que nos avisa si necesitamos enviar un cvv aparte. </p></ac:rich-text-body></ac:structured-macro><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"d127e8c3-3fed-4af2-bc1b-c09b7117def2\"><colgroup><col style=\"width: 539.0px;\" /><col style=\"width: 221.0px;\" /></colgroup><tbody><tr><th><p><strong>Tarea</strong></p></th><th><p style=\"text-align: center;\"><strong>Estimaci&oacute;n (hs)</strong></p></th></tr><tr><td><p>Durante el flujo de pago con token chequear en el endpoint RPG si requiere CVV (Llamado a RPG Middleware desde VPos Service)</p></td><td><p>10 (8 + 2 testing)</p></td></tr><tr><td><p>Agregar formulario de CVV &uacute;nicamente en flujos de pago con token que lo requieran (VPos Portal)</p></td><td><p>20 (16 + 4 testing)</p></td></tr><tr><td><p>Modificar llamado a jpos de pago con token, para incluir CVV (Vpos Service)</p></td><td><p>10 (8 + 2 testing)</p></td></tr><tr><td data-highlight-colour=\"#eae6ff\"><p><strong>Total Desarrollo</strong></p></td><td data-highlight-colour=\"#eae6ff\"><p style=\"text-align: center;\">40</p></td></tr></tbody></table>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/3891298305"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":179691623},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3891298305/child","restrictions":"/rest/api/content/3891298305/restriction/byOperation","history":"/rest/api/content/3891298305/history","draftVersion":"","descendants":"/rest/api/content/3891298305/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=3891298305","webui":"/spaces/BAN/pages/3891298305/Mandato+de+Gambling+CVV+y+3DS+en+VPos+-+Tasking+y+Estimaci+n","edituiv2":"/spaces/BAN/pages/edit-v2/3891298305","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/3891298305","tinyui":"/x/AYDw5w","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}