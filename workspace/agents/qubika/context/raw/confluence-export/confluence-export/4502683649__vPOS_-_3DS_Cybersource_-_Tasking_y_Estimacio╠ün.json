ulePublishDate":"","children":"/rest/api/content/2178416778/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2178416778","tinyui":"/x/igDYgQ","editui":"/pages/resumedraft.action?draftId=2178416778","webui":"/spaces/BAN/overview","edituiv2":"/spaces/BAN/pages/edit-v2/2178416778"}},{"id":"2685108225","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2685108225","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjY4NTEwODIyNQ==","status":"current","title":"Iniciativas","macroRenderedOutput":{},"extensions":{"position":274391100},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2685108225/restriction/byOperation","history":"/rest/api/content/2685108225/history","body":"","version":"","descendants":"/rest/api/content/2685108225/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2685108225/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2685108225","tinyui":"/x/AYALo","editui":"/pages/resumedraft.action?draftId=2685108225","webui":"/spaces/BAN/pages/2685108225/Iniciativas","edituiv2":"/spaces/BAN/pages/edit-v2/2685108225"}},{"id":"2760147005","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2760147005","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjc2MDE0NzAwNQ==","status":"current","title":"Iniciativas en Curso","macroRenderedOutput":{},"extensions":{"position":258},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2760147005/restriction/byOperation","history":"/rest/api/content/2760147005/history","body":"","version":"","descendants":"/rest/api/content/2760147005/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2760147005/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2760147005","tinyui":"/x/PYCEp","editui":"/pages/resumedraft.action?draftId=2760147005","webui":"/spaces/BAN/pages/2760147005/Iniciativas+en+Curso","edituiv2":"/spaces/BAN/pages/edit-v2/2760147005"}},{"id":"4487741468","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/4487741468","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvNDQ4Nzc0MTQ2OA==","status":"current","title":"Migrar Cardinal 3DS a Cybersource 3DS","macroRenderedOutput":{},"extensions":{"position":156},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/4487741468/restriction/byOperation","history":"/rest/api/content/4487741468/history","body":"","version":"","descendants":"/rest/api/content/4487741468/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/4487741468/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/4487741468","tinyui":"/x/HIB9CwE","editui":"/pages/resumedraft.action?draftId=4487741468","webui":"/spaces/BAN/pages/4487741468/Migrar+Cardinal+3DS+a+Cybersource+3DS","edituiv2":"/spaces/BAN/pages/edit-v2/4487741468"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<ac:structured-macro ac:name=\"info\" ac:schema-version=\"1\" ac:local-id=\"63e8c255-0bb3-47c9-a87c-9d1a04c3ce24\" ac:macro-id=\"d9e458ca-0ac4-437f-8369-e983a7fe78b9\"><ac:rich-text-body><p local-id=\"e9f27c1d-b459-4825-86ad-c16bb6ed4a17\">Este documento representa el tasking y estimaci&oacute;n para el proyecto de migraci&oacute;n del flujo 3DS Cardinal a Cybersource en vPOS, a cargo de <ac:link><ri:user ri:account-id=\"712020:9e4c7b07-03d5-4a81-a522-cc90518f3086\" ri:local-id=\"480544c5-e72e-42ef-98c5-0d86758b3b2d\" /></ac:link> y <ac:link><ri:user ri:account-id=\"712020:bd6be9b3-2ff0-412b-8fb1-57e9e188f6cf\" ri:local-id=\"e9768c37-cf8c-43fc-8e22-db829ba2655a\" /></ac:link> </p><p local-id=\"fddc80f4-559a-4c30-918f-0efdeb223d55\">Las horas estimadas son: 336 ~ 42 d&iacute;as</p><p local-id=\"7e444a854018\">El equipo hizo el an&aacute;lisis y hay un 30% de tareas que se puede paralelizar, por ende, no van a ser 21 d&iacute;as de cada desarrollador, sino 30 de uno y 12 del otro. En el desarrollo vamos a definir quien es el que culmina primero y queda libre para tomar otras tareas o dar soporte.</p><p local-id=\"47cf096a-4206-4384-a06a-7f9f76f074ed\">Fecha de Inicio: <time datetime=\"2026-01-28\" local-id=\"1d4a8a39b94c\" /> </p><p local-id=\"6cdb6630-9cc0-4312-881a-b56c775dca7c\">Fecha de Entrega: <time datetime=\"2026-03-16\" local-id=\"457ad6f12c70\" /> </p></ac:rich-text-body></ac:structured-macro><h1 local-id=\"e9b03325-3a02-4635-841e-c873377fa3a3\">Consideraciones Generales</h1><p local-id=\"eb20bc0b-ac09-4191-af45-85b5eee68b13\">El proceso 3DS en cybersource est&aacute; dividido en 5 pasos, los cuales son nuestra gu&iacute;a para el armado de la estimaci&oacute;n:</p><ol start=\"1\" local-id=\"033413ae-9a57-488b-9e7d-fd86fb948610\"><li local-id=\"dddc29a6-a03c-42f5-ac85-4e153cdbd78d\"><p local-id=\"0929a680-cdb1-4638-8bd1-56b0300fd079\"><strong>Setup Service:</strong> llamado a la API de cybersource enviando datos de la tarjeta para obtener la URL y el JWT para el DDC. </p></li><li local-id=\"0cf34911-d84d-4052-9ba4-efecd5a13a5f\"><p local-id=\"1eb762b7-5a25-47ca-beaf-b71b4151a65b\"><strong>Device Data Collection:</strong> llamado a la DDC URL, recolecci&oacute;n de los datos del navegador en iframe invisible.</p></li><li local-id=\"9821f0bb-1861-4df3-9201-a5a7ff32f1a5\"><p local-id=\"de45a5bb-eb41-40b3-b1d9-c18dca2d72b3\"><strong>Payer Authentication Check Enrollment Service: </strong>(ex lookup) llamado a la API de cybersource para conocer el nivel de riesgo de la operaci&oacute;n:<br />- Frictionless success (riesgo bajo)<br />- Challenge required (riesgo moderado)<br />- Frictionless failure or decline (riesgo alto)</p></li><li local-id=\"74dac5dd-8a2b-4bd6-bbd9-35eb126081da\"><p local-id=\"c9d94509-7baa-4943-b16b-875bd83d1a2b\"><strong>Step-Up iframe: </strong>iframe visible donde el usuario completa el challenge para validar su identidad.</p></li><li local-id=\"48c44d1a-1f54-4682-a757-e317ab711d9a\"><p local-id=\"9b0dc9cc-9938-46bb-a8c8-86b69d7bd894\"><strong>Payer Authentication Validation Service: </strong>verificaci&oacute;n de que el usuario valid&oacute; exitosamente su identidad (solo si ocurri&oacute; un challenge). </p></li></ol><h2 local-id=\"8cef92d4-278a-41a2-baac-4fa4f4908e06\">vPOS</h2><h3 local-id=\"1f113643-bae4-4e37-8a30-9852257e8c13\">Flujos involucrados:</h3><ul local-id=\"7f24893d-fb29-4ca0-947a-4e8a8d538dd5\"><li local-id=\"756be950-8793-473a-a87d-cd51248d773e\"><p local-id=\"e6726dce-c703-4fa0-9964-1b3ac1702802\">Pago con formulario</p><ul local-id=\"9b98eb01-e7c1-41be-9188-0d4a0ad69b19\"><li local-id=\"60fa3833-0469-4047-8e61-5b42f63dc0bc\"><p local-id=\"8c13937c-7efe-4e6c-a0ca-958e101d3190\">Single (con o sin preautorizaci&oacute;n)</p></li><li local-id=\"a57d4e87-0772-4b12-be00-86fd16ade8fb\"><p local-id=\"f5128cd5-23d4-461d-8167-c3c57fd82b6f\">Multi (con o sin preautorizaci&oacute;n)</p></li></ul></li><li local-id=\"34709d55-3af6-448a-9c75-d3332da1f023\"><p local-id=\"b12f1b2b-a285-4fb3-8fce-521a606f1055\">Pago con token</p><ul local-id=\"146c5ae7-8b22-44dd-9ef0-ae2b6bdc384d\"><li local-id=\"b90af27a-2897-42da-90db-34d5d935c2ef\"><p local-id=\"de3ed0bb-07d8-45c3-98d2-b2e326dfc2ce\">Single (con o sin preautorizaci&oacute;n)</p></li><li local-id=\"402a4a20-735e-48c6-9fd3-f10992f48785\"><p local-id=\"82201a66-62a0-40e9-af67-ada7fd84fee4\">Multi (con o sin preautorizaci&oacute;n)</p></li></ul></li><li local-id=\"e8d3322f-4587-4c10-aaaf-b65bc179afd6\"><p local-id=\"eba145ad-a1d1-4084-800a-baee1fb669da\">Catastro</p></li></ul><table data-table-width=\"1296\" data-layout=\"center\" ac:local-id=\"4719d491-786e-4761-9e9c-ede74830dcb5\"><colgroup><col style=\"width: 1056.0px;\" /><col style=\"width: 240.0px;\" /></colgroup><tbody><tr ac:local-id=\"886f637f-43af-4af7-81fd-e2da98a38cc0\"><th ac:local-id=\"b164766b-8c9f-4727-a00d-d5e96ffad41f\"><p local-id=\"5d6d029b-bd8f-4ac9-88d6-c8963da49b86\"><strong>Tarea</strong></p></th><th ac:local-id=\"32547706-46aa-48e6-80ed-84ce8d7de319\"><p local-id=\"354d6a78-d6c5-4ffb-887c-31d1af331f87\"><strong>Estimaci&oacute;n (hs)</strong></p></th></tr><tr ac:local-id=\"d433f46f-4593-46e1-8fe1-6a09bad67316\"><td ac:local-id=\"f65f2e27-e78f-4a27-b892-8cc940778be3\"><p local-id=\"78ffb524-3ce0-467b-9c4a-23fd54f3498f\"><strong>[PASO 1] Setup Service</strong></p><p local-id=\"1ab5cdf58028\">Implementar endpoint en vpos-service para invocar al servicio de setups para obtener JWT y URL para el DDC. </p><p local-id=\"965efd2c1cf3\">Llamar a la API de Cybersourse usando gema oficial <a href=\"https://github.com/CyberSource/cybersource-rest-client-ruby\">cybersource-rest-client-ruby</a> reempazando external-services.</p><p local-id=\"59ab4e5ac418\">Invocar a esta nueva operaci&oacute;n al hacer submit en todos los flujos involucrados.</p></td><td ac:local-id=\"343f622f-f14e-4ceb-a90a-04dd97922c0c\"><p local-id=\"d263b6f2-7d86-46b8-8e93-45816f36d9b7\">40</p></td></tr><tr ac:local-id=\"6af2e10b-6eb3-484d-bf6f-0ac915ae450a\"><td ac:local-id=\"3c7fdae6-1fe0-47bf-bcd8-fb925bcdfd74\"><p local-id=\"a7c5d2d9-a2b9-4e8e-8ab5-de954a58b842\"><strong>[PASO 2] Device Data Collection</strong><br />Implementar el iframe y form ocultos para DDC. Capturar el mensaje desde el iframe oculto para habilitar el paso 3.</p><p local-id=\"52c76c4d54aa\">Implementar para todos los flujos involucrados.</p></td><td ac:local-id=\"98f18511-c8ac-4fb9-bd50-d2df1ce916f5\"><p local-id=\"77d6b00e-f169-4293-a820-3f0bfa2306e4\">40</p></td></tr><tr ac:local-id=\"d6139dad-5a62-4f4b-8113-b1c28d6d3f4b\"><td ac:local-id=\"c6db32fd-dc09-4b6b-8e2b-9ad0d3159fa9\"><p local-id=\"6f965626-499b-4166-a8ed-2678251f19ad\"><strong>[PASO 3] Payer Authentication Check Enrollment Service</strong><br />Invocar al servicio usando el <code>referenceId</code> obtenido en el paso 1. Evaluar si se har&aacute; challenge o no. </p><p local-id=\"7060f7ed7ce5\">Implementar para todos los flujos involucrados.</p></td><td ac:local-id=\"5edd6c72-0904-4b26-a198-a5fa7ff20f9e\"><p local-id=\"e6f07e1a-b994-45c0-8809-25941ba6621a\">32</p></td></tr><tr ac:local-id=\"87e35c76-368f-4496-9528-9e5532398f69\"><td ac:local-id=\"abb261d6-6535-4f04-afb5-363ac18bf140\"><p local-id=\"f8ffab88-96e2-4668-9c66-ac0ff94c47a3\"><strong>[PASO 4] Step-Up iframe</strong><br />Implementar el iframe visible para el challenge. Integrar el <code>stepUpUrl</code> y <code>accessToken</code> recibidos en el punto 3. Gestionar el callback: eliminar websockets y reemplazar por mensajes de javascript.</p><p local-id=\"776a60af429a\">Implementar para todos los flujos involucrados.</p></td><td ac:local-id=\"f3b7c4bd-3d50-40d6-8880-bdb2365c9e26\"><p local-id=\"8d6e4a6a-2738-4b70-afa6-bf098edd9daf\">56</p></td></tr><tr ac:local-id=\"3541fd21-b47b-4792-b496-2179d5d8a902\"><td ac:local-id=\"fc0590a5-6d0e-403c-b558-92a2756bd464\"><p local-id=\"96c27ebf-1aed-4609-967a-6d1e78b9c59f\"><strong>[PASO 5] Payer Authentication Validation</strong> Verificar el resultado del challenge (si ocurri&oacute;). Invocar el endpoint de validaci&oacute;n y procesar la respuesta antes de autorizar el pago/catastro.</p><p local-id=\"ed373ac2085f\">Implementar para todos los flujos involucrados.</p></td><td ac:local-id=\"fbbb1533-90f5-4043-aed5-17192ba691f4\"><p local-id=\"a4f99065-a871-405b-9e8f-6649244bc5d5\">24</p></td></tr><tr ac:local-id=\"880c8100b2b4\"><td ac:local-id=\"f244baaa2ebb\"><p local-id=\"8190a9fe1baa\">Dise&ntilde;o del modelo de datos. Crear asociaciones en modelos.</p><p local-id=\"acb53d7f6051\">Creaci&oacute;n de tabla three_ds_sessions:<br />- id<br />- reference_id<br />- setup_response<br />- enrollment_response<br />- validation_response<br />- resource_id<br />- resource_type (Flow o NewCardRequest)</p></td><td ac:local-id=\"f489bab24947\"><p local-id=\"943f820bcf58\">24</p></td></tr><tr ac:local-id=\"c2de010b81b5\"><td ac:local-id=\"0e67dbda953d\"><p local-id=\"e1714dab88de\">Deprecar cardinal:</p><ul local-id=\"02c21547fdc0\"><li local-id=\"759b2e98ea50\"><p local-id=\"7be0ba4d21aa\">eliminar c&oacute;digo referente a cardinal.</p></li><li local-id=\"53bd237bcaa3\"><p local-id=\"b5a76672616d\">dejar de usar columnas en la BBDD referentes a cardinal. usar ignored_columns de ActiveRecord en caso de que sea pertinente.</p></li></ul></td><td ac:local-id=\"18638dba3aa6\"><p local-id=\"8f52fdf7a2c0\">12</p></td></tr><tr ac:local-id=\"14c13be82ddc\"><td ac:local-id=\"a35512d29b4d\"><p local-id=\"421920db41bb\">Modificar llamados al JPOS de todas las operaciones para enviar las respuestas de cybersource.</p><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:local-id=\"03096aed2f20\" ac:macro-id=\"a037b2b0-5769-475f-89e7-e4afac0062ab\"><ac:plain-text-body><![CDATA[payerAuthentication: {\n    enrollmentResponse: {...},\n    validationResponse: {...}\n}]]></ac:plain-text-body></ac:structured-macro></td><td ac:local-id=\"b6b207d227e1\"><p local-id=\"9e575bc54806\">24</p></td></tr><tr ac:local-id=\"b22b829fe013\"><td ac:local-id=\"276c5e70318a\"><p local-id=\"7565d3583afa\">Relevamiento de seguridad en todos los flujos. Evaluar riesgos y vulnerabilidades.</p><p local-id=\"6617abc70ae0\">Evitar validaciones de seguridad o controles en el front-end. En caso de ser necesarios, respaldarlos con sus respectivas validaciones en el back-end.</p><p local-id=\"ce33746bc17e\">Especialmente importante cuando validamos si un flujo debe o no realizar 3DS.</p><p local-id=\"0cdc30eb5863\">Refactorizar seg&uacute;n sea necesario. </p></td><td ac:local-id=\"763a10fb5d7d\"><p local-id=\"5290c14b2825\">16<br />en caso de un refactor significativo, puede requerir una extensi&oacute;n.</p></td></tr><tr ac:local-id=\"445f76ee-c5a3-42c2-a99e-49b3ff06df56\"><td ac:local-id=\"c52e30e6-d61a-42ef-8afb-a3841662d2cd\"><p local-id=\"dcc28b5c-1e7c-4656-b897-b1f9102d74e1\"><strong>Integraci&oacute;n y pruebas en Staging</strong>\n- Integraci&oacute;n de los flujos\n- Creaci&oacute;n y correcci&oacute;n de PRs\n- Pruebas locales\n- Armado de ramas\n- Deploy a STG\n- Pruebas iniciales en STG</p></td><td ac:local-id=\"31adeea7-9111-4953-b4ea-f4597bba33ad\"><p local-id=\"124c67d4-bc75-409c-9b98-28607a0728bc\">24</p></td></tr><tr ac:local-id=\"74d4a816-ea65-42e8-b7b3-14cf7247f81c\"><td ac:local-id=\"89af4cd1-f50d-4c80-a305-9adf15972645\"><p local-id=\"7b623d4d-4981-42ba-b9a9-76435540cc30\"><strong>Total Desarrollo</strong></p></td><td ac:local-id=\"3b5e87b5-9939-44f8-9a39-9e28018082d5\"><p local-id=\"f65e9c4b-f4f8-4497-a4a6-8d16edc17a70\">292</p></td></tr><tr ac:local-id=\"dff75f8e-f642-42e9-8495-8efe8b4fb4ad\"><td ac:local-id=\"bc581eb0-5df8-4e2c-818a-77c128dbfa23\"><p local-id=\"666166f0-7e11-4bdf-ba9b-72068664a634\"><strong>Total Gesti&oacute;n 15%</strong>\nIncluye reuniones de estimaci&oacute;n, planificaci&oacute;n, t&eacute;cnicas y de seguimiento.</p></td><td ac:local-id=\"d7a9870c-eff5-49ea-8cc0-3d3055be2d89\"><p local-id=\"380e692c-70c7-47c9-a4bd-bdd909ca5650\">44</p></td></tr><tr ac:local-id=\"7933a139-03e3-4e0d-9be6-c92fdab4aa22\"><td ac:local-id=\"b3ff41b7-c62e-4aa4-b5ca-cb4793a19f1c\"><p local-id=\"83dcd50d-292d-4d81-a2e1-68ab5bf88872\"><strong>Total Desarrollo + Gesti&oacute;n</strong></p></td><td ac:local-id=\"a2686ee1-165e-43e7-9c1d-5c9ddbe3bd80\"><p local-id=\"c1df71d8-1381-4593-8f26-e7f025b2ec13\">336</p></td></tr></tbody></table>","representation":"storage","embeddedContent":[],"_expandable":{"content"