e":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2757296194/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2757296194","tinyui":"/x/QgBZp","editui":"/pages/resumedraft.action?draftId=2757296194","webui":"/spaces/BAN/pages/2757296194/Archived+Initiatives","edituiv2":"/spaces/BAN/pages/edit-v2/2757296194"}},{"id":"2788033784","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2788033784","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjc4ODAzMzc4NA==","status":"current","title":"VisaQR","macroRenderedOutput":{},"extensions":{"position":172686666},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2788033784/restriction/byOperation","history":"/rest/api/content/2788033784/history","body":"","version":"","descendants":"/rest/api/content/2788033784/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2788033784/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2788033784","tinyui":"/x/_AQupg","editui":"/pages/resumedraft.action?draftId=2788033784","webui":"/spaces/BAN/pages/2788033784/VisaQR","edituiv2":"/spaces/BAN/pages/edit-v2/2788033784"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"caa449dc-2c7a-4071-aae4-72fe5638c12a\"><colgroup><col style=\"width: 434.0px;\" /><col style=\"width: 167.0px;\" /><col style=\"width: 159.0px;\" /></colgroup><tbody><tr><th><p><strong>Tarea</strong></p></th><th><p><strong>Estimaci&oacute;n (d&iacute;as) </strong></p></th><th><p><strong>Epica</strong></p></th></tr><tr><td><p>Crear el modelo de merchants en db</p></td><td><p>1</p></td><td><p>setup / onboarding</p></td></tr><tr><td><p>Crear el modelo en terminales db de terminales</p></td><td><p>1</p></td><td><p>setup / onboarding</p></td></tr><tr><td><p>Agregar la operaci&oacute;n MerchantOnboarding para crear el merchant en HST (external-services)</p></td><td><p>4</p></td><td><p>setup / onboarding</p></td></tr><tr><td><p>Modificar el endpoint de creaci&oacute;n de comercio para que llame a HST para crear el merchant</p></td><td><p>3</p></td><td><p>setup / onboarding</p></td></tr><tr><td><p>Agregar la operaci&oacute;n para registrar terminal en external-services</p></td><td><p>4</p></td><td><p>setup / onboarding</p></td></tr><tr><td><p>Agregar operaci&oacute;n para consultar terminal en external-services</p></td><td><p>4</p></td><td><p>setup / onboarding</p></td></tr><tr><td><p>Agregar operaci&oacute;n para borrar terminal en external-services</p></td><td><p>4</p></td><td><p>setup / onboarding</p></td></tr><tr><td><p>Agregar operaci&oacute;n para actualizar terminal en external-services</p></td><td><p>4</p></td><td><p>setup / onboarding</p></td></tr><tr><td><p>Agregar operaci&oacute;n para consultar la configuraci&oacute;n de la terminal en external-services</p></td><td><p>4</p></td><td><p>setup / onboarding</p></td></tr><tr><td><p>Agregar operaci&oacute;n para consultar el status de la terminal en external-services</p></td><td><p>4</p></td><td><p>setup / onboarding</p></td></tr><tr><td><p>Crear endpoint en commerce-service para cargar terminales nuevas </p><p>Tener en cuenta que hay que crear por defecto una terminal por comercio/sucursal para utilizar siempre que el QR no sea generado desde un POS</p></td><td><p>2</p></td><td><p>setup / onboarding</p></td></tr><tr><td><p>Cargar merchants existentes a HST</p></td><td><p>2</p></td><td><p>setup / onboarding</p></td></tr><tr><td><p>Cambiar formato QR en creaci&oacute;n para que sea compatible con HST (bancard-commons)</p><p /><p>Nota: Asegurar compatibilidad hacia atras.</p></td><td><p>6</p></td><td><p>transaccional </p></td></tr><tr><td><p>Modificar el decode de QRs para decodificar los nuevos QRs (bancard-commons)</p><p /><p>Nota: Asegurar compatibilidad hacia atras.</p></td><td><p>6</p></td><td><p>transaccional </p></td></tr><tr><td><p>Cambios en generaci&oacute;n de QR &rarr; Express y comercio con nueva info (selling-service)</p><p>Los qr de comercio que ya est&aacute;n generados, no se regeneran, salvo que se llame al endpoint de generaci&oacute;n.</p><p>Los nuevos comercios ya generan con nuevos parametros</p></td><td><p>4</p></td><td><p>transaccional </p></td></tr><tr><td><p>Cambiar QR en tpago para codificaci&oacute;n y lectura de QR sea igual para todos </p></td><td><p>4</p></td><td><p>transaccional</p></td></tr><tr><td><p>Cambios QR en mpos </p></td><td><p>8</p></td><td><p>transaccional</p></td></tr><tr><td><p>Revisar TPago y MPos para ver impacto que tiene y que cambios habr&iacute;a que hacer para cambiar los flujos de confirmaci&oacute;n</p></td><td><p>1</p></td><td><p>transaccional</p></td></tr><tr><td><p>Agregar endpoint en selling-service para la confirmaci&oacute;n</p></td><td><p>4</p></td><td><p>transaccional</p></td></tr><tr><td><p>Agregar endpoint en payment-link-service para la confirmaci&oacute;n O agregar validaci&oacute;n en billing proxy para no confirmar pagos de Tpago por ese endpoint.</p></td><td><p>3 o 1</p></td><td><p>transaccional</p></td></tr><tr><td><p>Agregar endpoint en mpos-service para la confirmaci&oacute;n O agregar validaci&oacute;n en billing proxy para no confirmar pagos de MPOS por ese endpoint.</p></td><td><p>4 o 1</p></td><td><p>transaccional</p></td></tr><tr><td><p>Agregar endpoint billing-proxy para la confirmaci&oacute;n de HST.</p></td><td><p>3</p></td><td><p>transaccional</p></td></tr><tr><td><p>Configurar nginx para que cierto endpoint valide el certificado de autenticaci&oacute;n</p></td><td><p><ac:link><ri:user ri:account-id=\"557058:93ee8e9b-2ed8-4f84-9650-d77f20c62592\" /></ac:link> </p></td><td><p>transaccional</p></td></tr><tr><td><p>Agregar opci&oacute;n para que merchant pueda actualizar QR desde VentasQR (validar)</p><p>4 dias endpoint de regenerar qr comercio</p><p>2 dias para agregar boton llaamr endpoint actualizar qr</p></td><td><p>6</p></td><td><p>transaccional</p></td></tr><tr><td><p>Validar si esta registrada la terminal al momento de generar el QR</p></td><td><p>2</p></td><td><p>transaccional</p></td></tr></tbody></table><p><strong>Total</strong>: <em>88 d&iacute;as </em></p>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/2803728434"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":799},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2803728434/child","restrictions":"/rest/api/content/2803728434/restriction/byOperation","history":"/rest/api/content/2803728434/history","draftVersion":"","descendants":"/rest/api/content/2803728434/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=2803728434","webui":"/spaces/BAN/pages/2803728434/VisaQR+-+Tasking+y+Estimaciones","edituiv2":"/spaces/BAN/pages/edit-v2/2803728434","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/2803728434","tinyui":"/x/MoAdpw","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}