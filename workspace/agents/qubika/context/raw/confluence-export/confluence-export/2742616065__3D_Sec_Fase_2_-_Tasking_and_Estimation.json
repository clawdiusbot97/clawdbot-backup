t/api/content/2742484993/history","body":"","version":"","descendants":"/rest/api/content/2742484993/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2742484993/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2742484993","tinyui":"/x/AQB3ow","editui":"/pages/resumedraft.action?draftId=2742484993","webui":"/spaces/BAN/pages/2742484993/3D+Sec+Fase+2","edituiv2":"/spaces/BAN/pages/edit-v2/2742484993"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"bb95d958-acaa-40d6-9cf8-d8224fc83092\"><colgroup><col style=\"width: 151.0px;\" /><col style=\"width: 425.0px;\" /><col style=\"width: 76.0px;\" /><col style=\"width: 108.0px;\" /></colgroup><tbody><tr><th><p><strong>&Eacute;pica</strong></p></th><th><p><strong>Tarea</strong></p></th><th><p><strong>Hrs.</strong></p></th><th><p><strong>Servicio</strong></p></th></tr><tr><td rowspan=\"2\"><p><a href=\"https://bancard.atlassian.net/browse/PAF-30?atlOrigin=eyJpIjoiM2MzMWZjYjZjMjYyNGZmMTgwZTE2MGEwNTkzMjMwN2IiLCJwIjoiaiJ9\">Investigaci&oacute;n</a></p></td><td><p>Investigar como podemos hacer la comunicaci&oacute;n con un servicio RPG. (no existe mucha informaci&oacute;n respecto a esto)</p></td><td><p>16</p></td><td><p /></td></tr><tr><td><p>Hacer POC de comunicaci&oacute;n con servicio RPG desde Ruby.</p></td><td><p>20</p></td><td><p /></td></tr><tr><td><p><a href=\"https://bancard.atlassian.net/browse/PAF-8?atlOrigin=eyJpIjoiM2YxNzdmYzBhMTUyNGY0MGI0MGFkYzVjNTM0YjUyYjYiLCJwIjoiaiJ9\">Implementaci&oacute;n</a></p></td><td><p>Crear base de gema para comunicaci&oacute;n con servicios RPG.</p></td><td><p>12</p></td><td><p /></td></tr><tr><td><p /></td><td><p>Implementar comunicaci&oacute;n con servicio RPG para catastro.</p></td><td><p>32</p></td><td><p /></td></tr><tr><td><p /></td><td><p>Implementar comunicaci&oacute;n con servicio RPG para consulta de TC</p></td><td><p>24</p></td><td><p /></td></tr><tr><td><p /></td><td><p>Agregar columna para indicar si desarroll&oacute; el pago con token con 3DS</p></td><td><p>4</p></td><td><p>vpos-service</p></td></tr><tr><td><p /></td><td><p>Agregar columna para indicar si firm&oacute; la adenda para bypassear 3DS para los pagos en los que la tarjeta no fue catastrada con 3DS</p></td><td><p>4</p></td><td><p>vpos-service</p></td></tr><tr><td><p /></td><td data-highlight-colour=\"#ffffff\"><p>Modificar operaci&oacute;n de pay_with_alias_token para que haga la validaci&oacute;n de si va a ser con cardinal o no el pago.</p><p>Si es buy, crear el pago con estado pendiente cardinal</p></td><td data-highlight-colour=\"#ffffff\"><p>24</p></td><td><p>vpos-service</p></td></tr><tr><td><p /></td><td data-highlight-colour=\"#ffffff\"><p>Modificar operaci&oacute;n de multibuy_with_alias_token para que haga la validaci&oacute;n de si va a ser con cardinal o no el pago.</p><p>Si es buy, crear el pago con estado pendiente cardinal</p><p>(aca hay que guardar toda la informaci&oacute;n (sensible de la tarjeta?) del comercio cuando recibimos el pago, porque luego no la vmoas a recibir)</p></td><td data-highlight-colour=\"#ffffff\"><p>24</p></td><td><p>vpos-service</p></td></tr><tr><td><p /></td><td data-highlight-colour=\"#ffffff\"><p>Implementar la integraci&oacute;n con el RPG para consultar la info de la tarjeta</p></td><td data-highlight-colour=\"#ffffff\"><p>24</p></td><td><p>external-services o gema nueva</p></td></tr><tr><td><p /></td><td data-highlight-colour=\"#ffffff\"><p>Implementar comunicaci&oacute;n con servicio JPOS visa token</p></td><td data-highlight-colour=\"#ffffff\"><p>32</p></td><td><p /></td></tr><tr><td><p /></td><td data-highlight-colour=\"#ffffff\"><p>Modificar endpoint de lookup para que si es un pago con token haga todo el flujo nuevo (consultar info de la tarjeta, que por ser pago con token no la tenemos, y con esa info llamar al lookup) </p></td><td data-highlight-colour=\"#ffffff\"><p>24</p></td><td><p>vpos-service</p></td></tr><tr><td><p /></td><td data-highlight-colour=\"#ffffff\"><p>Agregar el endpoint para terminar de procesar el pago con token</p></td><td data-highlight-colour=\"#ffffff\"><p>32</p></td><td><p>vpos-service</p></td></tr><tr><td><p /></td><td data-highlight-colour=\"#ffffff\"><p>Agregar el iFrame en Bancard_connectors</p></td><td data-highlight-colour=\"#ffffff\"><p>24</p></td><td><p /></td></tr><tr><td><p /></td><td data-highlight-colour=\"#ffffff\"><p>Agregar el iFrame en Bancard_checkout_js</p></td><td data-highlight-colour=\"#ffffff\"><p>16</p></td><td><p /></td></tr><tr><td><p /></td><td><p>Modificar endpoint de register_card para que no llame al jpos si es una tarjeta local. Y que llame al servicio RPG en el caso de que el catastro no requiera validaci&oacute;n con 3D Sec.</p></td><td><p>32</p></td><td><p>vpos-service</p></td></tr><tr><td><p /></td><td><p>Modificar endpoint validate_register_card_for_3dsec_with_cmpi_authenticate para que llame al servicio RPG cuando un catastro de tarjeta se valid&oacute; de forma exitosa.<span style=\"color: rgb(255,255,255);\">12:11P h</span></p></td><td><p>32</p></td><td><p /></td></tr><tr><td><p /></td><td><p>Quitar consumo y logica alrededor de la flag 'international_card_registration' del controller y js del flujo de catastro</p></td><td><p>4</p></td><td><p /></td></tr><tr><td><p /></td><td><p>Refactorear la logica if else-if que existe hoy en dia para discriminar a que tipo de tarjeta mostrar cvv, c&eacute;dula y datos adicionales</p></td><td><p>4</p></td><td><p /></td></tr><tr><td><p /></td><td><p>Quitar flag de 'international_card_registration' del codigo, asi como tambien logica y quitarlo de parametro en varios endpoints, ya que esa flag no se utilizar&aacute; mas</p></td><td><p>4</p></td><td><p /></td></tr><tr><td><p /></td><td><p>Agregar una columna en el modelo 'card_request' para guardar un dato de boleta que devuelve el ultimo servicio JPOS que aprueba el catastro</p></td><td><p>4</p></td><td><p /></td></tr><tr><td rowspan=\"4\"><p><a href=\"https://bancard.atlassian.net/browse/PAF-18?atlOrigin=eyJpIjoiODBmOGIzMTBjMjZkNGU0MmIzZWY1NmM2NWRkMGRkNTYiLCJwIjoiaiJ9\">Vista vpos-portal</a></p></td><td><p>Crear la vista en vpos-portal para cargar el ddc (device data collector), cargar el ddc y abrir el listener para el mensaje que devuelve cuando termina de recolectar la data</p><p><em>Investigar lo del load</em></p></td><td><p>24</p></td><td><p>vpos-portal</p></td></tr><tr><td><p>Integrar con operaci&oacute;n para confirmar el pago con token</p></td><td><p>16</p></td><td><p>vpos-portal</p></td></tr><tr><td><p>Llamar al lookup desde vpos-portal y en caso de ser necesario levantar el iFrame del challenge y abrir los WebSockets. En el caso de ser frictionless llamar a la operaci&oacute;n de confirmaci&oacute;n de pago. </p></td><td><p>24</p></td><td><p>vpos-portal</p></td></tr><tr><td><p>En el caso de que se haya requerido el challenge, cuando recibimos el callback por el socket, llamamos a la operaci&oacute;n de confirmaci&oacute;n de pago. </p></td><td><p>16</p></td><td><p>vpos-portal</p></td></tr><tr><td data-highlight-colour=\"#f4f5f7\"><p /></td><td data-highlight-colour=\"#f4f5f7\"><p>Management</p></td><td data-highlight-colour=\"#f4f5f7\"><p>48h</p></td><td data-highlight-colour=\"#f4f5f7\"><p>6d</p></td></tr><tr><td data-highlight-colour=\"#e3fcef\" colspan=\"2\"><p>Total</p></td><td data-highlight-colour=\"#e3fcef\"><p>472h</p></td><td data-highlight-colour=\"#e3fcef\"><p>59d</p></td></tr><tr><td data-highlight-colour=\"#f4f5f7\" colspan=\"2\"><p>Total + Management <em>(esto no afecta la duraci&oacute;n del proyecto)</em></p></td><td data-highlight-colour=\"#f4f5f7\" colspan=\"2\"><p>520h</p></td></tr></tbody></table><h3>Fecha de Fin estimada</h3><ac:structured-macro ac:name=\"info\" ac:schema-version=\"1\" ac:macro-id=\"35ec87d3-7755-4fcb-a385-50d0dced0212\"><ac:rich-text-body><p>Teniendo en cuenta las tareas ya culminadas, al d&iacute;a de hoy nos quedan 52 d&iacute;as de trabajo. La tabla de abajo representa la fecha tentativa de fin, dependiendo la fecha de cuando se una el segundo recurso al proyecto.</p></ac:rich-text-body></ac:structured-macro><p> </p><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"e5bb6230-1d38-481a-9f28-89df2e294de5\"><tbody><tr><th><p><strong>Fecha Inicio 2do recurso</strong></p></th><th><p><strong>D&iacute;as solo </strong><ac:link><ri:user ri:account-id=\"612e2e8063f7bb006976b761\" /></ac:link> </p></th><th><p><strong>D&iacute;as en conjunto</strong></p></th><th><p><strong>Fecha Fin</strong></p></th></tr><tr><td><p><time datetime=\"2024-02-13\" /> </p></td><td><p>5</p></td><td><p>47 / 2 = 24</p></td><td><p><time datetime=\"2024-03-15\" /> </p></td></tr><tr><td><p><time datetime=\"2024-02-19\" /> </p></td><td><p>9</p></td><td><p>43 / 2 = 22</p></td><td><p><time datetime=\"2024-03-19\" /> </p></td></tr><tr><td><p><time datetime=\"2024-02-26\" /> </p></td><td><p>14</p></td><td><p>38 / 2 = 19</p></td><td><p><time datetime=\"2024-03-19\" /> </p></td></tr><tr><td><p><time datetime=\"2024-03-04\" /> </p></td><td><p>19</p></td><td><p>33 / 2 = 17</p></td><td><p><time datetime=\"2024-03-26\" /> </p></td></tr></tbody></table><p />","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/2742616065"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":392308738},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2742616065/child","restrictions":"/rest/api/content/2742616065/restriction/byOperation","history":"/rest/api/content/2742616065/history","draftVersion":"","descendants":"/rest/api/content/2742616065/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=2742616065","webui":"/spaces/BAN/pages/2742616065/3D+Sec+Fase+2+-+Tasking+and+Estimation","edituiv2":"/spaces/BAN/pages/edit-v2/2742616065","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/2742616065","tinyui":"/x/AQB5ow","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}