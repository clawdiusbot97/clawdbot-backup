7005/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2760147005/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2760147005","tinyui":"/x/PYCEp","editui":"/pages/resumedraft.action?draftId=2760147005","webui":"/spaces/BAN/pages/2760147005/Iniciativas+en+Curso","edituiv2":"/spaces/BAN/pages/edit-v2/2760147005"}},{"id":"4740612105","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/4740612105","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvNDc0MDYxMjEwNQ==","status":"current","title":"Tokenizacion en API Entidades","macroRenderedOutput":{},"extensions":{"position":10596452},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/4740612105/restriction/byOperation","history":"/rest/api/content/4740612105/history","body":"","version":"","descendants":"/rest/api/content/4740612105/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/4740612105/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/4740612105","tinyui":"/x/CQCQGgE","editui":"/pages/resumedraft.action?draftId=4740612105","webui":"/spaces/BAN/pages/4740612105/Tokenizacion+en+API+Entidades","edituiv2":"/spaces/BAN/pages/edit-v2/4740612105"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<ac:structured-macro ac:name=\"info\" ac:schema-version=\"1\" ac:local-id=\"8673954d-a67d-47af-be2e-1b87d8481c0f\" ac:macro-id=\"ac160b4e-ea0a-43a0-a594-7c594a0c3831\"><ac:rich-text-body><p local-id=\"49d9daf4-ae54-4a3e-a4a7-24c3ff515ab0\">Este documento representa el tasking y estimaci&oacute;n para Tokenizaci&oacute;n en API Entidades, a cargo de <ac:link><ri:user ri:account-id=\"622640bedb58c100687be853\" ri:local-id=\"8ffc45cc-6956-400d-a3ca-61f9c116926f\" /></ac:link> y <ac:link><ri:user ri:account-id=\"712020:bd6be9b3-2ff0-412b-8fb1-57e9e188f6cf\" ri:local-id=\"a322c866-d070-4e05-b591-26b2638f1680\" /></ac:link> .</p><p local-id=\"b04d02f8-52d3-4b24-9cd1-6aa38421df6f\">Las horas estimadas son: </p><p local-id=\"be1cb692-84b2-48d3-9b3c-737a4a91a1eb\"><ac:inline-comment-marker ac:ref=\"ec2ee111-2cf6-4aa7-b6bd-bf288b55d9a4\">Fecha de Inicio: </ac:inline-comment-marker><strong>Mi&eacute;rcoles</strong> <time datetime=\"2026-01-28\" local-id=\"dfc295b56e82\" /></p><p local-id=\"accaebab-6e1b-4409-a1ba-b5c2231d16b9\">Fecha de Entrega: <strong>Mi&eacute;rcoles</strong> <time datetime=\"2026-02-04\" local-id=\"5f50ba0a6aed\" />  </p></ac:rich-text-body></ac:structured-macro><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"e2353a1a8077\"><colgroup><col style=\"width: 545.0px;\" /><col style=\"width: 215.0px;\" /></colgroup><tbody><tr ac:local-id=\"ce047b7b-b8b5-4886-9c29-00a82f32ea74\"><th ac:local-id=\"96431746-1c7c-419f-91b9-1b02b6f4b2df\"><p local-id=\"b7bed96bf45b\"><strong>Tarea</strong></p></th><th ac:local-id=\"ed975729-efb7-41b2-b340-68d2c15c6c91\"><p local-id=\"06ea1119f63d\" style=\"text-align: center;\"><strong>Estimaci&oacute;n (hs)</strong></p></th></tr><tr ac:local-id=\"9982c01c-1bca-4241-994e-5d4e7db4e625\"><td ac:local-id=\"7da28b61-6faa-4e22-b038-6349b27eae34\"><p local-id=\"1f772df7409b\"><strong>Integraci&oacute;n con RPG para tokenizaci&oacute;n:</strong></p><ul local-id=\"dbdb4831ca5d\"><li local-id=\"c90fb2f1-636f-4dc9-b8e9-6d0bca7cf0d1\"><p local-id=\"fb004b4dd676\">Implementar comunicacion con RPG. Crear archivo de configuraci&oacute;n de la operaci&oacute;n. Implementar m&eacute;todo en <code>Services:Rpg</code></p></li><li local-id=\"f765451072b5\"><p local-id=\"e837e1e6cb2e\">Ajustar configuraci&oacute;n para poder acceder desde local.</p></li><li local-id=\"5d4ac083-2294-4f1b-b9ce-dc6ee121ca89\"><p local-id=\"79af00778a37\">Mensajes de error. Mapear c&oacute;digos de error de RPG a mensajes. Manejo de las excepciones.</p></li><li local-id=\"dbe7797d-d170-4c31-9a53-5955cbf4a8ba\"><p local-id=\"074e0bd61920\">&ldquo;00&rdquo; tokenizaci&oacute;n exitosa. Para el resto de c&oacute;digos hacer un diccionario de errores. En caso de que no este en el diccionario, devolver un error gen&eacute;rico.</p></li></ul></td><td ac:local-id=\"945b1d8e-0b6a-4168-8f89-0e2345a6f010\"><p local-id=\"dfba5d18b1db\" style=\"text-align: center;\">10</p></td></tr><tr ac:local-id=\"e8ed383f-8d87-45b8-85fb-28bf32f8395d\"><td ac:local-id=\"d095c3b0-aef3-4b2a-bc57-60f4ab9982c6\"><p local-id=\"c955f9d6f4c0\">Endpoint de tokenizaci&oacute;n</p><ul local-id=\"7b6f38cf129b\"><li local-id=\"a5c3ad35f5fd\"><p local-id=\"fa0073bb2ce2\">Definir operation</p></li><li local-id=\"6c8b53ceb8e5\"><p local-id=\"75edc2c3dff4\">Validar parametros de entrada</p></li><li local-id=\"51de8db7c493\"><p local-id=\"f9162b1a6782\">Llamar al RPG.</p></li><li local-id=\"43efdc91-308d-43f3-815a-6ed17e5301b8\"><p local-id=\"15387a119978\">Crear registro en tabla <code>transactions_log</code>con <code>transaction_type</code>, <code>transaction_stage</code>, <code>entity_transaction_id</code>, <code>body</code>.  EN el body incluir request enmascarado y el response, sea cual sea la respuesta</p></li><li local-id=\"213e4ccaf1ef\"><p local-id=\"698f3295bb90\">Agregar tests.</p><ul local-id=\"1ce3c50d05b3\"><li local-id=\"e0b707d355fb\"><p local-id=\"601c76b029d3\">tokenizacion exitosa</p></li><li local-id=\"b7d12823-180c-47ae-b60f-fba75dbf30ba\"><p local-id=\"89eb9dd8e187\">parametros faltantes</p></li><li local-id=\"86801f5a-9895-487b-a375-733ec1267030\"><p local-id=\"9631de3a00de\">error de conexi&oacute;n</p></li><li local-id=\"d9360693-fa79-4d19-b978-60e3ddee2fea\"><p local-id=\"235578c87cf1\">CardNotAllowedError</p></li><li local-id=\"7732c698-d5aa-43dc-927c-fcd831effe2b\"><p local-id=\"270622f8431f\">TokenizeCardFailError</p></li></ul></li></ul></td><td ac:local-id=\"4c1c3642-5457-4dfc-8351-7be4c573a96c\"><p local-id=\"99163f0fa5c2\" style=\"text-align: center;\">14</p></td></tr><tr ac:local-id=\"c946846d869b\"><td ac:local-id=\"b153495f42cd\"><p local-id=\"a0457fd1a9a5\">Crear constantes en BancardConstants para <code>transaction_type</code> y <code>transaction_stage</code></p></td><td ac:local-id=\"53b965325444\"><p local-id=\"6e352625d931\" style=\"text-align: center;\">1</p></td></tr><tr ac:local-id=\"aadaa40f-9cd0-4799-9f63-25e71b2c45c8\"><td ac:local-id=\"b6aeda72-023e-4b8b-91d3-8bdcae63803e\"><p local-id=\"22675f9f52ea\">Salida a Staging</p><ul local-id=\"e16eb084-7974-4a1f-bdf3-027f60020b85\"><li local-id=\"f7fc03d5-b14e-46da-a0e2-7e7f55ba9bc7\"><p local-id=\"b064da801656\">Integraci&oacute;n de los flujos</p></li><li local-id=\"09622880-cbfb-4366-ab5d-fd8c472449a7\"><p local-id=\"06b32ecc05fb\">Creaci&oacute;n y correci&oacute;n de PRs</p></li><li local-id=\"6c139cb6-5b08-4c9e-a092-12fc52e29ab9\"><p local-id=\"4f6cf6894dda\">Pruebas locales</p></li><li local-id=\"41819359-673a-48ed-81a0-4b80b5c84a6c\"><p local-id=\"72a8ac8e271a\">Armado de ramas</p></li><li local-id=\"3eb54f1d-ad49-468b-85aa-9c563971a1d9\"><p local-id=\"bfcac81e0872\">Deploy a STG</p></li><li local-id=\"ee370d5b-2c17-40d9-9203-43de6cb71047\"><p local-id=\"e2a40cf24864\">Pruebas iniciales en STG</p></li></ul></td><td ac:local-id=\"5a5ce161-0d8b-46b6-b03f-27a669e2126f\"><p local-id=\"dab25855331a\" style=\"text-align: center;\">8</p></td></tr><tr ac:local-id=\"4ea865ed-eb9b-4221-b1b8-6e889f0900ae\"><td data-highlight-colour=\"#eae6ff\" ac:local-id=\"45e73a17-1f62-4e8a-b6ac-9b6d6ec21ba1\"><p local-id=\"2517c5d628a7\"><strong>Total Desarrollo</strong></p></td><td data-highlight-colour=\"#eae6ff\" ac:local-id=\"97edcc0f-eaac-4d70-8f8a-1a8bfc6f4f7c\"><p local-id=\"5af985c4653b\" style=\"text-align: center;\">33</p></td></tr><tr ac:local-id=\"edd23744-7fea-4488-b0e6-5c90cde14a9e\"><td data-highlight-colour=\"#eae6ff\" ac:local-id=\"b177d938-47b1-48a9-a773-6b9affd79d5c\"><p local-id=\"d9ca9112967d\"><strong>Total Gesti&oacute;n 15% (para facturaci&oacute;n, no afecta el desarrollo)</strong></p><p local-id=\"d61dca399fe1\"><em>Incluye reuniones de estimaci&oacute;n, planificaci&oacute;n, t&eacute;cnicas y de seguimiento.</em></p></td><td data-highlight-colour=\"#eae6ff\" ac:local-id=\"1329d2de-1d28-4e47-bf91-5312c1192599\"><p local-id=\"a90f94af8f29\" style=\"text-align: center;\">5</p></td></tr><tr ac:local-id=\"75628324-9c3b-40a1-aeb6-bd7cf6c8a9a9\"><td data-highlight-colour=\"#eae6ff\" ac:local-id=\"85c16c83-8ff4-47ff-bb9e-b6363e5fc428\"><p local-id=\"eb87bd7e433e\"><strong>Total Desarrollo + Gesti&oacute;n</strong></p></td><td data-highlight-colour=\"#eae6ff\" ac:local-id=\"f7f4fdfc-3d9d-4105-8f96-8a6af4ff3b21\"><p local-id=\"777f9fef466b\" style=\"text-align: center;\">38</p></td></tr></tbody></table>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/4741693441"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":419784310},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/4741693441/child","restrictions":"/rest/api/content/4741693441/restriction/byOperation","history":"/rest/api/content/4741693441/history","draftVersion":"","descendants":"/rest/api/content/4741693441/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=4741693441","webui":"/spaces/BAN/pages/4741693441/Tokenizaci+n+API+Entidades+BEPSA+-+Tasking+y+Estimaci+n","edituiv2":"/spaces/BAN/pages/edit-v2/4741693441","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/4741693441","tinyui":"/x/AYCgGgE","collection":"/rest/api/content","base