/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2760147005/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2760147005","tinyui":"/x/PYCEp","editui":"/pages/resumedraft.action?draftId=2760147005","webui":"/spaces/BAN/pages/2760147005/Iniciativas+en+Curso","edituiv2":"/spaces/BAN/pages/edit-v2/2760147005"}},{"id":"4487741468","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/4487741468","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvNDQ4Nzc0MTQ2OA==","status":"current","title":"Migrar Cardinal 3DS a Cybersource 3DS","macroRenderedOutput":{},"extensions":{"position":156},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/4487741468/restriction/byOperation","history":"/rest/api/content/4487741468/history","body":"","version":"","descendants":"/rest/api/content/4487741468/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/4487741468/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/4487741468","tinyui":"/x/HIB9CwE","editui":"/pages/resumedraft.action?draftId=4487741468","webui":"/spaces/BAN/pages/4487741468/Migrar+Cardinal+3DS+a+Cybersource+3DS","edituiv2":"/spaces/BAN/pages/edit-v2/4487741468"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<p local-id=\"ee77a661-bc61-48eb-901a-82ee7033d11e\">Utilizando el accessToken y ddcFormUrl Recibidos en el Step 1, debemos completar y submittear el ddcForm via Javascript. Este proceso debe completarse previo a iniciar el Step 3</p><p local-id=\"f3f5cb7b-0c84-4c50-bab0-551d526f77e8\" /><h1 local-id=\"250d2245-8375-4eea-a0b3-ec8bf5459ec3\">DDC Iframe y Form:<br /></h1><p local-id=\"6d8dafa1-d8f5-4eee-8687-ca0ad06f3a80\">Se debe incorporar estos tags HTML a la vista del pago. Est&aacute;n ocultos, por lo que no interfieren con el renderizado del DOM.</p><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:local-id=\"5966c863-c81c-47ed-a822-223bda89c456\" ac:macro-id=\"b6d9dc8e-4eb0-444e-a3da-1b6eb903e9f6\"><ac:parameter ac:name=\"breakoutMode\">wide</ac:parameter><ac:parameter ac:name=\"breakoutWidth\">760</ac:parameter><ac:plain-text-body><![CDATA[<iframe id=\"cardinal_collection_iframe\" name=\"collectionIframe\" height=\"10\" width=\"10\" style=\"display: none;\"></iframe>\n<form id=\"cardinal_collection_form\" method=\"POST\" target=\"collectionIframe\" action=\"\">\n  <input id=\"cardinal_collection_form_input\" type=\"hidden\" name=\"JWT\" value=\"\">\n</form>                         ]]></ac:plain-text-body></ac:structured-macro><h1 local-id=\"44040f1f-ddaa-4164-af4b-6cb1f663ed04\">Completado y submit del ddcForm</h1><p local-id=\"1ee4b0fc-83ff-4f22-b195-0f5349ed2bc2\">Desde el javascript ya se dispar&oacute; el Step 1 y se obtuvo una respuesta. Posterior a ello, se debe ejecutar la siguiente funci&oacute;n para completar y submittear el collection form</p><p local-id=\"8c332fe1-532e-4722-afb8-a4ddfc613a28\" /><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:local-id=\"40cbda42-a1d0-40c5-9ebf-4bce3433b3b2\" ac:macro-id=\"4e6d0f23-b747-43fd-980e-d211ab9cdfc2\"><ac:parameter ac:name=\"breakoutMode\">wide</ac:parameter><ac:parameter ac:name=\"breakoutWidth\">760</ac:parameter><ac:plain-text-body><![CDATA[<script>\n  function(ddcUrl, ddcJwt) { \n  var cardinalCollectionForm = document.querySelector('#cardinal_collection_form');\n  var cardinalJwtInputField = document.querySelector('#cardinal_collection_form_input');\n  \n  // Imponer ddcUrl y ddcJwt\n  cardinalCollectionForm.action = ddcUrl;\n  cardinalJwtInputField.value = ddcJwt;\n\n  //Submit de formulario\n  cardinalCollectionForm.submit();\n</script>\n]]></ac:plain-text-body></ac:structured-macro><p local-id=\"bbcaf5cd-7ebf-411b-9cde-65dc2768ad4f\" /><p local-id=\"8300dc65-e568-4575-b5e7-5d6b91f15a79\">Al completarse el proceso de submit, el iframe emitir&aacute; un message que se puede capturar de la siguiente manera para comenzar el Step 3:<br /></p><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:local-id=\"01aa5282-7862-4b7d-8b9a-5b631cb22923\" ac:macro-id=\"220ba00b-2c1e-4ac5-b927-8621e0c1a738\"><ac:parameter ac:name=\"breakoutMode\">wide</ac:parameter><ac:parameter ac:name=\"breakoutWidth\">760</ac:parameter><ac:plain-text-body><![CDATA[window.addEventListener(\"message\", function(event) {\n  if (event.origin === https://centinelapistag.cardinalcommerce.com) {\n    console.log(event.data);\n  }\n}, false);\n\n// Contenido del Message:\n//{\n//  \"MessageType\": \"profile.completed\",\n//  \"Session Id\": \"f54ea591-51ac-48de-b908-eecf4ff6beff\",\n//  \"Status\": true\n//} Nada de esto se requiere mas adelante, pero el status da luz vede para el Step 3]]></ac:plain-text-body></ac:structured-macro><blockquote local-id=\"aa44b03e-725e-4c33-bf1a-ad353dcde6df\"><p local-id=\"e029931d-e74f-46ac-93e2-c2dd149d4992\">La url de origen debe ser acorde al ambiente de trabajo</p><p local-id=\"c69e433e-c4f1-4bd0-8f0d-1a72b4a14367\">Test: <a href=\"https://centinelapistag.cardinalcommerce.com\">https://centinelapistag.cardinalcommerce.com</a></p><p local-id=\"b01aed53-c073-48fa-a49c-ad09d6aca986\">Prod: <a href=\"https://centinelapi.cardinalcommerce.com\">https://centinelapi.cardinalcommerce.com</a></p></blockquote><p local-id=\"007413c4-6ba9-42fb-8fac-f3695e71672b\" />","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/4492886033"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":746},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/4492886033/child","restrictions":"/rest/api/content/4492886033/restriction/byOperation","history":"/rest/api/content/4492886033/history","draftVersion":"","descendants":"/rest/api/content/4492886033/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=4492886033","webui":"/spaces/BAN/pages/4492886033/STEP+2+-+Actualizar+DDC","edituiv2":"/spaces/BAN/pages/edit-v2/4492886033","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/4492886033","tinyui":"/x/EQDMCwE","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}