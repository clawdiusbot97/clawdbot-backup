Info":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2794160273/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2794160273","tinyui":"/x/kYCLpg","editui":"/pages/resumedraft.action?draftId=2794160273","webui":"/spaces/BAN/pages/2794160273/Servicios+de+Bancard","edituiv2":"/spaces/BAN/pages/edit-v2/2794160273"}},{"id":"2330099727","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2330099727","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjMzMDA5OTcyNw==","status":"current","title":"Auth Service","macroRenderedOutput":{},"extensions":{"position":163425727},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2330099727/restriction/byOperation","history":"/rest/api/content/2330099727/history","body":"","version":"","descendants":"/rest/api/content/2330099727/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2330099727/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2330099727","tinyui":"/x/D4Diig","editui":"/pages/resumedraft.action?draftId=2330099727","webui":"/spaces/BAN/pages/2330099727/Auth+Service","edituiv2":"/spaces/BAN/pages/edit-v2/2330099727"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<ol start=\"1\"><li><p>Check the minor application_id value in the application_credentials table in auth-service database.<br /></p><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:macro-id=\"c47ecbf7-3f9d-4df6-ae83-8333f3a540c6\"><ac:plain-text-body><![CDATA[SELECT * FROM auth_service_production.application_credentials ORDER BY application_id;]]></ac:plain-text-body></ac:structured-macro><p>&nbsp;</p><ac:image ac:align=\"center\" ac:layout=\"center\" ac:original-height=\"46\" ac:original-width=\"914\" ac:width=\"646\"><ri:attachment ri:filename=\"Screen Shot 2022-12-15 at 14.26.47-20221215-172701.png\" ri:version-at-save=\"1\" /></ac:image><p>&nbsp;</p></li><li><p>Create a new application_credential using the auth-service API and send as application_id the previous number than the last one. In this case, -311.<br /></p><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:macro-id=\"6904ed0e-0dd6-40f2-8e2b-13af9ba89f03\"><ac:plain-text-body><![CDATA[curl --location --request POST 'https://10.100.14.73:4480/auth/api/0.2/application_credentials' \\\n--form 'application_id=\"-311\"'\n\nRESPONSE:\n{\n    \"status\": \"success\",\n    \"application_credential\": {\n        \"id\": 2723,\n        \"application_id\": -311,\n        \"private_key\": \"y1,c$0im(zqdg85k3FIUOJ4n,B8XclC9WGSFb2Uq\",\n        \"public_key\": \"xw1pdhLhgAoFyPhntATsckgSzWmW7kyJ\"\n    }\n}]]></ac:plain-text-body></ac:structured-macro></li><li><p>Add the corresponding credential_role to the created application_credential using as credential_identifier the string &ldquo;apps/&ldquo; followed by the public key.<br />In this case, &ldquo;apps/xw1pdhLhgAoFyPhntATsckgSzWmW7kyJ&ldquo;<br /></p><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:macro-id=\"ff4a1989-14dd-4f3a-bdc3-844bc2a6ae48\"><ac:plain-text-body><![CDATA[INSERT INTO `auth_service_production`.`credential_roles` (`role`, `credential_identifier`) VALUES ('bancard_service', 'apps/xw1pdhLhgAoFyPhntATsckgSzWmW7kyJ');]]></ac:plain-text-body></ac:structured-macro></li></ol>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/2818080786"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":1473},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2818080786/child","restrictions":"/rest/api/content/2818080786/restriction/byOperation","history":"/rest/api/content/2818080786/history","draftVersion":"","descendants":"/rest/api/content/2818080786/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=2818080786","webui":"/spaces/BAN/pages/2818080786/Create+Application","edituiv2":"/spaces/BAN/pages/edit-v2/2818080786","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/2818080786","tinyui":"/x/EoD4pw","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}