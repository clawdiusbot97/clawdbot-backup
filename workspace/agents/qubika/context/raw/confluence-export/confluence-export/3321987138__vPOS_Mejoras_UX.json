schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2760147005/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2760147005","tinyui":"/x/PYCEp","editui":"/pages/resumedraft.action?draftId=2760147005","webui":"/spaces/BAN/pages/2760147005/Iniciativas+en+Curso","edituiv2":"/spaces/BAN/pages/edit-v2/2760147005"}},{"id":"3233218577","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/3233218577","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMzIzMzIxODU3Nw==","status":"current","title":"VPos","macroRenderedOutput":{},"extensions":{"position":10592077},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/3233218577/restriction/byOperation","history":"/rest/api/content/3233218577/history","body":"","version":"","descendants":"/rest/api/content/3233218577/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3233218577/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/3233218577","tinyui":"/x/EQC3w","editui":"/pages/resumedraft.action?draftId=3233218577","webui":"/spaces/BAN/pages/3233218577/VPos","edituiv2":"/spaces/BAN/pages/edit-v2/3233218577"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"d127e8c3-3fed-4af2-bc1b-c09b7117def2\"><colgroup><col style=\"width: 395.0px;\" /><col style=\"width: 111.0px;\" /><col style=\"width: 253.0px;\" /></colgroup><tbody><tr><th><p><strong>Tarea</strong></p></th><th><p style=\"text-align: center;\"><strong>Estimaci&oacute;n (hs)</strong></p></th><th><p><strong>Servicio / Portal</strong></p></th></tr><tr><td><p>A&ntilde;adir estilos de forma a los inputs del iframe (bordes rounded, sharp, pill)<br /><br />Se agrega el dropdown select a la configuraci&oacute;n de vpos en el portal.</p></td><td><p>6</p></td><td><p>Commerce suite (configuraci&oacute;n)</p></td></tr><tr><td><p>A&ntilde;adir estilos de forma a los inputs del iframe (bordes rounded, sharp, pill)<br /><br />Agregar la l&oacute;gica para aceptar esta configuraci&oacute;n de los bordes a cada uno de los inputs.</p></td><td><p>16</p></td><td><p>vPOS portal (representaci&oacute;n final)</p></td></tr><tr><td><p>A&ntilde;adir estilos de forma a los inputs del iframe (bordes rounded, sharp, pill)</p><p>Determinar como manejar el guardado de estas configuraciones en la base de datos de vpos service.</p></td><td><p>6</p></td><td><p>vPOS service (base de datos)</p></td></tr><tr><td><p>Tipo de Fuente para texto<br /><br />Se agrega el dropdown select a la configuraci&oacute;n de vpos en el portal.<br /><br />Determinar que tipos de fuente queremos incluir **</p></td><td><p>8</p></td><td><p>Commerce Suite (configuraci&oacute;n)</p></td></tr><tr><td><p>Tipo de fuente para texto</p></td><td><p>12</p></td><td><p>vPOS portal (representaci&oacute;n final)</p></td></tr><tr><td><p>Tama&ntilde;o de Fuente para texto</p><p>Se agrega el dropdown select a la configuraci&oacute;n de vpos en el portal.</p><p>Determinar que tama&ntilde;os de fuente queremos incluir **</p></td><td><p>6</p></td><td><p>Commerce Suite (configuraci&oacute;n)</p></td></tr><tr><td><p>Tama&ntilde;o de fuente</p></td><td><p>12</p></td><td><p>vPOS portal (representaci&oacute;n final)</p></td></tr><tr><td><p>Tooltip para los tipos de tarjetas que acepta Bancard.<br /><br />En el input de n&uacute;mero de tarjeta se debe mostrar en el lado derecho las tarjetas que se aceptan desde Bancard.<br />En tama&ntilde;o escritorio se muestran Visa, Mastercard y AMEX fijas, y en 4 posici&oacute;n se muestra una &uacute;ltima que debe ir cambiando seg&uacute;n un lapso de tiempo determinado.<br />En tama&ntilde;o mobile se muestra solo un logo de tarjeta que debe ir cambiando seg&uacute;n determinado lapso de tiempo.<br /><br />En ambos casos al hacer hover sobre la opci&oacute;n que va cambiando se debe mostrar un tooltip con los logos de las tarjetas ocultas.</p></td><td><p>24</p></td><td><p>vPOS portal</p></td></tr><tr><td><p>A&ntilde;adir opci&oacute;n de configuraci&oacute;n para la posici&oacute;n de los placeholder/labels de los inputs (Above o flotante)</p></td><td><p>6</p></td><td><p>Commerce Suite (condifuraci&oacute;n)</p></td></tr><tr><td><p>Tomar configuraci&oacute;n de posici&oacute;n de los placeholders/labels y posicionarlos.<br />Tomar en cuenta el comportamiento de los placeholders en stripe que se posicionan en la parte superior de los inputs cuando hay un focus en tal.</p></td><td><p>24</p></td><td><p>vPOS portal</p></td></tr><tr><td><p>Agregar Tabs en la parte superior &lsquo;Card&rsquo;<br /> <br />(Tener en cuenta que en el futuro se planea agregar otros medios de pago, como en stripe)</p></td><td><p>8</p></td><td><p>vPOS portal</p></td></tr><tr><td><p>Color Danger<br /><br />Agregar configuraci&oacute;n para determinar el color del texto cuando hay alg&uacute;n error.<br />Dropdown con opciones *</p></td><td><p>6</p></td><td><p>Commerce Suite (configuraci&oacute;n)</p></td></tr><tr><td><p>Color Danger</p><p>Tomar la configuraci&oacute;n establecida para el texto de errores en el portal.</p></td><td><p>16</p></td><td><p>vPOS portal</p></td></tr><tr><td><p><code>iconCardCvcColor</code><br />Color del &iacute;cono del input CVC<br /><br />Agregar opciones para configurar el color de este &iacute;cono. **</p></td><td><p>6</p></td><td><p>Commerce Suite (configuraci&oacute;n)</p></td></tr><tr><td><p><code>iconCardCvcColor</code><br />Color del &iacute;cono del input CVC</p><p>Tomar la configuraci&oacute;n establecida para este item</p></td><td><p>8</p></td><td><p>vPOS portal</p></td></tr><tr><td><p><code>iconCardCvcErrorColor</code></p><p>Color del &iacute;cono del input CVC cuando hay un error</p></td><td><p>8</p></td><td><p>vPOS portal</p></td></tr><tr><td><p>Aceptar reglas en CSS puro por c&oacute;digo para el comportamiento bajo los eventos hover y focus para las tabs de la parte superior.<br />Se debe aceptar el CSS que el cliente env&iacute;e por c&oacute;digo para la personalizaci&oacute;n de estos elementos en esos eventos.</p></td><td><p>24</p></td><td><p>vPOS portal</p></td></tr><tr><td><p>Cambiar el flujo actual del proceso de catastro<br /><br />Remover el paso del bot&oacute;n &lsquo;Siguiente&rsquo; y mostrar los inputs necesarios para el flujo completo de catastro en la misma vista.</p></td><td><p>24</p></td><td><p>vPOS portal</p></td></tr><tr><td><p /></td><td><p /></td><td><p /></td></tr><tr><td data-highlight-colour=\"#eae6ff\"><p><strong>Total Desarrollo</strong></p></td><td data-highlight-colour=\"#eae6ff\"><p>190</p></td><td data-highlight-colour=\"#eae6ff\"><p /></td></tr><tr><td data-highlight-colour=\"#eae6ff\"><p><strong>Total Gesti&oacute;n 15% (para facturaci&oacute;n, no afecta el desarrollo)</strong></p><p><em>Incluye reuniones de estimaci&oacute;n, planificaci&oacute;n, t&eacute;cnicas y de seguimiento.</em></p></td><td data-highlight-colour=\"#eae6ff\"><p>28</p></td><td data-highlight-colour=\"#eae6ff\"><p /></td></tr><tr><td data-highlight-colour=\"#eae6ff\"><p><strong>Total Desarrollo + Gesti&oacute;n</strong></p></td><td data-highlight-colour=\"#eae6ff\"><p>218</p></td><td data-highlight-colour=\"#eae6ff\"><p /></td></tr></tbody></table><ac:adf-extension><ac:adf-node type=\"panel\"><ac:adf-attribute key=\"panel-type\">note</ac:adf-attribute><ac:adf-content><p>Preguntas</p></ac:adf-content></ac:adf-node><ac:adf-fallback><div class=\"panel conf-macro output-block\" style=\"background-color: rgb(234,230,255);border-color: rgb(153,141,217);border-width: 1.0px;\"><div class=\"panelContent\" style=\"background-color: rgb(234,230,255);\">\n<p>Preguntas</p>\n</div></div></ac:adf-fallback></ac:adf-extension><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"df39bc32-2722-40c6-b433-4529f0480f16\"><tbody><tr><td><p>&iquest;Qu&eacute; fuentes queremos incluir en las opciones para el iframe?</p></td><td><p /></td></tr><tr><td><p>Se debe definir el &iacute;cono del input CVC</p></td><td><p /></td></tr><tr><td><p /></td><td><p /></td></tr></tbody></table>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/3321987138"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":179688750},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3321987138/child","restrictions":"/rest/api/content/3321987138/restriction/byOperation","history":"/rest/api/content/3321987138/history","draftVersion":"","descendants":"/rest/api/content/3321987138/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=3321987138","webui":"/spaces/BAN/pages/3321987138/vPOS+Mejoras+UX","edituiv2":"/spaces/BAN/pages/edit-v2/3321987138","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/3321987138","tinyui":"/x/QoABxg","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}