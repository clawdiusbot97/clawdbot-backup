ontent/2760147005/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2760147005/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2760147005","tinyui":"/x/PYCEp","editui":"/pages/resumedraft.action?draftId=2760147005","webui":"/spaces/BAN/pages/2760147005/Iniciativas+en+Curso","edituiv2":"/spaces/BAN/pages/edit-v2/2760147005"}},{"id":"2685632513","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/2685632513","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMjY4NTYzMjUxMw==","status":"current","title":"Tpago","macroRenderedOutput":{},"extensions":{"position":10589376},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/2685632513/restriction/byOperation","history":"/rest/api/content/2685632513/history","body":"","version":"","descendants":"/rest/api/content/2685632513/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2685632513/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2685632513","tinyui":"/x/AYATo","editui":"/pages/resumedraft.action?draftId=2685632513","webui":"/spaces/BAN/pages/2685632513/Tpago","edituiv2":"/spaces/BAN/pages/edit-v2/2685632513"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<ac:structured-macro ac:name=\"info\" ac:schema-version=\"1\" ac:macro-id=\"ef27d4db-b243-4f24-b637-04847c885aeb\"><ac:rich-text-body><p>Estas son las estimaciones para las nuevas funcionalidades de Pagos Manuales, Actualizaci&oacute;n de Suscripciones y Borrado de Suscripciones.</p></ac:rich-text-body></ac:structured-macro><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"7e49184c-0ae8-48e7-8335-4723bebb7586\"><colgroup><col style=\"width: 151.0px;\" /><col style=\"width: 219.0px;\" /><col style=\"width: 104.0px;\" /><col style=\"width: 103.0px;\" /><col style=\"width: 178.0px;\" /></colgroup><tbody><tr><th><p><strong>Funcionalidad</strong></p></th><th><p><strong>Tarea</strong></p></th><th><p><strong>Estimaci&oacute;n (hs)</strong></p></th><th><p><strong>Estimaci&oacute;n (d&iacute;as)</strong></p></th><th><p><strong>Servicio / Portal</strong></p></th></tr><tr><td rowspan=\"7\"><p><strong>Pagos Manuales</strong></p></td><td><p>Crear el endpoint para crear Pagos Adelantados</p><ul><li><p><em>Crea un nuevo registro en la tabla de pagos con el nuevo estado &ldquo;Adelanto de Pago&ldquo;.</em></p></li><li><p><em>Debe actualizar la &uacute;ltima fecha de pago</em></p></li><li><p><em>No debe de pasar por el proceso de cobro.</em></p></li></ul></td><td><p style=\"text-align: center;\">36</p></td><td><p style=\"text-align: center;\">6</p></td><td><p>payment-link-service</p></td></tr><tr><td><p>Modificar la tabla de susbcriber_pauses para indicar que una pausa es por pagos adelantados</p></td><td><p style=\"text-align: center;\">12</p></td><td><p style=\"text-align: center;\">2</p></td><td><p>payment-link-service</p></td></tr><tr><td><p>Modificar el endpoint updateSuscriber para enviar si la pausa es por adelanto de pago o no. </p></td><td><p style=\"text-align: center;\">18</p></td><td><p style=\"text-align: center;\">3</p></td><td><p>payment-link-service</p></td></tr><tr><td><p><span style=\"color: rgb(255,86,48);\">No debe de mostrar como pausado al suscriptor</span></p><p>No se deber&iacute;a mostrar como pausado pero si buscar una forma de identificar si el pago fue adelantado para no confundir al usuario (ver con Carlos) </p></td><td><p style=\"text-align: center;\">24</p></td><td><p style=\"text-align: center;\">4</p></td><td><p>payment-link-portal</p></td></tr><tr><td><p>Habilitar funcionalidad para portal y API.</p><p>Crear endpoint en external-commerce-service para adelantar el pago y pausar el suscriptor</p></td><td><p style=\"text-align: center;\">18</p></td><td><p style=\"text-align: center;\">3</p></td><td><p>external-commerce-service</p></td></tr><tr><td><p>Registrar el pago manual en audit.</p></td><td><p style=\"text-align: center;\">ver con jhona</p></td><td><p style=\"text-align: center;\">ver con jhona</p></td><td><p>audit-service </p></td></tr><tr><td><p>Agregar bot&oacute;n y modal para crear adelanto de pago</p></td><td><p style=\"text-align: center;\">12</p></td><td><p style=\"text-align: center;\">2</p></td><td><p>payment-link-portal</p></td></tr><tr><td rowspan=\"4\"><p><strong>Actualizaci&oacute;n de Suscripciones</strong></p></td><td><p>Modificar el endpoint para que permita actualizar el campo descripci&oacute;n y fecha de fin de cobro</p><ul><li><p><em>Utilizar el mismo servicio de actualizaci&oacute;n de monto.</em></p></li></ul><ul><li><p><em>Solo se van a editar los campos que tengan info, los que se dejen en blanco no deben modificarse</em></p></li></ul></td><td><p style=\"text-align: center;\">24</p></td><td><p style=\"text-align: center;\">3</p></td><td><p>payment-link-service</p></td></tr><tr><td><p>Modificar el endpoint en external-commerce-service que permita actualizar el campo descripci&oacute;n y fecha de fin de cobro</p></td><td><p style=\"text-align: center;\">24</p></td><td><p style=\"text-align: center;\">3</p></td><td><p>external-commerce-service</p></td></tr><tr><td><p>Agregar opci&oacute;n para editar la suscripci&oacute;n en payment-link-portal. </p><ul><li><p>Agregar el l&aacute;piz para el edit</p></li><li><p>La edici&oacute;n de los campos va a ser inline (no vamos a abrir un modal) </p></li></ul></td><td><p style=\"text-align: center;\">40</p></td><td><p style=\"text-align: center;\">5</p></td><td><p>payment-link-portal</p></td></tr><tr><td><p>Registrar la actualizaci&oacute;n en audit.</p></td><td><p>ver con jhona</p></td><td><p>ver con jhona</p></td><td><p>audit-service</p></td></tr><tr><td rowspan=\"3\"><p><strong>Borrado de Suscripciones</strong></p></td><td><p>Modificar el endpoint de actualizar suscriptor para deshabilitarlo.</p></td><td><p style=\"text-align: center;\">8</p></td><td><p style=\"text-align: center;\">1</p></td><td><p>payment-link-service</p></td></tr><tr><td><p>Al momento de darse de alta, reactivar el mismo suscriptor. </p><ul><li><p><em>Investigar como se vincula la suscripci&oacute;n con el usuario para dar de alta esa suscripci&oacute;n</em></p></li><li><p><em>Si el usuario se da de alta con otra tarjeta, hay que actualizar el user_card_id</em></p></li></ul></td><td><p style=\"text-align: center;\">24</p></td><td><p style=\"text-align: center;\">3</p></td><td><p /></td></tr><tr><td><p>Registrar la actualizaci&oacute;n en audit.</p></td><td><p>ver con jhona</p></td><td><p>ver con jhona</p></td><td><p>audit-service</p></td></tr><tr><td colspan=\"2\"><p>Total Desarrollo</p></td><td><p>360</p></td><td><p>45</p></td><td><p /></td></tr><tr><td colspan=\"2\"><p>QA y Bug Fixing 20%</p></td><td><p>72</p></td><td><p>9</p></td><td><p /></td></tr><tr><td data-highlight-colour=\"#e3fcef\" colspan=\"2\"><p>Total</p></td><td data-highlight-colour=\"#e3fcef\"><p>432hs</p></td><td data-highlight-colour=\"#e3fcef\"><p>54d</p></td><td data-highlight-colour=\"#e3fcef\"><p /></td></tr><tr><td colspan=\"2\"><p>Management 15% (para facturaci&oacute;n)</p></td><td><p>64</p></td><td><p>8</p></td><td><p /></td></tr><tr><td colspan=\"2\"><p>Total Desarrollo + Management (para facturaci&oacute;n, no afecta fecha de entrega)</p></td><td><p>496hs</p></td><td><p>62d</p></td><td><p /></td></tr></tbody></table>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/2903343117"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":91986425},"_expandable":{"childTypes":"","co