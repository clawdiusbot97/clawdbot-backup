ntent/2757296194/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/2757296194/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/2757296194","tinyui":"/x/QgBZp","editui":"/pages/resumedraft.action?draftId=2757296194","webui":"/spaces/BAN/pages/2757296194/Archived+Initiatives","edituiv2":"/spaces/BAN/pages/edit-v2/2757296194"}},{"id":"3063087149","type":"page","ari":"ari:cloud:confluence:4e3a1a04-13f1-4674-95f6-44812aec1da3:page/3063087149","base64EncodedAri":"YXJpOmNsb3VkOmNvbmZsdWVuY2U6NGUzYTFhMDQtMTNmMS00Njc0LTk1ZjYtNDQ4MTJhZWMxZGEzOmNvbnRlbnQvMzA2MzA4NzE0OQ==","status":"current","title":"Facturación Electrónica","macroRenderedOutput":{},"extensions":{"position":172688813},"_expandable":{"container":"/rest/api/space/BAN","metadata":"","restrictions":"/rest/api/content/3063087149/restriction/byOperation","history":"/rest/api/content/3063087149/history","body":"","version":"","descendants":"/rest/api/content/3063087149/descendant","space":"/rest/api/space/BAN","childTypes":"","schedulePublishInfo":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3063087149/child","ancestors":"","draftVersion":""},"_links":{"self":"https://qubika.atlassian.net/wiki/rest/api/content/3063087149","tinyui":"/x/LQCTtg","editui":"/pages/resumedraft.action?draftId=3063087149","webui":"/spaces/BAN/pages/3063087149/Facturaci+n+Electr+nica","edituiv2":"/spaces/BAN/pages/edit-v2/3063087149"}}],"macroRenderedOutput":{},"body":{"storage":{"value":"<ac:structured-macro ac:name=\"info\" ac:schema-version=\"1\" ac:macro-id=\"e8bf55eb-679e-4347-9afd-dfe4d1503c93\"><ac:rich-text-body><p>Este documento representa el tasking y estimaci&oacute;n para <em>las tareas adicionales que el equipo de Qubika fue tomando por fuera de la estimaci&oacute;n inicial.</em></p><p>Las horas totales de desarrollo son 172.</p><p>Las horas restantes de desarrollo para los cambios nuevos que surgieron para la creaci&oacute;n de la oportunidad comercial son </p></ac:rich-text-body></ac:structured-macro><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"d127e8c3-3fed-4af2-bc1b-c09b7117def2\"><colgroup><col style=\"width: 322.0px;\" /><col style=\"width: 113.0px;\" /><col style=\"width: 323.0px;\" /></colgroup><tbody><tr><th><p><strong>Tarea</strong></p></th><th><p style=\"text-align: center;\"><strong>Estimaci&oacute;n (hs)</strong></p></th><th><p><strong>Servicio / Portal</strong></p></th></tr><tr><td data-highlight-colour=\"#abf5d1\"><p>Solicitud de C&oacute;digo de Verificaci&oacute;n en modal para retomar proceso de Onboarding</p></td><td data-highlight-colour=\"#abf5d1\"><p style=\"text-align: center;\">4</p></td><td data-highlight-colour=\"#abf5d1\"><p>commerce-suite</p></td></tr><tr><td data-highlight-colour=\"#abf5d1\"><p>Modificar validaci&oacute;n de OTP para no usar el company_type</p></td><td data-highlight-colour=\"#abf5d1\"><p style=\"text-align: center;\">6</p></td><td data-highlight-colour=\"#abf5d1\"><p>commerce-service</p></td></tr><tr><td data-highlight-colour=\"#abf5d1\"><p>Verificaci&oacute;n doble de Email en pantalla de registro de usuario</p><p><em>No acepta copy-paste</em></p></td><td data-highlight-colour=\"#abf5d1\"><p style=\"text-align: center;\">6</p></td><td data-highlight-colour=\"#abf5d1\"><p>commerce-suite</p></td></tr><tr><td data-highlight-colour=\"#abf5d1\"><p>Modificar el acceso code para que sea de 6 d&iacute;gitos</p></td><td data-highlight-colour=\"#abf5d1\"><p style=\"text-align: center;\">4</p></td><td data-highlight-colour=\"#abf5d1\"><p>commerce-service</p></td></tr><tr><td data-highlight-colour=\"#fff0b3\"><p>Datos adicionales en pantalla de Ingreso de Contrase&ntilde;a</p><p><em>Posibilidad de agregar hasta 2 RRLL</em></p></td><td data-highlight-colour=\"#fff0b3\"><p style=\"text-align: center;\">12</p></td><td data-highlight-colour=\"#fff0b3\"><p>commerce-suite</p></td></tr><tr><td data-highlight-colour=\"#fff0b3\"><p>Creaci&oacute;n del Nodo de RRLL </p><p><em>Obtenci&oacute;n de datos env&iacute;o</em></p><p><em>Aca tenemos que usar de referencia el ejemplo del env&iacute;o de la cuenta bancaria</em></p></td><td data-highlight-colour=\"#fff0b3\"><p style=\"text-align: center;\">12</p></td><td data-highlight-colour=\"#fff0b3\"><p>external-commerce-service</p></td></tr><tr><td data-highlight-colour=\"#fff0b3\"><p>Creaci&oacute;n de la l&oacute;gica del env&iacute;o de la informacion de RRLL</p></td><td data-highlight-colour=\"#fff0b3\"><p style=\"text-align: center;\">4</p></td><td data-highlight-colour=\"#fff0b3\"><p>commerce-service</p></td></tr><tr><td data-highlight-colour=\"#fff0b3\"><p>Creaci&oacute;n de el Nodo de Actividades Econ&oacute;micas</p><p><em>Se crea un nodo por cada una de las AAEE</em></p></td><td data-highlight-colour=\"#fff0b3\"><p style=\"text-align: center;\">12</p></td><td data-highlight-colour=\"#fff0b3\"><p>external-commerce-service</p></td></tr><tr><td data-highlight-colour=\"#fff0b3\"><p>Creaci&oacute;n de la l&oacute;gica del env&iacute;o de la informaci&oacute;n de AAEE</p></td><td data-highlight-colour=\"#fff0b3\"><p style=\"text-align: center;\">4</p></td><td data-highlight-colour=\"#fff0b3\"><p>commerce-service</p></td></tr><tr><td data-highlight-colour=\"#fff0b3\"><p>Creaci&oacute;n de el Nodo de Establecimientos</p></td><td data-highlight-colour=\"#fff0b3\"><p style=\"text-align: center;\">12</p></td><td data-highlight-colour=\"#fff0b3\"><p>external-commerce-service</p></td></tr><tr><td data-highlight-colour=\"#fff0b3\"><p>Creaci&oacute;n de la l&oacute;gica de env&iacute;o de la informaci&oacute;n de Establecimientos</p></td><td data-highlight-colour=\"#fff0b3\"><p style=\"text-align: center;\">4</p></td><td data-highlight-colour=\"#fff0b3\"><p>commerce-serice</p></td></tr><tr><td data-highlight-colour=\"#fff0b3\"><p>Agregar datos de score vs ci y score vs extracci&oacute;n de DIA a la OC</p></td><td data-highlight-colour=\"#fff0b3\"><p style=\"text-align: center;\">4</p></td><td data-highlight-colour=\"#fff0b3\"><p>commerce-service</p></td></tr><tr><td data-highlight-colour=\"#abf5d1\"><p>Modificar el endpoint de get_opportunity_products y get_opportunity_plans para identificar el tipo de onboarding, si es para clientes nuevos o existentes, y en base a eso que nos devuelva que productos y planes se traen</p></td><td data-highlight-colour=\"#abf5d1\"><p style=\"text-align: center;\">16</p></td><td data-highlight-colour=\"#abf5d1\"><p>commerce-service</p></td></tr><tr><td data-highlight-colour=\"#abf5d1\"><p>Modificar vistas con llamado a get_opportunity_products y get_opportunity_plans para que solo traiga los planes y productos que corresponden al onboarding de nuevos clientes </p></td><td data-highlight-colour=\"#abf5d1\"><p style=\"text-align: center;\">4</p></td><td data-highlight-colour=\"#abf5d1\"><p>commerce-suite</p></td></tr><tr><td data-highlight-colour=\"#abf5d1\"><p>Cambios en la pantalla de Resumen. </p><p><em>Definir que productos tienen un contador para agregar m&aacute;s de uno (Ej POS Android), y cuales no (Ej TPago)</em></p></td><td data-highlight-colour=\"#abf5d1\"><p style=\"text-align: center;\">12</p></td><td data-highlight-colour=\"#abf5d1\"><p>commerce-suite</p></td></tr><tr><td data-highlight-colour=\"#abf5d1\"><p>Investigaci&oacute;n y estimaci&oacute;n de secci&oacute;n de biometr&iacute;a. </p></td><td data-highlight-colour=\"#abf5d1\"><p style=\"text-align: center;\">32</p></td><td data-highlight-colour=\"#abf5d1\"><p>-</p></td></tr><tr><td data-highlight-colour=\"#abf5d1\"><p>Investigaci&oacute;n y estimaci&oacute;n de secci&oacute;n de carga de archivos</p></td><td data-highlight-colour=\"#abf5d1\"><p style=\"text-align: center;\">24</p></td><td data-highlight-colour=\"#abf5d1\"><p>-</p></td></tr><tr><td data-highlight-colour=\"#eae6ff\"><p><strong>Total Desarrollo</strong></p></td><td data-highlight-colour=\"#eae6ff\"><p style=\"text-align: center;\">172</p></td><td data-highlight-colour=\"#eae6ff\"><p /></td></tr><tr><td data-highlight-colour=\"#eae6ff\"><p><strong>Total Gesti&oacute;n 15% (para facturaci&oacute;n, no afecta el desarrollo)</strong></p><p><em>Incluye reuniones de estimaci&oacute;n, planificaci&oacute;n, t&eacute;cnicas y de seguimiento.</em></p></td><td data-highlight-colour=\"#eae6ff\"><p style=\"text-align: center;\">25</p></td><td data-highlight-colour=\"#eae6ff\"><p /></td></tr><tr><td data-highlight-colour=\"#eae6ff\"><p><strong>Total Desarrollo + Gesti&oacute;n</strong></p></td><td data-highlight-colour=\"#eae6ff\"><p style=\"text-align: center;\"><strong>197</strong></p></td><td data-highlight-colour=\"#eae6ff\"><p /></td></tr></tbody></table>","representation":"storage","embeddedContent":[],"_expandable":{"content":"/rest/api/content/3275489281"}},"_expandable":{"editor":"","atlas_doc_format":"","view":"","export_view":"","styled_view":"","dynamic":"","editor2":"","anonymous_export_view":""}},"extensions":{"position":6752},"_expandable":{"childTypes":"","container":"/rest/api/space/BAN","schedulePublishInfo":"","metadata":"","operations":"","schedulePublishDate":"","children":"/rest/api/content/3275489281/child","restrictions":"/rest/api/content/3275489281/restriction/byOperation","history":"/rest/api/content/3275489281/history","draftVersion":"","descendants":"/rest/api/content/3275489281/descendant","space":"/rest/api/space/BAN"},"_links":{"editui":"/pages/resumedraft.action?draftId=3275489281","webui":"/spaces/BAN/pages/3275489281/Facturaci+n+Electr+nica+-+Tareas+Adicionales+-+Tasking+y+Estimaci+n","edituiv2":"/spaces/BAN/pages/edit-v2/3275489281","context":"/wiki","self":"https://qubika.atlassian.net/wiki/rest/api/content/3275489281","tinyui":"/x/AQA8ww","collection":"/rest/api/content","base":"https://qubika.atlassian.net/wiki"}}